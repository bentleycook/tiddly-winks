#!/usr/bin/env bash
# tw — tiddly-winks: Feature Space Manager
# Manages named tmux sessions per feature with dynamic port allocation, Caddy routing,
# git worktrees, isolated databases, and bead-backed persistent context.
# See https://github.com/bentleycook/tiddly-winks for docs.

set -euo pipefail

TW_DIR="$HOME/.tiddly-winks"
SESSIONS_FILE="$TW_DIR/sessions.json"
CADDYFILE="$TW_DIR/Caddyfile"
CADDY_ADMIN="http://localhost:2019"
# Find Caddy binary: environment override > PATH > common locations
if [[ -n "${CADDY_BIN:-}" ]]; then
    : # user override
elif command -v caddy &>/dev/null; then
    CADDY_BIN="$(command -v caddy)"
elif [[ -x /opt/homebrew/bin/caddy ]]; then
    CADDY_BIN="/opt/homebrew/bin/caddy"
elif [[ -x /usr/local/bin/caddy ]]; then
    CADDY_BIN="/usr/local/bin/caddy"
else
    CADDY_BIN="caddy"  # hope it's on PATH at runtime
fi

# Source machine-local secrets (.env not checked in)
[[ -f "$TW_DIR/.env" ]] && source "$TW_DIR/.env"

# ─── Helpers ────────────────────────────────────────────────────────────────

log()  { echo "[tw] $*" >&2; }
die()  { echo "[tw] error: $*" >&2; exit 1; }
info() { echo "$*"; }

# Read a top-level key from a YAML file
yaml_get() {
    local file="$1" key="$2" default="${3:-}"
    python3 - "$file" "$key" "$default" <<'EOF'
import yaml, sys
try:
    d = yaml.safe_load(open(sys.argv[1]))
    val = d.get(sys.argv[2], sys.argv[3]) if d else sys.argv[3]
    print(val if val is not None else sys.argv[3])
except Exception:
    print(sys.argv[3])
EOF
}

# Read a nested key (dot-separated) from a YAML file
yaml_get_nested() {
    local file="$1" keypath="$2" default="${3:-}"
    python3 - "$file" "$keypath" "$default" <<'EOF'
import yaml, sys
try:
    d = yaml.safe_load(open(sys.argv[1]))
    keys = sys.argv[2].split('.')
    for k in keys:
        d = d.get(k, None) if isinstance(d, dict) else None
    print(d if d is not None else sys.argv[3])
except Exception:
    print(sys.argv[3])
EOF
}

# Scrub likely secrets (API keys, tokens) from text before storing in beads
# or injecting into prompts. Replaces values with [REDACTED].
scrub_secrets() {
    python3 -c "
import re, sys

text = sys.stdin.read()

# 1. Well-known prefixed keys (standalone match — no lookbehind needed)
prefixed = [
    r'(?:sk|pk|ce|rk)_(?:live|test)_[A-Za-z0-9]{10,}',  # Clerk, Stripe
    r'sk-[A-Za-z0-9_-]{20,}',                             # OpenAI
    r'AKIA[0-9A-Z]{16}',                                  # AWS access key
    r'gh[pousr]_[A-Za-z0-9_]{16,}',                       # GitHub tokens
    r'xox[bpas]-[A-Za-z0-9-]{10,}',                       # Slack tokens
    r'AIza[A-Za-z0-9_-]{30,}',                            # Google API keys
]
for p in prefixed:
    text = re.sub(p, '[REDACTED]', text)

# 2. Label + separator + secret (capture prefix, replace secret)
#    Uses \\1 backreference to keep the label, redact only the value
labeled = [
    # key=val, key: val, key val patterns (case-insensitive label)
    (r'([Kk][Ee][Yy][\s=:]+)[A-Za-z0-9_-]{20,}', r'\1[REDACTED]'),
    (r'([Tt][Oo][Kk][Ee][Nn][\s=:]+)[A-Za-z0-9_-]{20,}', r'\1[REDACTED]'),
    (r'([Ss][Ee][Cc][Rr][Ee][Tt][\s=:]+)[A-Za-z0-9_-]{20,}', r'\1[REDACTED]'),
    (r'([Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd][\s=:]+)\S{8,}', r'\1[REDACTED]'),
    (r'([Bb]earer\s+)[A-Za-z0-9._-]{20,}', r'\1[REDACTED]'),
    (r'([Aa][Pp][Ii]\s[Kk][Ee][Yy]\s+)[A-Za-z0-9_-]{10,}', r'\1[REDACTED]'),
]
for p, repl in labeled:
    text = re.sub(p, repl, text)

# 3. Env-var style: NAME_KEY=long-secret on its own line
text = re.sub(
    r'(?m)^([A-Z][A-Z0-9_]*(?:_KEY|_SECRET|_TOKEN|_PASSWORD|_CREDENTIALS)=)[^\s]{8,}',
    r'\1[REDACTED]', text)

sys.stdout.write(text)
"
}

# Get all service names from a YAML file
yaml_service_names() {
    local file="$1"
    python3 - "$file" <<'EOF'
import yaml, sys
try:
    d = yaml.safe_load(open(sys.argv[1]))
    services = d.get('services', {}) or {}
    print('\n'.join(services.keys()))
except Exception:
    pass
EOF
}

# Get a service attribute
yaml_service_get() {
    local file="$1" service="$2" attr="$3" default="${4:-}"
    python3 - "$file" "$service" "$attr" "$default" <<'EOF'
import yaml, sys
try:
    d = yaml.safe_load(open(sys.argv[1]))
    s = (d.get('services', {}) or {}).get(sys.argv[2], {}) or {}
    val = s.get(sys.argv[3], sys.argv[4])
    print(val if val is not None else sys.argv[4])
except Exception:
    print(sys.argv[4])
EOF
}

# Get workers as "name:role\n..." pairs
# Supports multiple formats:
#   workers: [dev-1, dev-2]              → name-only list (generic workers)
#   workers: {dev: {role: backend-dev}}  → dict with roles (legacy)
#   workers: {dev-1: {}, dev-2: {}}     → dict without roles (generic)
#   pool_size: 3                         → generates dev-1..dev-N (generic)
yaml_worker_pairs() {
    local file="$1"
    python3 - "$file" <<'EOF'
import yaml, sys
try:
    d = yaml.safe_load(open(sys.argv[1]))
    workers = d.get('workers', None)
    pool_size = d.get('pool_size', 0)
    default_engine = d.get('engine', '')
    if isinstance(workers, list):
        # List format: [dev-1, dev-2, ...]
        for name in workers:
            print(f"{name}::{default_engine}")
    elif isinstance(workers, dict):
        for name, info in workers.items():
            role = (info or {}).get('role', '') if isinstance(info, dict) else ''
            engine = (info or {}).get('engine', default_engine) if isinstance(info, dict) else default_engine
            print(f"{name}:{role}:{engine}")
    elif pool_size and int(pool_size) > 0:
        for i in range(1, int(pool_size) + 1):
            print(f"dev-{i}::{default_engine}")
except Exception:
    pass
EOF
}

# Get review entries as "r-name:prompt_path:engine\n..." triples from reviews: section
yaml_review_entries() {
    local file="$1"
    python3 - "$file" <<'EOF'
import yaml, sys
try:
    d = yaml.safe_load(open(sys.argv[1]))
    reviews = d.get('reviews', None)
    default_engine = d.get('engine', '')
    if isinstance(reviews, dict):
        for name, info in reviews.items():
            prompt = (info or {}).get('prompt', '') if isinstance(info, dict) else ''
            engine = (info or {}).get('engine', default_engine) if isinstance(info, dict) else default_engine
            print(f"r-{name}:{prompt}:{engine}")
except Exception:
    pass
EOF
}

# Get proxy map as "subdomain:service\n..." pairs
yaml_proxy_pairs() {
    local file="$1"
    python3 - "$file" <<'EOF'
import yaml, sys
try:
    d = yaml.safe_load(open(sys.argv[1]))
    proxy = d.get('proxy', {}) or {}
    for subdomain, service in proxy.items():
        print(f"{subdomain}:{service}")
except Exception:
    pass
EOF
}

# Get quality gates as "name:command\n..." pairs
yaml_quality_gates() {
