except Exception:
    pass
EOF
}

# Template env files using allocated service ports.
# Reads the 'env_files' section from .tw.yml and writes templated values
# into the target files within the given worktree/config directory.
#
# .tw.yml format:
#   env_files:
#     .env.local:                          # target file (relative to service path or config dir)
#       VITE_API_URL: 'http://localhost:{{backend.port}}'
#       API_PORT: '{{server.port}}'
#
# service_ports_json: JSON object like {"backend": 5006, "frontend": 5173}
template_env_files() {
    local config_file="$1" config_dir="$2" service_ports_json="$3"
    python3 - "$config_file" "$config_dir" "$service_ports_json" <<'PYEOF'
import yaml, sys, os, re, json

config_file = sys.argv[1]
config_dir = sys.argv[2]
service_ports = json.loads(sys.argv[3])

try:
    d = yaml.safe_load(open(config_file))
    env_files = d.get('env_files', {}) or {}
except Exception:
    sys.exit(0)

if not env_files:
    sys.exit(0)

# Also read worktree paths from the config to resolve service paths
services = d.get('services', {}) or {}

for target_file, vars_dict in env_files.items():
    if not isinstance(vars_dict, dict):
        continue

    # Determine which service this env file belongs to (if target starts with a service path)
    # Otherwise, write relative to config_dir
    abs_target = os.path.join(config_dir, target_file)

    # Read existing file if it exists, so we can update in place
    existing = {}
    if os.path.isfile(abs_target):
        for line in open(abs_target):
            line = line.strip()
            if line and not line.startswith('#') and '=' in line:
                k, _, v = line.partition('=')
                existing[k.strip()] = v.strip()

    # Template each variable
    for var_name, template in vars_dict.items():
        value = str(template)
        # Replace {{service.port}} with actual port
        for svc_name, port in service_ports.items():
            value = value.replace('{{' + svc_name + '.port}}', str(port))
        existing[var_name] = value

    # Write the file
    os.makedirs(os.path.dirname(abs_target), exist_ok=True)
    with open(abs_target, 'w') as f:
        for k, v in existing.items():
            f.write(f'{k}={v}\n')

    print(f'Templated: {target_file} ({len(vars_dict)} vars)')
PYEOF
}

# Merge override YAML into base YAML (override wins for service paths)
# Returns merged YAML file path (temp file)
yaml_merge_override() {
    local base="$1" override="$2"
    python3 - "$base" "$override" <<'EOF'
import yaml, sys, tempfile, os
base = yaml.safe_load(open(sys.argv[1])) or {}
try:
    ov = yaml.safe_load(open(sys.argv[2])) or {}
    # Merge services
    for svc, attrs in (ov.get('services') or {}).items():
        if svc in (base.get('services') or {}):
            base['services'][svc].update(attrs)
        else:
            base.setdefault('services', {})[svc] = attrs
except Exception:
    pass
f = tempfile.NamedTemporaryFile(mode='w', suffix='.yml', delete=False)
yaml.dump(base, f)
f.close()
print(f.name)
EOF
}

# JSON helpers
json_get() { python3 -c "import json,sys; d=json.load(open('$SESSIONS_FILE')); print(d.get('$1', {}).get('$2', ''))" 2>/dev/null; }

sessions_read() {
    python3 -c "import json; print(json.dumps(json.load(open('$SESSIONS_FILE'))))" 2>/dev/null || echo '{}'
}

sessions_write() {
    # Receives JSON on stdin — atomic write via temp + rename
    python3 -c "
import json, sys, os, tempfile
data = json.loads(sys.stdin.read())
target = '$SESSIONS_FILE'
parent = os.path.dirname(target)
fd, tmp = tempfile.mkstemp(dir=parent, suffix='.tmp')
try:
    with os.fdopen(fd, 'w') as f:
        json.dump(data, f, indent=2)
        f.write('\n')
        f.flush()
        os.fsync(f.fileno())
    os.rename(tmp, target)
except:
    os.unlink(tmp)
    raise
"
}

# Atomic JSON write helper for any file. Receives JSON on stdin.
# Usage: echo '{}' | safe_write_json /path/to/file.json
safe_write_json() {
    local target="$1"
    python3 -c "
import json, sys, os, tempfile
data = json.loads(sys.stdin.read())
target = sys.argv[1]
parent = os.path.dirname(target)
os.makedirs(parent, exist_ok=True)
fd, tmp = tempfile.mkstemp(dir=parent, suffix='.tmp')
try:
    with os.fdopen(fd, 'w') as f:
        json.dump(data, f, indent=2)
        f.write('\n')
        f.flush()
        os.fsync(f.fileno())
    os.rename(tmp, target)
except:
    os.unlink(tmp)
    raise
" "$target"
}

sessions_get_key() {
    local session_key="$1" field="$2"
    python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
print(d.get('$session_key', {}).get('$field', ''))
" 2>/dev/null
}

sessions_list_keys() {
    python3 -c "import json; [print(k) for k in json.load(open('$SESSIONS_FILE')).keys()]" 2>/dev/null
}

# Add a dynamic worker to session state
sessions_add_dynamic_worker() {
    local session_key="$1" name="$2" role="${3:-}" engine="${4:-claude}"
    python3 -c "
import json, sys, os, tempfile
sk, name, role, engine = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
target = '$SESSIONS_FILE'
with open(target) as f:
    d = json.load(f)
session = d.get(sk, {})
dw = session.get('dynamic_workers', [])
# Don't add duplicates
if not any(w['name'] == name for w in dw):
    dw.append({'name': name, 'role': role, 'engine': engine})
session['dynamic_workers'] = dw
d[sk] = session
parent = os.path.dirname(target)
fd, tmp = tempfile.mkstemp(dir=parent, suffix='.tmp')
try:
    with os.fdopen(fd, 'w') as f:
        json.dump(d, f, indent=2)
        f.write('\n')
        f.flush()
        os.fsync(f.fileno())
    os.rename(tmp, target)
except:
    os.unlink(tmp)
    raise
" "$session_key" "$name" "$role" "$engine"
}

# Remove a dynamic worker from the session's dynamic_workers array
sessions_remove_dynamic_worker() {
    local session_key="$1" name="$2"
    python3 -c "
import json, sys, os, tempfile
sk, name = sys.argv[1], sys.argv[2]
target = '$SESSIONS_FILE'
with open(target) as f:
    d = json.load(f)
session = d.get(sk, {})
dw = session.get('dynamic_workers', [])
session['dynamic_workers'] = [w for w in dw if w['name'] != name]
d[sk] = session
parent = os.path.dirname(target)
fd, tmp = tempfile.mkstemp(dir=parent, suffix='.tmp')
try:
    with os.fdopen(fd, 'w') as f:
        json.dump(d, f, indent=2)
        f.write('\n')
        f.flush()
        os.fsync(f.fileno())
    os.rename(tmp, target)
except:
    os.unlink(tmp)
    raise
" "$session_key" "$name"
}

# Get dynamic workers as name:role:engine triples (same format as yaml_worker_pairs)
sessions_get_dynamic_workers() {
    local session_key="$1"
    python3 -c "
import json, sys
d = json.load(open('$SESSIONS_FILE'))
dw = d.get(sys.argv[1], {}).get('dynamic_workers', [])
for w in dw:
    print(f\"{w['name']}:{w.get('role', '')}:{w.get('engine', '')}\")
" "$session_key" 2>/dev/null
}

# Resolve a feature-or-index argument into session variables.
# Sets in the CALLER's scope: session_key, project, config_dir, tmux_session, bead_id
# Accepts: numeric index (from tw list), exact feature name, or substring match.
resolve_session() {
    local _rs_feature="$1"

    if [[ "$_rs_feature" =~ ^[0-9]+$ ]]; then
        # Index-based: resolve Nth session from sessions.json (1-based, matches tw list)
        local _rs_data
        _rs_data=$(sessions_read)
        session_key=$(python3 - "$_rs_data" "$_rs_feature" <<'PYEOF'
import json, sys
data = json.loads(sys.argv[1])
idx = int(sys.argv[2])
keys = list(data.keys())
if 1 <= idx <= len(keys):
    print(keys[idx - 1])
PYEOF
        )
        [[ -z "$session_key" ]] && die "No session at index $_rs_feature"
        project=$(sessions_get_key "$session_key" "project")
        config_dir=$(sessions_get_key "$session_key" "workspace")
    else
        # String-based: try find_config first (CWD-aware), then sessions.json
        local _rs_config_file
        if _rs_config_file=$(find_config 2>/dev/null); then
            project=$(yaml_get "$_rs_config_file" "project" "")
            config_dir="$(dirname "$_rs_config_file")"
            session_key="${project}-${_rs_feature}"
            # Verify the synthesized key exists. If not, fall back to
            # sessions.json lookup so `tw done <feat>` from the "wrong"
            # workspace still resolves instead of silently fabricating a
            # non-existent key. Update project/config_dir from the match.
            if ! sessions_list_keys | grep -Fxq "$session_key"; then
                session_key=$(sessions_list_keys | grep -Fx "$_rs_feature" | head -1 || true)
                if [[ -z "$session_key" ]]; then
                    session_key=$(sessions_list_keys | grep -F "$_rs_feature" | head -1 || true)
                fi
                [[ -z "$session_key" ]] && die "No session for '$_rs_feature' (tried ${project}-${_rs_feature} and substring match across all projects)"
                project=$(sessions_get_key "$session_key" "project")
                config_dir=$(sessions_get_key "$session_key" "workspace")
            fi
        else
            session_key=$(sessions_list_keys | grep -Fx "$_rs_feature" | head -1 || true)
            if [[ -z "$session_key" ]]; then
                session_key=$(sessions_list_keys | grep -F "$_rs_feature" | head -1 || true)
            fi
            [[ -z "$session_key" ]] && die "No session found for '$_rs_feature'"
            project=$(sessions_get_key "$session_key" "project")
            config_dir=$(sessions_get_key "$session_key" "workspace")
        fi
    fi
    tmux_session="$session_key"
    bead_id=$(sessions_get_key "$session_key" "bead_id")
}

# ─── Tmux Color Theming ──────────────────────────────────────────────────────
#
# Assigns a stable color theme to each project using FNV-32a hash.
# Same project always gets the same color across sessions/restarts.

TW_THEME_PALETTE=(
    "ocean:#1a3a5c:#e0e8f0"
    "sunset:#8b4513:#ffd700"
    "forest:#2d5016:#90ee90"
    "berry:#5c1a5c:#dda0dd"
    "copper:#704214:#ffdead"
    "slate:#3c4f5c:#b0c4de"
    "wine:#5c1a2a:#ffb6c1"
    "teal:#1a5c5c:#afeeee"
    "ember:#5c2a0a:#ffa07a"
    "moss:#3a5c1a:#98fb98"
)

# Apply color theme to a tmux session
session_apply_theme() {
    local tmux_session="$1" project="$2" feature="$3" session_key="$4"

    local idx entry bg fg
    idx=$(python3 -c "import hashlib,sys; print(int(hashlib.md5(sys.argv[1].encode()).hexdigest(),16) % $((${#TW_THEME_PALETTE[@]})))" "$project")
    entry="${TW_THEME_PALETTE[$idx]}"
    bg="${entry#*:}"
    bg="${bg%%:*}"
    fg="${entry##*:}"

    tmux set -t "=$tmux_session" status-style "bg=$bg,fg=$fg" 2>/dev/null || true
    tmux set -t "=$tmux_session" status-left " [$project/$feature] " 2>/dev/null || true
    tmux set -t "=$tmux_session" status-left-length 40 2>/dev/null || true
    tmux set -t "=$tmux_session" status-right "#(tw status-bar $session_key)" 2>/dev/null || true
    tmux set -t "=$tmux_session" status-right-length 100 2>/dev/null || true
    tmux set -t "=$tmux_session" status-interval 30 2>/dev/null || true
}

# Generate status-right string with worker states + service health
# Called by tmux via: #(tw status-bar <session_key>)
# Must be fast — runs every 30s via tmux status-interval.
cmd_status_bar() {
    local session_key="$1"
    [[ -z "$session_key" ]] && return

    local out=""

    # ── Worker states from daemon health JSON ──
    local health_file="$TW_DIR/health/${session_key}.json"
    if [[ -f "$health_file" ]]; then
        out+=$(python3 -c "
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    icons = {
        'working':       '#[fg=green]⚙',
        'idle':          '#[fg=blue]◉',
        'stalled':       '#[fg=yellow]⚠',
        'dead':          '#[fg=red]✗',
        'not-logged-in': '#[fg=red]🔒',
        'circuit-broken':'#[fg=red]⊘',
    }
    parts = []
    for w in d.get('workers', []):
        name = w.get('name','?')[:3]
        status = w.get('status','')
        icon = icons.get(status, '#[fg=white]?')
        parts.append(f'{icon}#[default]{name}')
    print(' '.join(parts))
except Exception:
    pass
" "$health_file" 2>/dev/null || true)
    else
        # Fallback: output-file mtime heuristic
        local agents_dir="$TW_DIR/agents/${session_key}"
        if [[ -d "$agents_dir" ]]; then
            local now
            now=$(date +%s)
            for f in "$agents_dir"/*.md; do
                [[ -f "$f" ]] || continue
                local wname mtime age color
                wname=$(basename "$f" .md)
                mtime=$(stat -f %m "$f" 2>/dev/null || echo 0)
                age=$(( now - mtime ))
                if [[ $age -lt 300 ]]; then color="green"
                elif [[ $age -lt 600 ]]; then color="yellow"
                else color="red"; fi
                out+="#[fg=$color]● #[default]${wname:0:3} "
            done
        fi
    fi

    # ── Service health via port check ──
    local sessions_file="$TW_DIR/sessions.json"
    if [[ -f "$sessions_file" ]]; then
        local svc_status
        svc_status=$(python3 -c "
import json, sys, subprocess
try:
    d = json.load(open(sys.argv[1]))
    s = d.get(sys.argv[2], {})
    svcs = s.get('services', {})
    parts = []
    for name, info in svcs.items():
        port = info.get('port', '')
        if not port:
            continue
        try:
            r = subprocess.run(['lsof', '-i', f':{port}', '-sTCP:LISTEN'],
                               capture_output=True, timeout=2)
            up = r.returncode == 0
        except Exception:
            up = False
        icon = '#[fg=green]●' if up else '#[fg=red]●'
        parts.append(f'{icon}#[default]{name[:4]}')
    if parts:
        print(' '.join(parts))
except Exception:
    pass
" "$sessions_file" "$session_key" 2>/dev/null || true)
        if [[ -n "$svc_status" ]]; then
            [[ -n "$out" ]] && out+=" │ "
            out+="$svc_status"
        fi
    fi

    # ── Time ──
    [[ -n "$out" ]] && out+=" │ "
    out+=$(date +"%H:%M")

    echo "$out"
}

# ─── Activity Spinner ────────────────────────────────────────────────────────
#
# Background loop that shows braille spinner frames on worker tmux window names
# when a Claude process is actively using CPU. Runs per-session.

SPINNER_FRAMES=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
SPINNER_RESERVED="god|main|services"

spinner_start() {
    local tmux_session="$1" session_key="$2"
    local pid_file="$TW_DIR/spinner-${session_key}.pid"

    # Kill any existing spinner for this session
    if [[ -f "$pid_file" ]]; then
        kill "$(cat "$pid_file")" 2>/dev/null || true
        rm -f "$pid_file"
    fi

    # Launch spinner as a fully detached background process.
    # Redirect all FDs and use nohup to survive parent shell exit.
    nohup bash -c '
        pid_file="'"$pid_file"'"
        tmux_session="'"$tmux_session"'"
        SPINNER_FRAMES=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
        SPINNER_RESERVED="god|main|services"

        trap "rm -f \"$pid_file\"" EXIT
        echo $$ > "$pid_file"

        frame=0
        declare -A prev_state

        while tmux has-session -t "=$tmux_session" 2>/dev/null; do
            win_list=$(tmux list-windows -t "=$tmux_session" -F "#{window_index}:#{window_name}" 2>/dev/null) || break

            while IFS= read -r entry; do
                [[ -z "$entry" ]] && continue
                widx="${entry%%:*}"
                wname="${entry#*:}"

                base_name="${wname% [⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]}"
                [[ "$base_name" =~ ^($SPINNER_RESERVED)$ ]] && continue

                pane_pid=$(tmux list-panes -t "=$tmux_session:$widx" -F "#{pane_pid}" 2>/dev/null | head -1)
                [[ -z "$pane_pid" ]] && continue

                child_pid=$(pgrep -P "$pane_pid" -f "claude|cursor-agent|codex" 2>/dev/null | head -1)
                active=0
                if [[ -n "$child_pid" ]]; then
                    cpu=$(ps -p "$child_pid" -o %cpu= 2>/dev/null | xargs)
                    cpu_int="${cpu%%.*}"
                    if [[ -n "$cpu_int" && "$cpu_int" -gt 1 ]] 2>/dev/null; then
                        active=1
                    fi
                fi

                if [[ $active -eq 1 ]]; then
                    tmux rename-window -t "=$tmux_session:$widx" "$base_name ${SPINNER_FRAMES[$frame]}" 2>/dev/null || true
                    prev_state[$base_name]=1
                elif [[ "${prev_state[$base_name]:-0}" -eq 1 ]]; then
                    tmux rename-window -t "=$tmux_session:$widx" "$base_name" 2>/dev/null || true
                    prev_state[$base_name]=0
                fi
            done <<< "$win_list"

            frame=$(( (frame + 1) % ${#SPINNER_FRAMES[@]} ))
            sleep 0.3
        done
    ' </dev/null >/dev/null 2>&1 &
    disown $!
}

spinner_stop() {
    local session_key="$1"
    local pid_file="$TW_DIR/spinner-${session_key}.pid"
    if [[ -f "$pid_file" ]]; then
        kill "$(cat "$pid_file")" 2>/dev/null || true
        rm -f "$pid_file"
    fi
}

# ─── Port Allocation ─────────────────────────────────────────────────────────

# Track ports allocated in this run to avoid intra-session collisions
ALLOCATED_THIS_RUN=()

claimed_ports() {
    python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
ports = set()
for session in d.values():
    for svc in session.get('services', {}).values():
        p = svc.get('port')
        if p: ports.add(int(p))
print(' '.join(str(p) for p in ports))
" 2>/dev/null
}

port_in_use() {
    local port="$1"
    lsof -i ":$port" -t >/dev/null 2>&1
}

# Allocate a free port, avoiding ports already claimed in sessions.json, ports
# allocated earlier in THIS run, and ports currently in use by the OS.
#
# Uses a nameref out-param rather than stdout so the function runs in the
# caller's shell: `$(allocate_port …)` would execute in a subshell and any
# push to ALLOCATED_THIS_RUN would be discarded on return, causing two
# services with the same port_hint to both claim the hint.
#
# Usage:   allocate_port <out_var> <hint>
# Example: local p; allocate_port p 3000
allocate_port() {
    # Internal vars prefixed with __ to avoid nameref shadow: if a local var
    # has the same name as the caller's out-var (typical case: both named
    # "port"), the nameref resolves to the local instead of the caller.
    local -n __out_port="$1"
    local __hint="$2"
    local __port=$__hint
    local __claimed
    __claimed=$(claimed_ports)

    while true; do
        # Check not in sessions.json
        if echo " $__claimed " | grep -q " $__port "; then
            ((__port++)); continue
        fi
        # Check not allocated this run
        local __found=0
        for __p in "${ALLOCATED_THIS_RUN[@]:-}"; do
            [[ "$__p" == "$__port" ]] && { __found=1; break; }
        done
        [[ $__found -eq 1 ]] && { ((__port++)); continue; }
        # Check not in use by OS
        if port_in_use "$__port"; then
            ((__port++)); continue
        fi
        break
    done

    ALLOCATED_THIS_RUN+=("$__port")
    __out_port="$__port"
}

# ─── Caddyfile Generation ────────────────────────────────────────────────────

regen_caddyfile() {
    local overrides_dir="$TW_DIR/caddy-overrides"
    mkdir -p "$overrides_dir"
    python3 - "$SESSIONS_FILE" "$CADDYFILE" "$overrides_dir" <<'EOF'
import json, sys, os

sessions = json.load(open(sys.argv[1]))
overrides_dir = sys.argv[3]
lines = [
    '{',
    '    # Caddy admin API — needed for hot reload',
    '    admin localhost:2019',
    '}',
    '',
]

for session_key, session in sessions.items():
    project = session.get('project', '')
    feature = session.get('feature', '')
    services = session.get('services', {})
    proxy_map = session.get('proxy_map', {})

    # proxy_map: subdomain -> service name
    for subdomain, svc_name in proxy_map.items():
        svc = services.get(svc_name, {})
        port = svc.get('port')
        if not port:
            continue
        if subdomain == '':
            host = f'{project}-{feature}.localhost'
        else:
            host = f'{project}-{feature}-{subdomain}.localhost'

        override_file = os.path.join(overrides_dir, f'{host}.caddy')
        lines.append(f'http://{host} {{')
        if os.path.isfile(override_file):
            lines.append(f'    import {override_file}')
        else:
            lines.append(f'    reverse_proxy localhost:{port}')
        lines.append('}')
        lines.append('')

with open(sys.argv[2], 'w') as f:
    f.write('\n'.join(lines))
EOF
}

caddy_reload() {
    if curl -sf "$CADDY_ADMIN/config/" >/dev/null 2>&1; then
        curl -sf -X POST "$CADDY_ADMIN/load" \
            -H "Content-Type: text/caddyfile" \
            --data-binary "@$CADDYFILE" >/dev/null 2>&1 \
            && log "Caddy reloaded" \
            || log "Caddy reload failed — check $TW_DIR/logs/caddy.log"
    else
        log "Caddy admin API not reachable (is Caddy running?)"
    fi
}

# ─── Agent Communication ─────────────────────────────────────────────────────

agents_dir() { echo "$HOME/.tiddly-winks/agents/$1"; }

# Maximum concurrent Claude worker processes across all sessions.
# Safety net to prevent spawn storms from overwhelming the machine.
TW_MAX_WORKERS=${TW_MAX_WORKERS:-100}

# ── Engine abstraction ──────────────────────────────────────────────
# Check if a tmux window exists by name, accounting for spinner suffix (e.g., "test ⠼").
# Usage: tmux_window_exists <tmux_session> <window_name>
tmux_window_exists() {
    local tmux_session="$1" wname="$2"
    tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null \
        | grep -q "^${wname}\( [⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]\)\?$"
}

# Dispatch on engine name to support different AI CLI backends.
# Currently only 'claude' is implemented. Add cases for cursor, codex, etc.

engine_spawn_cmd() {
    local engine="$1" worker_name="$2" prompt_file="${3:-}"
    case "$engine" in
        claude) echo "claude --dangerously-skip-permissions --name '$worker_name'" ;;
        cursor)
            if [[ -n "$prompt_file" ]]; then
                echo "cursor-agent --force \"\$(cat '$prompt_file')\""
            else
                echo "cursor-agent --force"
            fi
            ;;
        *) die "Unknown engine: $engine" ;;
    esac
}

engine_process_pattern() {
    local engine="$1"
    case "$engine" in
        claude) echo "claude.*--dangerously-skip-permissions" ;;
        cursor) echo "cursor-agent" ;;
        *) echo "$engine" ;;
    esac
}

engine_wake_delay() {
    case "$1" in
        claude) echo 16 ;;
        cursor) echo 5 ;;
        *) echo 5 ;;
    esac
}

engine_wake_prompt() {
    case "$1" in
        claude) echo "You are now online. Read your role and context from the SessionStart hook above, then report ready to your output file." ;;
        cursor) echo "You are now online. Execute your task and write progress to your output file." ;;
        *) echo "You are now online. Execute your task and write progress to your output file." ;;
    esac
}

engine_supports_hooks() {
    case "$1" in
        claude) return 0 ;;
        cursor) return 1 ;;
        *) return 1 ;;
    esac
}

# Patterns indicating the worker is idle (at the prompt, ready for input).
engine_idle_pattern() {
    case "$1" in
        claude) echo '❯|bypass permissions|hold Space to speak|Sautéed for' ;;
        cursor) echo '❯|>' ;;
        *) echo '❯|>' ;;
    esac
}

# Patterns indicating the worker is busy (actively running tools).
engine_busy_pattern() {
    case "$1" in
        claude) echo 'esc to interrupt' ;;
        cursor) echo 'running|executing|processing' ;;
        *) echo 'running|processing' ;;
    esac
}

# Patterns indicating the worker is not authenticated.
engine_not_logged_in_pattern() {
    case "$1" in
        claude) echo 'Not logged in' ;;
        cursor) echo 'authentication required|API key invalid|unauthorized' ;;
        *) echo 'Not logged in|authentication required|API key invalid' ;;
    esac
}

# Command to gracefully exit the engine's session.
engine_exit_cmd() {
    case "$1" in
        claude) echo "/exit" ;;
        cursor) echo "C-c" ;;
        *) echo "/exit" ;;
    esac
}

# Build context preamble for non-hook engines.
# Writes full context (bead, role, task, output file) to a prompt file.
# Returns the prompt file path via stdout.
# Usage: engine_context_preamble <session_key> <worker> <engine>
engine_context_preamble() {
    local session_key="$1" wname="$2" engine="$3"

    # Only needed for non-hook engines
    engine_supports_hooks "$engine" && return 0

    local hooked_file="$HOME/.tiddly-winks/hooked/${session_key}/${wname}.json"
    [[ -f "$hooked_file" ]] || return 1

    local prompt_dir="$TW_DIR/prompts/${session_key}"
    mkdir -p "$prompt_dir"
    local prompt_file="$prompt_dir/${wname}.txt"

    # Read hooked JSON fields
    local _preamble_bead_id _preamble_wbead_id _preamble_role _preamble_output _preamble_task
    eval "$(python3 -c "
import json, shlex
d = json.load(open('$hooked_file'))
print(f'_preamble_bead_id={shlex.quote(d.get(\"bead_id\", \"\"))}')
print(f'_preamble_wbead_id={shlex.quote(d.get(\"worker_bead_id\", \"\"))}')
print(f'_preamble_role={shlex.quote(d.get(\"role\", \"\"))}')
print(f'_preamble_output={shlex.quote(d.get(\"output_file\", \"\"))}')
print(f'_preamble_task={shlex.quote(d.get(\"current_task\", \"\"))}')
" 2>/dev/null)"

    # Build prompt file
    > "$prompt_file"

    # Feature context from bead
    if [[ -n "$_preamble_bead_id" ]]; then
        echo "## Feature context (bead $_preamble_bead_id)" >> "$prompt_file"
        bd show "$_preamble_bead_id" 2>/dev/null >> "$prompt_file" || true
        echo "" >> "$prompt_file"
    fi

    # Worker identity
    if [[ -n "$_preamble_wbead_id" ]]; then
        echo "## Your identity (worker bead $_preamble_wbead_id)" >> "$prompt_file"
        bd show "$_preamble_wbead_id" 2>/dev/null >> "$prompt_file" || true
        echo "" >> "$prompt_file"
    fi

    # Role
    if [[ -n "$_preamble_role" ]] && [[ -f "$HOME/.claude/roles/${_preamble_role}.md" ]]; then
        echo "## Your role" >> "$prompt_file"
        cat "$HOME/.claude/roles/${_preamble_role}.md" >> "$prompt_file"
        echo "" >> "$prompt_file"
    fi

    # Output file instructions
    if [[ -n "$_preamble_output" ]]; then
        cat >> "$prompt_file" <<PREAMBLE_OUTPUT
## Output file

Your output file for this session: $_preamble_output

IMPORTANT: Write to your output file incrementally — append after each discrete
subtask, not just at the end. The orchestrator polls this file to track your
progress. If you only write at the end, you appear stuck/stalled.

Pattern:
  echo '## <subtask title>' >> $_preamble_output
  echo '<what you did, what you found>' >> $_preamble_output
PREAMBLE_OUTPUT
    fi

    # Current task
    if [[ -n "$_preamble_task" ]]; then
        cat >> "$prompt_file" <<PREAMBLE_TASK

## CURRENT TASK (execute this immediately)

$_preamble_task

When complete, report results to your output file.
PREAMBLE_TASK
    fi

    echo "$prompt_file"
}

# Look up the engine for a worker from sessions.json.
# Falls back to "claude" if not set.
worker_engine() {
    local session_key="$1" wname="$2"
    python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
s = d.get(sys.argv[2], {})
w = s.get('workers', {}).get(sys.argv[3], {})
print(w.get('engine', 'claude'))
" "$HOME/.tiddly-winks/sessions.json" "$session_key" "$wname" 2>/dev/null || echo claude
}

# Resolve engine for a session — check .tw.yml, fall back to 'claude'
resolve_engine() {
    local engine="$1" config_file="${2:-}"
    [[ -n "$engine" ]] && echo "$engine" && return
    if [[ -n "$config_file" && -f "$config_file" ]]; then
        yaml_get "$config_file" "engine" "claude"
    else
        echo "claude"
    fi
}

# Track engine spawn for load-balancing visibility.
# Increments counter at $TW_DIR/engine-usage/<engine>/<YYYY-MM-DD>.count
engine_track_usage() {
    local engine="$1"
    local date_str
    date_str=$(date +%Y-%m-%d)
    local usage_dir="$TW_DIR/engine-usage/$engine"
    mkdir -p "$usage_dir"
    local count_file="$usage_dir/$date_str.count"
    local current=0
    [[ -f "$count_file" ]] && current=$(cat "$count_file")
    echo $((current + 1)) > "$count_file"
}

# Returns engine usage summary for today (e.g. "claude=5 cursor=2")
engine_usage_summary() {
    local date_str
    date_str=$(date +%Y-%m-%d)
    local usage_dir="$TW_DIR/engine-usage"
    local summary=""
    if [[ -d "$usage_dir" ]]; then
        for engine_dir in "$usage_dir"/*/; do
            [[ -d "$engine_dir" ]] || continue
            local engine
            engine=$(basename "$engine_dir")
            local count=0
            local count_file="$engine_dir/$date_str.count"
            [[ -f "$count_file" ]] && count=$(cat "$count_file")
            summary+="$engine=$count "
        done
    fi
    [[ -z "$summary" ]] && summary="no usage tracked yet"
    echo "$summary"
}

# Capture pane output before killing/respawning a worker.
# Saves the last 1000 lines to agents/<session>/<worker>-last-screen.txt
capture_pane() {
    local tmux_target="$1" session_key="$2" wname="$3"
    local agents_path
    agents_path="$(agents_dir "$session_key")"
    mkdir -p "$agents_path"
    tmux capture-pane -t "$tmux_target" -p -S -1000 \
        > "$agents_path/${wname}-last-screen.txt" 2>/dev/null || true
}

# Spawn a worker window and wire up hook-based context injection.
# Usage: spawn_worker <tmux_session> <session_key> <config_dir> <wname> <wrole> [bead_id] [worker_bead_id] [engine]
spawn_worker() {
    local tmux_session="$1" session_key="$2" config_dir="$3" wname="$4" wrole="$5" bead_id="${6:-}" worker_bead_id="${7:-}" engine="${8:-claude}"

    # Spawn cap — refuse if too many AI workers are already running
    local active_workers _proc_pattern
    _proc_pattern=$(engine_process_pattern "$engine")
    active_workers=$(pgrep -f "$_proc_pattern" 2>/dev/null | wc -l | tr -d '[:space:]' || echo 0)
    [[ -z "$active_workers" ]] && active_workers=0
    if [[ "$active_workers" -ge "$TW_MAX_WORKERS" ]]; then
        log "Spawn cap reached: $active_workers active workers (max $TW_MAX_WORKERS). Refusing to spawn $wname."
        echo "  ⚡ Spawn cap: $active_workers/$TW_MAX_WORKERS workers running. Not spawning $wname." >&2
        return 1
    fi

    local output_file
    output_file="$(agents_dir "$session_key")/${wname}.md"

    # Write hooked work file — consumed by the SessionStart hook (tw-prime.sh)
    # to inject bead context + role + output file path + worker identity at session open.
    local hooked_dir="$HOME/.tiddly-winks/hooked/${session_key}"
    mkdir -p "$hooked_dir"
    local _feature
    _feature=$(sessions_get_key "$session_key" "feature" 2>/dev/null || echo "${session_key#*-}")
    python3 -c "
import json, sys
with open(sys.argv[1], 'w') as f:
    json.dump({
        'bead_id': sys.argv[2],
        'worker': sys.argv[3],
        'role': sys.argv[4],
        'output_file': sys.argv[5],
        'worker_bead_id': sys.argv[6],
        'engine': sys.argv[7],
        'feature': sys.argv[8]
    }, f, indent=2)
" "${hooked_dir}/${wname}.json" "$bead_id" "$wname" "$wrole" "$output_file" "$worker_bead_id" "$engine" "$_feature"

    # Recover last task from worker bead and inject into hooked file
    # so the worker resumes with context even after respawn
    if [[ -n "$worker_bead_id" ]]; then
        local _last_task
        _last_task=$(bd comments "$worker_bead_id" 2>/dev/null \
            | grep -o '\[TASK [^]]*\] .*' | tail -1 \
            | sed 's/^\[TASK [^]]*\] //' || true)
        if [[ -n "$_last_task" ]]; then
            python3 -c "
import json, sys
f = sys.argv[1]
task = sys.argv[2]
d = json.load(open(f))
d['current_task'] = task
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
" "${hooked_dir}/${wname}.json" "$_last_task" 2>/dev/null || true
            log "Recovered task from bead $worker_bead_id for $wname"
        fi
    fi

    # Kill any existing windows with this name to prevent duplicates
    # (can happen if daemon respawns during boot, or if tw start races with daemon)
    if tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "$wname"; then
        capture_pane "=$tmux_session:$wname" "$session_key" "$wname"
    fi
    while tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "$wname"; do
        tmux kill-window -t "=$tmux_session:$wname" 2>/dev/null || break
    done

    tmux new-window -d -t "=$tmux_session" -n "$wname"
    tmux set-option -t "=$tmux_session:$wname" allow-rename off 2>/dev/null || true
    tmux set-option -t "=$tmux_session:$wname" remain-on-exit on 2>/dev/null || true
    # For non-hook engines, build a context preamble file with bead/role/task info
    local _prompt_file=""
    if ! engine_supports_hooks "$engine"; then
        _prompt_file=$(engine_context_preamble "$session_key" "$wname" "$engine" 2>/dev/null || true)
    fi
    local _engine_cmd
    _engine_cmd=$(engine_spawn_cmd "$engine" "$wname" "$_prompt_file")
    tmux send-keys -t "=$tmux_session:$wname" \
        "cd '$config_dir' && TW_SESSION='$session_key' TW_WORKER='$wname' TW_ROLE='$wrole' $_engine_cmd" Enter

    # Auto-respawn hook: when pane dies, capture output, check crash count, and respawn
    # tmux calls this automatically — much faster than waiting for daemon patrol
    local _respawn_dir="$TW_DIR/rapid-respawns/$session_key"
    tmux set-hook -t "=$tmux_session:$wname" pane-died \
        "run-shell 'mkdir -p \"$_respawn_dir\" && \
         tw pane-capture \"$tmux_session\" \"$session_key\" \"$wname\" && \
         tw pane-respawn \"$tmux_session\" \"$session_key\" \"$wname\" \"$_respawn_dir\" \"$config_dir\" \"$wrole\" \"$engine\"'" \
        2>/dev/null || true

    # Queue an initial wake prompt — delivered on the worker's first turn.
    # The delay gives the engine time to fully boot.
    local _wake_delay _wake_prompt
    _wake_delay=$(engine_wake_delay "$engine")
    _wake_prompt=$(engine_wake_prompt "$engine")
    (
        sleep "$_wake_delay"
        tmux send-keys -t "=$tmux_session:$wname" \
            "$_wake_prompt" Enter
    ) &

    # Clear any leftover signals from previous session
    worker_signal_clear_all "$session_key" "$wname" 2>/dev/null || true

    # Record session start in worker CV
    local _cv_project="${session_key%%-*}"
    local _cv_feature="${session_key#*-}"
    cv_record_session_start "$_cv_project" "$wname" "$_cv_feature" 2>/dev/null || true

    # Write spawn timestamp — daemon uses this to avoid respawning workers still booting
    local spawn_ts_dir="$TW_DIR/spawn-timestamps/$session_key"
    mkdir -p "$spawn_ts_dir"
    date +%s > "$spawn_ts_dir/$wname"

    if [[ -n "$wrole" ]]; then
        log "Started worker: $wname (initial context: $wrole, engine: $engine)"
    else
        log "Started worker: $wname (engine: $engine)"
    fi

    engine_track_usage "$engine"
}

# Send the orchestrator seed to the god window once agents are known.
# Usage: seed_orchestrator <tmux_session> <session_key> <feature> <project> <bead_id> <branch> <worker_pairs_str> <worktrees_json>
seed_orchestrator() {
    local tmux_session="$1" session_key="$2" feature="$3" project="$4"
    local bead_id="$5" branch="$6" workers_str="$7" worktrees_json="$8"
    local agents_path
    agents_path="$(agents_dir "$session_key")"

    # Build worker dispatch lines
    local worker_lines=""
    while IFS= read -r wpair; do
        [[ -z "$wpair" ]] && continue
        local wn="${wpair%%:*}" _wr_rest="${wpair#*:}"
        local wr="${_wr_rest%%:*}"
        if [[ -n "$wr" ]]; then
            worker_lines+="- $wn (context: $wr): tw send $feature $wn \"<task>\"  →  cat $agents_path/$wn.md"$'\n'
        else
            worker_lines+="- $wn: tw send $feature $wn \"<task>\"  →  cat $agents_path/$wn.md"$'\n'
        fi
    done <<< "$workers_str"

    # Build git state-check commands for each worktree
    local git_checks=""
    if [[ -n "$worktrees_json" ]]; then
        while IFS=: read -r svc path; do
            [[ -z "$svc" || -z "$path" ]] && continue
            git_checks+="  git -C '$path' log origin/staging..HEAD --oneline  # $svc commits ahead of staging"$'\n'
        done <<< "$worktrees_json"
    fi

    # Load task templates list if available
    local task_templates=""
    if [[ -d "$HOME/.claude/task-templates" ]]; then
        task_templates=$(ls "$HOME/.claude/task-templates/" 2>/dev/null | sed 's/\.md$//' | tr '\n' ', ' | sed 's/, $//')
    fi

    local seed
    seed="You are the orchestrator for the '$feature' feature (project: $project).

## Your role
Route and track — do not explore code, run commands, or implement anything yourself. Workers do all hands-on work. Your job is dispatching tasks, polling output files, and reporting results to the user.

## Workers
$worker_lines
Workers are generic — any worker can handle any task. The task message you send IS the context. Dispatch based on availability, not on worker names.

## Dispatching tasks
Send work to any available worker:
  tw send $feature <worker> \"<task description>\"
The task description should be self-contained — include all context the worker needs.

## Task templates
${task_templates:+Reusable task snippets in ~/.claude/task-templates/:
  $task_templates
Read a template: cat ~/.claude/task-templates/<name>.md
Prepend template content to your task message when dispatching.}${task_templates:-No task templates found. Create ~/.claude/task-templates/ with .md snippets for common tasks (run-tests, check-services, code-review, etc.)}

## Spawning new workers
If all workers are busy, spawn more:
  tw spawn $feature <name>
Workers are generic slots — no role required. If you want to give initial context from a role file:
  tw spawn $feature <name> <role>
Available roles: $(ls "$HOME/.claude/roles/" 2>/dev/null | sed 's/\.md$//' | tr '\n' ', ' | sed 's/, $//')

## PR Review
Spawn specialized, workspace-tailored reviewers for a PR:
  tw review $feature <pr-number>
This reads the reviews: config from .tw.yml and spawns one focused reviewer per configured specialty. Each reviewer posts a separate --comment review tagged with their perspective (e.g. **[Backend]**, **[Schema]**). Reviewers are idempotent — re-running skips already-running reviewers and re-sends the task.
To set up review profiles for a new workspace: tw review init

## Monitoring worker progress
Workers write to their output files incrementally. Poll progress:
  tw feed $feature --problems    # one-shot: which workers have recent/stale output
  tw feed $feature               # stream: tail all output files in real time
  tw patrol $feature             # full health check + output tracking
  cat ~/.tiddly-winks/health/${session_key}.json  # structured health report (updated by daemon)
The daemon writes a JSON health report every tick with per-worker status (alive/dead/stalled/circuit-broken) and crash counts. Check this FIRST before running patrol — it's faster and tells you who needs attention.

## Cleaning up workers
After reviews complete or when done workers pile up, clean them out:
  tw workers $feature --cleanup   # kills done/dead workers, removes dynamic entries
Run this proactively after review dispatches complete or when you notice idle workers accumulating.

## Mail (persistent messaging)
For important signals (task done, help needed, handoffs), use mail instead of output file polling:
  tw mail send $feature <worker> -s \"Subject\" -m \"Body\" -f god
  tw mail inbox $feature god     # check your inbox
  tw mail read <bead-id>         # read and mark as read
  tw mail ack <bead-id>          # acknowledge and close
Workers can mail you when they complete tasks or need help. Check your inbox periodically.
After dispatching, check worker output files periodically. Don't wait for workers to message you — poll their files.

## Worker discoveries
Workers may file new beads when they discover bugs or work items. Periodically check:
  bd list --status=open
to see what workers have found. Triage and prioritize as needed.

## Engine routing (spread load across subscriptions)
Usage today: $(engine_usage_summary)
Available engines: claude, cursor
Check full stats: tw engine-stats

Override engine per task:
  tw send $feature <worker> --engine cursor \"<task>\"
  tw spawn $feature <name> --engine cursor
Non-claude workers get respawned with each new task (no mid-session hooks).

**When to use which engine:**
- **claude**: orchestration, debugging, investigation, PR review, anything needing strong reasoning
- **cursor**: refactoring, mechanical edits, test writing, code generation — good for spreading load

**Goal: spread usage across subscriptions.** If claude usage is high today, prefer cursor for
the next mechanical task. Don't overthink it — any worker can handle any task on any engine.

## Creating sub-beads (IMPORTANT)
When decomposing work into sub-beads, ALWAYS include --description with the full
implementation details. A title alone is useless — workers pick up beads in fresh
sessions with no conversation history. The description must be self-contained:
  bd create --title=\"<concise task name>\" --type=task --parent=<epic-id> --priority=2 \\
    --description=\"What: <specific implementation steps>. Where: <files/modules affected>. Acceptance: <how to verify done>.\"
Extract the relevant section of your plan and serialize it into --description.
Never create a bead with just a title — that's a lost plan.

## On startup — gather state by delegation, not directly
Dispatch to each worker:
  \"Explore the codebase: check git log origin/staging..HEAD --oneline, read bd show $bead_id if it has content, review recent changes. Summarize: what's done, what's in progress, what's missing. Write findings to your output file.\"

Wait for output files to populate, then synthesize a state summary for the user. Ask what to tackle next."

    (
        sleep 6
        tmux send-keys -t "=$tmux_session:god" "$seed"
        sleep 0.5
        tmux send-keys -t "=$tmux_session:god" "" Enter
    ) &
}

# ─── Bead Integration ────────────────────────────────────────────────────────

# Run bd from a specific directory (for per-workspace bead stores).
# bd_run <dir> <bd-args...>  — if dir is empty, runs bd in $PWD.
bd_run() {
    local dir="$1"; shift
    if [[ -n "$dir" ]]; then
        (cd "$dir" && bd "$@")
    else
        bd "$@"
    fi
}

bead_find_open() {
    local title="$1" bd_dir="${2:-}"
    bd_run "$bd_dir" list --status=open 2>/dev/null | grep -F "$title" | head -1 | awk '{print $2}' | tr -d '#' || true
}

# Find an existing worker identity bead (searches open + in_progress).
# Title convention: "tw:worker <name> (<project>)"
worker_bead_find() {
    local worker="$1" project="$2" bd_dir="${3:-}"
    local title="tw:worker ${worker} (${project})"
    {
        bd_run "$bd_dir" list --status=open 2>/dev/null
        bd_run "$bd_dir" list --status=in_progress 2>/dev/null
    } | grep -F "$title" | head -1 | awk '{print $2}' | tr -d '#' || true
}

worker_bead_find_or_create() {
    local worker="$1" project="$2" bd_dir="${3:-}"
    local title="tw:worker ${worker} (${project})"
    local wbead_id
    wbead_id=$(worker_bead_find "$worker" "$project" "$bd_dir")
    if [[ -z "$wbead_id" ]]; then
        wbead_id=$(bead_create "$title" "$bd_dir")
        bead_mark_in_progress "$wbead_id" "$bd_dir"
        log "Created worker bead $wbead_id: $title"
    else
        log "Reusing worker bead $wbead_id: $title"
    fi
    echo "$wbead_id"
}

# ─── Spawn Circuit Breaker ────────────────────────────────────────────────────
#
# Tracks respawn failures per worker. After N failures within a time window,
# blocks further respawns and notifies the orchestrator (god window).
# Prevents runaway respawn storms when a worker keeps crashing.

BREAKER_MAX_FAILURES=3
BREAKER_WINDOW_SECS=1800  # 30 minutes

breaker_dir() { echo "$TW_DIR/breaker/${1}"; }

# Record a respawn attempt. Returns 1 if breaker is tripped (should block).
breaker_check_and_record() {
    local session_key="$1" worker="$2"
    local dir
    dir="$(breaker_dir "$session_key")"
    mkdir -p "$dir"
    local file="$dir/${worker}"
    local now
    now=$(date +%s)

    local count=0 first_failure="$now"

    if [[ -f "$file" ]]; then
        local stored_count stored_time
        stored_count=$(head -1 "$file" 2>/dev/null || echo 0)
        stored_time=$(tail -1 "$file" 2>/dev/null || echo "$now")

        # If outside the window, reset
        local elapsed=$(( now - stored_time ))
        if [[ $elapsed -gt $BREAKER_WINDOW_SECS ]]; then
            count=0
            first_failure="$now"
        else
            count="$stored_count"
            first_failure="$stored_time"
        fi
    fi

    count=$(( count + 1 ))
    printf '%s\n%s\n' "$count" "$first_failure" > "$file"

    if [[ $count -gt $BREAKER_MAX_FAILURES ]]; then
        return 1  # tripped
    fi
    return 0
}

# Reset breaker for a worker (called on successful handoff or manual reset).
breaker_reset() {
    local session_key="$1" worker="$2"
    rm -f "$(breaker_dir "$session_key")/${worker}"
}

# Reset all breakers for a session.
breaker_reset_all() {
    local session_key="$1"
    rm -rf "$(breaker_dir "$session_key")"
}

# Notify the god window that a worker has been circuit-broken.
breaker_notify_god() {
    local tmux_session="$1" worker="$2" count="$3"
    local msg="[tw breaker] Worker '$worker' has failed $count times in ${BREAKER_WINDOW_SECS}s. Auto-respawn blocked. Manual action needed: tw workers <feature> --respawn --force"
    # Send as a message to the god window if it exists
    if tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "god"; then
        tmux send-keys -t "=$tmux_session:god" "" 2>/dev/null || true
        tmux send-keys -t "=$tmux_session:god" "$msg" Enter 2>/dev/null || true
    fi
    log "$msg"
}

# ─── Worker CV (Persistent Identity) ─────────────────────────────────────────
#
# JSON file per worker tracking sessions, completions, and work history.
# Survives across features and sessions. Stored locally for fast access.

cv_dir() { echo "$TW_DIR/cv"; }

# Get the CV file path for a worker. Keyed by project+worker (not session),
# so CVs persist across features within a project.
cv_file() {
    local project="$1" worker="$2"
    echo "$(cv_dir)/${project}-${worker}.json"
}

# Initialize or load a CV. Prints the file path.
cv_ensure() {
    local project="$1" worker="$2"
    local file
    file=$(cv_file "$project" "$worker")
    mkdir -p "$(cv_dir)"
    if [[ ! -f "$file" ]]; then
        python3 -c "
import json, sys
from datetime import datetime, timezone
cv = {
    'worker': sys.argv[1],
    'project': sys.argv[2],
    'created': datetime.now(timezone.utc).isoformat(),
    'sessions': 0,
    'handoffs': 0,
    'features_worked': [],
    'history': []
}
with open(sys.argv[3], 'w') as f:
    json.dump(cv, f, indent=2)
" "$worker" "$project" "$file"
    fi
    echo "$file"
}

# Record a session start in the CV.
cv_record_session_start() {
    local project="$1" worker="$2" feature="$3"
    local file
    file=$(cv_ensure "$project" "$worker")
    python3 -c "
import json, sys
from datetime import datetime, timezone
with open(sys.argv[1]) as f:
    cv = json.load(f)
cv['sessions'] = cv.get('sessions', 0) + 1
feat = sys.argv[2]
if feat not in cv.get('features_worked', []):
    cv.setdefault('features_worked', []).append(feat)
with open(sys.argv[1], 'w') as f:
    json.dump(cv, f, indent=2)
" "$file" "$feature"
}

# Record a handoff in the CV with a summary of work done.
cv_record_handoff() {
    local project="$1" worker="$2" feature="$3" summary="$4"
    local file
    file=$(cv_ensure "$project" "$worker")
    python3 -c "
import json, sys
from datetime import datetime, timezone
with open(sys.argv[1]) as f:
    cv = json.load(f)
cv['handoffs'] = cv.get('handoffs', 0) + 1
entry = {
    'timestamp': datetime.now(timezone.utc).isoformat(),
    'feature': sys.argv[2],
    'type': 'handoff',
    'summary': sys.argv[3]
}
cv.setdefault('history', []).append(entry)
# Keep last 50 history entries
cv['history'] = cv['history'][-50:]
with open(sys.argv[1], 'w') as f:
    json.dump(cv, f, indent=2)
" "$file" "$feature" "$summary"
}

# Record a respawn (crash recovery) in the CV.
cv_record_respawn() {
    local project="$1" worker="$2" feature="$3"
    local file
    file=$(cv_ensure "$project" "$worker")
    python3 -c "
import json, sys
from datetime import datetime, timezone
with open(sys.argv[1]) as f:
    cv = json.load(f)
entry = {
    'timestamp': datetime.now(timezone.utc).isoformat(),
    'feature': sys.argv[2],
    'type': 'respawn'
}
cv.setdefault('history', []).append(entry)
cv['history'] = cv['history'][-50:]
with open(sys.argv[1], 'w') as f:
    json.dump(cv, f, indent=2)
" "$file" "$feature"
}

# Display a worker's CV in human-readable format.
cv_show() {
    local project="$1" worker="$2"
    local file
    file=$(cv_file "$project" "$worker")
    if [[ ! -f "$file" ]]; then
        echo "  No CV found for $worker ($project)"
        return 1
    fi
    python3 -c "
import json, sys
from datetime import datetime, timezone

with open(sys.argv[1]) as f:
    cv = json.load(f)

worker = cv.get('worker', '?')
project = cv.get('project', '?')
created = cv.get('created', '?')[:10]
sessions = cv.get('sessions', 0)
handoffs = cv.get('handoffs', 0)
features = cv.get('features_worked', [])
history = cv.get('history', [])

# Count respawns
respawns = sum(1 for h in history if h.get('type') == 'respawn')

print(f'  Worker:     {worker}')
print(f'  Project:    {project}')
print(f'  Since:      {created}')
print(f'  Sessions:   {sessions}')
print(f'  Handoffs:   {handoffs}')
print(f'  Respawns:   {respawns}')
print(f'  Features:   {\", \".join(features) if features else \"(none)\"}')

if history:
    print()
    print('  Recent history:')
    now = datetime.now(timezone.utc)
    for entry in history[-10:]:
        ts = entry.get('timestamp', '')[:16].replace('T', ' ')
        etype = entry.get('type', '?')
        feat = entry.get('feature', '')
        summary = entry.get('summary', '')
        if etype == 'handoff':
            # Truncate long summaries
            if len(summary) > 60:
                summary = summary[:57] + '...'
            print(f'    {ts}  handoff  {feat}: {summary}')
        elif etype == 'respawn':
            print(f'    {ts}  respawn  {feat}')
" "$file"
}

# ─── Worker Signal (Self-Managed Completion) ────────────────────────────────
#
# Workers can signal their state by writing a sentinel file.
# Currently supported signals: "done" — worker has finished its task.

worker_signal_dir() {
    echo "$TW_DIR/signals"
}

# Write a signal for a worker. Creates a sentinel file.
# Usage: worker_signal_set <session_key> <worker> <signal>
worker_signal_set() {
    local session_key="$1" worker="$2" signal="$3"
    local dir
    dir="$(worker_signal_dir)/${session_key}"
    mkdir -p "$dir"
    echo "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "${dir}/${worker}.${signal}"
    log "Signal set: $worker → $signal"
}

# Check if a signal is set for a worker.
# Returns 0 if set, 1 if not.
worker_signal_check() {
    local session_key="$1" worker="$2" signal="$3"
    [[ -f "$(worker_signal_dir)/${session_key}/${worker}.${signal}" ]]
}

# Clear a signal for a worker.
worker_signal_clear() {
    local session_key="$1" worker="$2" signal="$3"
    rm -f "$(worker_signal_dir)/${session_key}/${worker}.${signal}"
    log "Signal cleared: $worker ← $signal"
}

# Clear all signals for a worker (used on respawn/wake).
worker_signal_clear_all() {
    local session_key="$1" worker="$2"
    rm -f "$(worker_signal_dir)/${session_key}/${worker}".* 2>/dev/null || true
}

# ─── Pool Reuse (Wake Idle Workers) ─────────────────────────────────────────
#
# Instead of killing an idle worker and spawning fresh, re-initialize it
# in place: update the hooked context file and send a wake prompt.
# This preserves the Claude session's accumulated context.

# Re-initialize an idle worker with fresh context instead of respawning.
# Returns 0 if wake succeeded, 1 if worker is not idle/alive.
# Usage: worker_wake <tmux_session> <session_key> <config_dir> <wname> <wrole> <bead_id> <worker_bead_id>
worker_wake() {
    local tmux_session="$1" session_key="$2" config_dir="$3" wname="$4" wrole="$5"
    local bead_id="${6:-}" worker_bead_id="${7:-}"

    # Only wake workers that are idle
    if ! worker_is_idle "$tmux_session" "$wname" "$session_key"; then
        return 1
    fi

    # Clear any completion signals
    worker_signal_clear_all "$session_key" "$wname"

    # Update the hooked context file with fresh bead/task info
    local hooked_dir="$HOME/.tiddly-winks/hooked/${session_key}"
    mkdir -p "$hooked_dir"
    local _feature
    _feature=$(sessions_get_key "$session_key" "feature" 2>/dev/null || echo "${session_key#*-}")
    python3 -c "
import json, sys
with open(sys.argv[1], 'w') as f:
    json.dump({
        'bead_id': sys.argv[2],
        'worker': sys.argv[3],
        'role': sys.argv[4],
        'output_file': sys.argv[5],
        'worker_bead_id': sys.argv[6],
        'feature': sys.argv[7]
    }, f, indent=2)
" "${hooked_dir}/${wname}.json" "$bead_id" "$wname" "$wrole" \
  "$(agents_dir "$session_key")/${wname}.md" "$worker_bead_id" "$_feature"

    # Send a wake prompt to re-activate the worker
    local wake_msg="You are being re-activated for new work. Re-read your role and context from the SessionStart hook, check bd show $bead_id for the latest feature state, and report ready to your output file."
    send_to_pane "=$tmux_session:$wname" "$wake_msg"

    # Record in CV
    local _cv_project="${session_key%%-*}"
    local _cv_feature="${session_key#*-}"
    cv_record_session_start "$_cv_project" "$wname" "$_cv_feature" 2>/dev/null || true

    log "Woke idle worker: $wname (reused session)"
}

bead_create() {
    local title="$1" bd_dir="${2:-}"
    local err_file out rc=0
    err_file=$(mktemp -t tw-bead-create.XXXXXX)
    out=$(bd_run "$bd_dir" create --title="$title" --type=task --priority=2 2>"$err_file") || rc=$?
    local err_out
    err_out=$(<"$err_file")
    rm -f "$err_file"
    if [[ $rc -ne 0 ]]; then
        echo "[tw] error: bd create failed (exit $rc) for title: $title" >&2
        [[ -n "$bd_dir" ]] && echo "[tw]        workspace: $bd_dir" >&2
        [[ -n "$err_out" ]] && echo "$err_out" >&2
        return 1
    fi
    local bead_id
    bead_id=$(echo "$out" | grep -oE '[a-zA-Z]+-[a-z0-9]+' | head -1)
    if [[ -z "$bead_id" ]]; then
        echo "[tw] error: bd create returned no parseable bead id for title: $title" >&2
        [[ -n "$out" ]] && echo "$out" >&2
        return 1
    fi
    echo "$bead_id"
}

bead_find_or_create() {
    local title="$1" bd_dir="${2:-}"
    local bead_id
    bead_id=$(bead_find_open "$title" "$bd_dir" || true)
    if [[ -z "$bead_id" ]]; then
        bead_id=$(bead_create "$title" "$bd_dir") || return 1
        log "Created bead $bead_id: $title"
    else
        log "Reusing bead $bead_id: $title"
    fi
    [[ -z "$bead_id" ]] && return 1
    echo "$bead_id"
}

bead_update_body() {
    local bead_id="$1" body="$2" bd_dir="${3:-}"
    bd_run "$bd_dir" update "$bead_id" --body="$body" >/dev/null 2>&1 || true
}

bead_mark_in_progress() {
    local bead_id="$1" bd_dir="${2:-}"
    bd_run "$bd_dir" update "$bead_id" --status=in_progress >/dev/null 2>&1 || true
}

bead_close() {
    local bead_id="$1" bd_dir="${2:-}"
    bd_run "$bd_dir" close "$bead_id" >/dev/null 2>&1 || true
}

# Parse the METADATA block of `bd show <id>` and print "key=value" lines.
bead_metadata_dump() {
    local bead_id="$1" bd_dir="${2:-}"
    bd_run "$bd_dir" show "$bead_id" 2>/dev/null | python3 -c "
import sys
in_meta = False
for line in sys.stdin:
    if line.startswith('METADATA'):
        in_meta = True
        continue
    if in_meta:
        if not line.strip():
            break
        if line.startswith(' '):
            kv = line.strip()
            if ':' in kv:
                k, _, v = kv.partition(':')
                print(f'{k.strip()}={v.strip()}')
        else:
            break
" 2>/dev/null || true
}

# Scan for orphaned task beads in a given session.
#
# An orphan is a bead where:
#   - status = in_progress, type = task
#   - metadata.session = <session_key>
#   - metadata.assigned_to points at a worker that is dead / missing / whose
#     tmux session is gone entirely.
#
# Prints one line per orphan: "<bead_id>\t<assigned_to>\t<reason>"
# Reasons: tmux-dead | worker-missing | worker-dead
#
# Usage: orphaned_beads_scan <session_key> <config_dir>
orphaned_beads_scan() {
    local session_key="$1" config_dir="${2:-}"
    [[ -z "$session_key" ]] && return 0

    local bead_ids
    bead_ids=$(bd_run "$config_dir" list \
            --status=in_progress \
            --type=task \
            --metadata-field="session=$session_key" 2>/dev/null \
        | grep -oE '[a-z][a-z0-9-]*-[a-z0-9]+' \
        | sort -u)
    [[ -z "$bead_ids" ]] && return 0

    local tmux_alive=1
    tmux has-session -t "=$session_key" 2>/dev/null || tmux_alive=0

    local agents_path
    agents_path="$(agents_dir "$session_key" 2>/dev/null || true)"

    # The feature bead itself (same session) also carries assigned_to metadata
    # for identifying the god's owner. Skip it — it's not a dispatched task.
    local feature_bead_id=""
    feature_bead_id=$(sessions_get_key "$session_key" "bead_id" 2>/dev/null || true)

    local id
    while IFS= read -r id; do
        [[ -z "$id" ]] && continue
        [[ -n "$feature_bead_id" && "$id" == "$feature_bead_id" ]] && continue

        # Real task beads from cmd_send carry an assigned_at stamp; feature/
        # worker-identity beads do not. Use that as an additional discriminator.
        local meta assigned assigned_at
        meta=$(bead_metadata_dump "$id" "$config_dir")
        assigned=$(echo "$meta" | awk -F= '$1=="assigned_to"{print $2; exit}')
        assigned_at=$(echo "$meta" | awk -F= '$1=="assigned_at"{print $2; exit}')
        [[ -z "$assigned" || -z "$assigned_at" ]] && continue

        local reason=""
        if [[ $tmux_alive -eq 0 ]]; then
            reason="tmux-dead"
        elif ! tmux_window_exists "$session_key" "$assigned"; then
            reason="worker-missing"
        else
            local ws
            ws=$(worker_state "$session_key" "$assigned" "$agents_path" "$session_key" 2>/dev/null || echo "")
            [[ "$ws" == "dead" ]] && reason="worker-dead"
        fi

        if [[ -n "$reason" ]]; then
            printf '%s\t%s\t%s\n' "$id" "$assigned" "$reason"
        fi
    done <<< "$bead_ids"
}

# Reset orphaned task beads for a session to status=open.
# Prints one line per reset; final line is the total count.
# Usage: orphaned_beads_reset <session_key> <config_dir>
orphaned_beads_reset() {
    local session_key="$1" config_dir="${2:-}"
    local count=0
    local id assigned reason
    while IFS=$'\t' read -r id assigned reason; do
        [[ -z "$id" ]] && continue
        bd_run "$config_dir" update "$id" --status=open >/dev/null 2>&1 || true
        bd_run "$config_dir" update "$id" --set-metadata "orphan_reset_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)" >/dev/null 2>&1 || true
        bd_run "$config_dir" update "$id" --set-metadata "orphan_reset_reason=$reason" >/dev/null 2>&1 || true
        echo "      reset $id (was $assigned, $reason)"
        count=$((count + 1))
    done < <(orphaned_beads_scan "$session_key" "$config_dir")
    echo "      total reset: $count"
}

bead_get_body() {
    local bead_id="$1" bd_dir="${2:-}"
    bd_run "$bd_dir" show "$bead_id" 2>/dev/null | python3 -c "
import sys
lines = sys.stdin.readlines()
body_lines = []
in_body = False
for line in lines:
    if line.startswith('Body:'):
        in_body = True
        rest = line[5:].strip()
        if rest:
            body_lines.append(rest)
        continue
    if in_body:
        body_lines.append(line.rstrip())
print('\n'.join(body_lines))
" 2>/dev/null || true
}

# Sync key session state to bead metadata so it survives hard resets.
# Usage: bead_sync_metadata <session_key> <bead_id> <config_dir>
bead_sync_metadata() {
    local session_key="$1" bead_id="$2" config_dir="$3"
    [[ -z "$bead_id" ]] && return 0

    local metadata_json
    metadata_json=$(python3 - "$session_key" <<'PYEOF'
import json, sys, os

sk = sys.argv[1]
sessions_file = os.path.expanduser("~/.tiddly-winks/sessions.json")
try:
    with open(sessions_file) as f:
        data = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    data = {}

session = data.get(sk, {})

# dynamic_workers: array of {name, role, bead_id}
dw = session.get('dynamic_workers', [])

# worker_beads: map of worker_name → bead_id
wb = session.get('worker_beads', {})

# services: current port allocations
svcs = session.get('services', {})

from datetime import datetime, timezone
result = {
    'dynamic_workers': json.dumps(dw),
    'worker_beads': json.dumps(wb),
    'services': json.dumps(svcs),
    'last_sync': datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ'),
}
# Output as key=value lines for --set-metadata
for k, v in result.items():
    print(f'{k}={v}')
PYEOF
    )

    # Apply each metadata key
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        bd_run "$config_dir" update "$bead_id" --set-metadata "$line" >/dev/null 2>&1 || true
    done <<< "$metadata_json"
}

build_bead_body() {
    local feature="$1"
    local project="$2"
    local branch="$3"
    local workspace="$4"
    local mode="$5"
    local started="$6"
    local pm_display="$7"
    local urls_block="$8"
    local worktrees_block="${9:-}"
    local db_name="${10:-}"

    cat <<BODY
## Feature Space
- branch: $branch
- workspace: $workspace
- mode: $mode
- started: $started
${worktrees_block:+$worktrees_block
}${db_name:+- db: $db_name
}
## URLs
$urls_block

## Issue Tracker
$pm_display

## PRs
(none yet)

## Session History
BODY
}

# ─── PM Integration ──────────────────────────────────────────────────────────

pm_linear_find_issue() {
    local team="$1" feature="$2"
    [[ -z "${LINEAR_API_KEY:-}" ]] && { echo ""; return; }

    local result
    result=$(curl -sf -X POST https://api.linear.app/graphql \
        -H "Authorization: $LINEAR_API_KEY" \
        -H "Content-Type: application/json" \
        -d "{\"query\": \"{ issues(filter: { team: { key: { eq: \\\"$team\\\" } }, title: { containsIgnoreCase: \\\"$feature\\\" }, state: { type: { neq: \\\"completed\\\" } } }, first: 1) { nodes { identifier url } } }\" }" \
        2>/dev/null) || true

    local id url
    id=$(echo "$result" | python3 -c "import json,sys; d=json.load(sys.stdin); nodes=d.get('data',{}).get('issues',{}).get('nodes',[]); print(nodes[0]['identifier'] if nodes else '')" 2>/dev/null || true)
    url=$(echo "$result" | python3 -c "import json,sys; d=json.load(sys.stdin); nodes=d.get('data',{}).get('issues',{}).get('nodes',[]); print(nodes[0]['url'] if nodes else '')" 2>/dev/null || true)

    [[ -n "$id" ]] && echo "$id:$url" || echo ""
}

pm_linear_create_issue() {
    local team="$1" feature="$2"
    [[ -z "${LINEAR_API_KEY:-}" ]] && { log "LINEAR_API_KEY not set — skipping Linear issue creation"; echo ""; return; }

    local team_result team_id
    team_result=$(curl -sf -X POST https://api.linear.app/graphql \
        -H "Authorization: $LINEAR_API_KEY" \
        -H "Content-Type: application/json" \
        -d "{\"query\": \"{ teams(filter: { key: { eq: \\\"$team\\\" } }) { nodes { id } } }\" }" \
        2>/dev/null) || true
    team_id=$(echo "$team_result" | python3 -c "import json,sys; d=json.load(sys.stdin); nodes=d.get('data',{}).get('teams',{}).get('nodes',[]); print(nodes[0]['id'] if nodes else '')" 2>/dev/null || true)

    [[ -z "$team_id" ]] && { log "Could not find Linear team '$team'"; echo ""; return; }

    local create_result issue_id issue_url
    create_result=$(curl -sf -X POST https://api.linear.app/graphql \
        -H "Authorization: $LINEAR_API_KEY" \
        -H "Content-Type: application/json" \
        -d "{\"query\": \"mutation { issueCreate(input: { teamId: \\\"$team_id\\\", title: \\\"$feature\\\" }) { issue { identifier url } } }\" }" \
        2>/dev/null) || true
    issue_id=$(echo "$create_result" | python3 -c "import json,sys; d=json.load(sys.stdin); i=d.get('data',{}).get('issueCreate',{}).get('issue',{}); print(i.get('identifier',''))" 2>/dev/null || true)
    issue_url=$(echo "$create_result" | python3 -c "import json,sys; d=json.load(sys.stdin); i=d.get('data',{}).get('issueCreate',{}).get('issue',{}); print(i.get('url',''))" 2>/dev/null || true)

    [[ -n "$issue_id" ]] && echo "$issue_id:$issue_url" || echo ""
}

pm_github_find_issue() {
    local repo="$1" feature="$2"
    local result
    result=$(gh issue list --repo "$repo" --search "$feature" --json number,url --limit 1 2>/dev/null) || true
    local num url
    num=$(echo "$result" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d[0]['number'] if d else '')" 2>/dev/null || true)
    url=$(echo "$result" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d[0]['url'] if d else '')" 2>/dev/null || true)
    [[ -n "$num" ]] && echo "$num:$url" || echo ""
}

pm_github_create_issue() {
    local repo="$1" feature="$2"
    local result
    result=$(gh issue create --repo "$repo" --title "$feature" --body "Created by tw for local dev session." 2>/dev/null) || true
    local url num
    url=$(echo "$result" | grep -oE 'https://github.com/[^ ]+' | head -1 || true)
    num=$(echo "$url" | grep -oE '[0-9]+$' || true)
    [[ -n "$num" ]] && echo "$num:$url" || echo ""
}

pm_find_or_create() {
    local config_file="$1" feature="$2"
    local tracker_type
    tracker_type=$(yaml_get_nested "$config_file" "issue_tracker.type" "none")

    case "$tracker_type" in
        linear)
            local team
            team=$(yaml_get_nested "$config_file" "issue_tracker.team" "")
            local found
            found=$(pm_linear_find_issue "$team" "$feature")
            if [[ -z "$found" ]]; then
                found=$(pm_linear_create_issue "$team" "$feature")
                [[ -n "$found" ]] && log "Created Linear issue: ${found%%:*}"
            else
                log "Found Linear issue: ${found%%:*}"
            fi
            echo "$found"
            ;;
        github)
            local repo
            repo=$(yaml_get_nested "$config_file" "issue_tracker.repo" "")
            local found
            found=$(pm_github_find_issue "$repo" "$feature")
            if [[ -z "$found" ]]; then
                found=$(pm_github_create_issue "$repo" "$feature")
                [[ -n "$found" ]] && log "Created GitHub issue: #${found%%:*}"
            else
                log "Found GitHub issue: #${found%%:*}"
            fi
            echo "$found"
            ;;
        *)
            echo ""
            ;;
    esac
}

pm_format_for_bead() {
    local tracker_type="$1" pm_issue="$2"
    if [[ -z "$pm_issue" ]]; then
        echo "- none"
        return
    fi
    local id="${pm_issue%%:*}"
    local url="${pm_issue##*:}"
    case "$tracker_type" in
        linear) echo "- linear: $id ($url)" ;;
        github) echo "- github: #$id ($url)" ;;
        *)      echo "- $id ($url)" ;;
    esac
}

# ─── Find .tw.yml (or .devenv.yml for compatibility) ─────────────────────────

find_config() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/.tw.yml" ]]; then
            echo "$dir/.tw.yml"
            return 0
        fi
        if [[ -f "$dir/.devenv.yml" ]]; then
            echo "$dir/.devenv.yml"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

# ─── Reconciliation ──────────────────────────────────────────────────────────
#
# Derives session state from reality (filesystem, tmux, beads) rather than
# trusting cached state. Inspired by gastown's ZFC principle / ReconcilePool().

# Reconcile sessions.json against actual filesystem and tmux state.
# - Worktrees in sessions.json but missing on disk → clean up the entry
# - Worktrees on disk belonging to tw but not in sessions.json → reconstruct from bead
# - Orphaned tmux sessions (no sessions.json entry) → log warning
reconcile_session() {
    local config_dir="${1:-$PWD}"
    [[ -f "$SESSIONS_FILE" ]] || return 0

    local sessions_data
    sessions_data=$(sessions_read)

    # Phase 1: Validate sessions.json entries against reality
    local new_data
    new_data=$(python3 - "$sessions_data" <<'PYEOF'
import json, sys, subprocess, os

data = json.loads(sys.argv[1])

for key, s in list(data.items()):
    worktrees = s.get('worktrees', {})
    if not worktrees:
        continue

    # Check each worktree path exists on disk
    missing = []
    for svc, path in worktrees.items():
        if not os.path.isdir(path):
            missing.append(svc)

    if missing and len(missing) == len(worktrees):
        # All worktrees gone — clear stale paths but keep the session entry.
        # The session record (bead, branch, ports) is needed for tw start to resume.
        data[key]['worktrees'] = {}
        session_name = key
        r = subprocess.run(['tmux', 'has-session', '-t', session_name],
                           capture_output=True)
        if r.returncode != 0:
            print(f"RECONCILE:cleared_worktrees:{key}:all worktrees missing + no tmux (session kept for resume)", file=sys.stderr)
        else:
            print(f"RECONCILE:cleared_worktrees:{key}:worktrees missing but tmux alive", file=sys.stderr)
    elif missing:
        # Some worktrees missing — remove only the missing ones
        for svc in missing:
            del data[key]['worktrees'][svc]
        print(f"RECONCILE:partial_cleanup:{key}:removed {','.join(missing)}", file=sys.stderr)

print(json.dumps(data, indent=2))
PYEOF
    )

    if [[ "$new_data" != "$sessions_data" ]]; then
        echo "$new_data" | sessions_write
        log "Reconciled sessions.json (cleaned stale entries)"
    fi

    # Phase 2: Check for tw worktrees on disk not tracked in sessions.json
    local worktrees_base
    worktrees_base=$(python3 -c "
import json, sys, os
data = json.loads(sys.argv[1])
config_dir = os.path.realpath(sys.argv[2])
# Infer worktrees base only from sessions belonging to THIS workspace
for key, s in data.items():
    ws = s.get('workspace', '')
    if ws and os.path.realpath(ws) != config_dir:
        continue
    wt = s.get('worktrees', {})
    for svc, path in wt.items():
        # worktrees are typically at <base>/<feature>/<svc>
        print(os.path.dirname(os.path.dirname(path)))
        sys.exit(0)
# Fallback: check common location for THIS workspace
candidate = os.path.join(config_dir, 'worktrees')
if os.path.isdir(candidate):
    print(candidate)
" "$new_data" "$config_dir" 2>/dev/null || true)

    if [[ -n "$worktrees_base" && -d "$worktrees_base" ]]; then
        local current_keys
        current_keys=$(echo "$new_data" | python3 -c "import json,sys; [print(k) for k in json.load(sys.stdin)]" 2>/dev/null)

        for feature_dir in "$worktrees_base"/*/; do
            [[ -d "$feature_dir" ]] || continue
            local feature_name
            feature_name=$(basename "$feature_dir")
            # Check if any session key references this feature
            if ! echo "$current_keys" | grep -qF "$feature_name"; then
                log "Reconcile: found untracked worktree dir: $feature_dir (no session entry)"
                # Try to find a matching bead to reconstruct
                local project
                project=$(yaml_get "$config_dir/.tw.yml" "project" "" 2>/dev/null || true)
                if [[ -n "$project" ]]; then
                    local bead_title="$feature_name ($project)"
                    local bead_id
                    bead_id=$(bead_find_open "$bead_title" "$config_dir" 2>/dev/null || true)
                    if [[ -z "$bead_id" ]]; then
                        bead_id=$(bd_run "$config_dir" list --status=in_progress 2>/dev/null \
                            | grep -F "$bead_title" | head -1 | awk '{print $2}' | tr -d '#' || true)
                    fi
                    if [[ -n "$bead_id" ]]; then
                        log "Reconcile: found bead $bead_id for untracked feature '$feature_name' — can be recovered with: tw start $feature_name"
                    fi
                fi
            fi
        done
    fi

    # Phase 3: Detect orphaned tmux sessions
    local tmux_sessions
    tmux_sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null || true)
    if [[ -n "$tmux_sessions" ]]; then
        local registered_keys
        registered_keys=$(echo "$new_data" | python3 -c "import json,sys; [print(k) for k in json.load(sys.stdin)]" 2>/dev/null)
        while IFS= read -r sess_name; do
            # Only check sessions that look like tw sessions (project-feature pattern)
            [[ "$sess_name" == *-* ]] || continue
            if ! echo "$registered_keys" | grep -qxF "$sess_name"; then
                log "Reconcile: orphaned tmux session '$sess_name' (not in sessions.json)"
            fi
        done <<< "$tmux_sessions"
    fi

    return 0
}

# Reconcile worker state by deriving liveness from tmux + bead status.
# - Worker bead says in_progress but tmux window dead → mark as needs_respawn
# - tmux window alive but no bead → log warning
reconcile_workers() {
    local session_key="$1" config_dir="${2:-$PWD}"
    local tmux_session="$session_key"

    # Only reconcile if the tmux session exists
    tmux has-session -t "=$tmux_session" 2>/dev/null || return 0

    local project
    project=$(sessions_get_key "$session_key" "project" 2>/dev/null || true)
    [[ -z "$project" ]] && return 0

    # Get all worker windows (exclude god, main, services, and numeric windows)
    local tmux_windows
    tmux_windows=$(tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null || true)
    [[ -z "$tmux_windows" ]] && return 0

    local agents_path="$TW_DIR/agents/$session_key"

    # Track base names we've already processed (spinner creates duplicate entries)
    local -A seen_workers

    while IFS= read -r wname; do
        # Strip spinner suffix (e.g. "alpha ⠴" → "alpha")
        local base_name="${wname%% [⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]}"

        # Skip non-worker windows
        case "$base_name" in
            god|main|services|[0-9]*) continue ;;
        esac

        # Deduplicate — spinner-renamed and base windows can both appear
        [[ -n "${seen_workers[$base_name]+x}" ]] && continue
        seen_workers[$base_name]=1

        # Check worker bead status
        local worker_bead_id
        worker_bead_id=$(worker_bead_find "$base_name" "$project" "$config_dir" 2>/dev/null || true)

        if [[ -z "$worker_bead_id" ]]; then
            log "Reconcile workers: '$base_name' has tmux window but no worker bead"
            continue
        fi

        # Derive liveness: tmux window + process
        local state
        state=$(worker_state "$tmux_session" "$wname" "$agents_path" "$session_key")

        # Get bead status
        local bead_status
        bead_status=$(bd_run "$config_dir" show "$worker_bead_id" 2>/dev/null \
            | grep -E "^Status:" | awk '{print $2}' || true)

        if [[ "$bead_status" == "in_progress" && "$state" == "dead" ]]; then
            # Worker bead thinks it's active but tmux says dead — mark for respawn
            bd_run "$config_dir" comments add "$worker_bead_id" \
                "[RECONCILE] Worker tmux dead but bead in_progress. Marking needs_respawn." \
                >/dev/null 2>&1 || true
            bd_run "$config_dir" update "$worker_bead_id" \
                --set-metadata "agent_state=needs_respawn" >/dev/null 2>&1 || true
            log "Reconcile workers: '$base_name' marked needs_respawn (tmux dead, bead was in_progress)"
        elif [[ "$state" != "dead" && "$bead_status" != "in_progress" ]]; then
            # Worker is alive but bead isn't in_progress — sync bead
            bead_mark_in_progress "$worker_bead_id" "$config_dir"
            bd_run "$config_dir" update "$worker_bead_id" \
                --set-metadata "agent_state=alive" >/dev/null 2>&1 || true
            log "Reconcile workers: '$base_name' bead updated to in_progress (worker alive)"
        fi
    done <<< "$tmux_windows"
}

# ─── Subcommands ─────────────────────────────────────────────────────────────

# Roll back partial side effects from a failed _start_one_session.
# Only acts on state flagged as "owned this invocation" — never touches
# pre-existing tmux sessions, worktrees, or sessions.json entries that
# were already there when we started. Ownership flags default to "0" and
# are only flipped to "1" right after we successfully create the resource.
_start_rollback_partial() {
    local session_key="$1" feature="$2" config_dir="$3"
    local tmux_session="$4" spawn_lock="$5"
    local owned_tmux="$6" owned_spawn_lock="$7"
    local owned_sessions_entry="$8" owned_spinner="$9" owned_hooked="${10}"
    shift 10
    local -a owned_worktrees=("$@")

    [[ -z "$session_key" ]] && return 0

    # Nothing to do if we created nothing.
    if [[ "$owned_tmux" != "1" && "$owned_spawn_lock" != "1" \
          && "$owned_sessions_entry" != "1" && "$owned_spinner" != "1" \
          && "$owned_hooked" != "1" && ${#owned_worktrees[@]} -eq 0 ]]; then
        return 0
    fi

    echo "[tw] rolling back partial init for '$session_key'" >&2

    [[ "$owned_tmux" == "1" && -n "$tmux_session" ]] \
        && tmux kill-session -t "=$tmux_session" 2>/dev/null || true
    [[ "$owned_spawn_lock" == "1" && -n "$spawn_lock" ]] && rm -f "$spawn_lock"
    [[ "$owned_spinner" == "1" ]] \
        && rm -f "$TW_DIR/spinner-$session_key.pid" 2>/dev/null || true
    [[ "$owned_hooked" == "1" ]] \
        && rm -rf "$HOME/.tiddly-winks/hooked/$session_key" 2>/dev/null || true

    # Capture each worktree's parent git common-dir before removal so we can
    # prune the stale registration afterward.
    local -a common_dirs=()
    for p in "${owned_worktrees[@]}"; do
        [[ -n "$p" && -e "$p" ]] || continue
        local cd_
        cd_=$(git -C "$p" rev-parse --git-common-dir 2>/dev/null) || cd_=""
        if [[ -n "$cd_" && "$cd_" != "." ]]; then
            cd_=$(cd "$(dirname "$cd_")" 2>/dev/null && pwd)/$(basename "$cd_") 2>/dev/null || cd_=""
        fi
        [[ -n "$cd_" ]] && common_dirs+=("$cd_")
        rm -rf "$p" 2>/dev/null || true
    done
    local seen=""
    for cd_ in ${common_dirs[@]+"${common_dirs[@]}"}; do
        [[ " $seen " == *" $cd_ "* ]] && continue
        seen+=" $cd_"
        [[ -d "$cd_" ]] && git --git-dir="$cd_" worktree prune 2>/dev/null || true
    done

    if [[ "$owned_sessions_entry" == "1" && -f "$SESSIONS_FILE" ]]; then
        python3 - "$SESSIONS_FILE" "$session_key" <<'PYEOF' 2>/dev/null || true
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    if d.pop(sys.argv[2], None) is not None:
        json.dump(d, open(sys.argv[1], 'w'), indent=2)
except Exception:
    pass
PYEOF
    fi
}

# Start a single feature session. Called by cmd_start for each target.
# Parses its own flags; cmd_start passes through --mode / --attach verbatim.
_start_one_session() {
    local feature="" mode="local" attach_flag=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --mode) mode="$2"; shift 2 ;;
            --mode=*) mode="${1#--mode=}"; shift ;;
            --attach) attach_flag=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *) feature="$1"; shift ;;
        esac
    done

    [[ -z "$feature" ]] && die "Usage: tw start <feature> [--mode staging]"

    # Find config
    local config_file
    config_file=$(find_config) || die "No .tw.yml found in $PWD or any parent directory"
    local config_dir
    config_dir="$(dirname "$config_file")"

    # Merge override if present
    local override_file="$config_dir/.tw.override.yml"
    # Also check old name
    [[ ! -f "$override_file" && -f "$config_dir/.devenv.override.yml" ]] && override_file="$config_dir/.devenv.override.yml"
    local effective_config="$config_file"
    if [[ -f "$override_file" ]]; then
        effective_config=$(yaml_merge_override "$config_file" "$override_file")
        log "Merged override: $override_file"
    fi

    local project
    project=$(yaml_get "$effective_config" "project" "") || true
    [[ -z "$project" ]] && die ".tw.yml missing 'project' key"

    local session_key="${project}-${feature}"
    local tmux_session="$session_key"

    # State captured for rollback on mid-init failure. Populated as side effects
    # occur; the EXIT trap below uses these to clean up on abnormal exit.
    declare -A worktree_paths=()
    local spawn_lock=""
    local worktrees_base=""
    # Ownership flags: flip to 1 ONLY after we actually create the resource.
    # Rollback must never touch pre-existing state that belonged to an already-
    # running or stopped session we were about to reuse — specifically:
    # killing the tmux session / wiping worktrees on a `tw start <already-running>`
    # die is catastrophic data loss. Rollback guards every action on these flags.
    local _owned_tmux=0 _owned_spawn_lock=0 _owned_sessions_entry=0
    local _owned_spinner=0 _owned_hooked=0
    declare -a _owned_worktrees=()
    # Install rollback trap. Fires on any exit (including die()); cleared at the
    # success point after sessions.json has been written. The `+` expansion
    # keeps the call safe under `set -u` when _owned_worktrees is empty.
    trap '_rc=$?; if [[ $_rc -ne 0 ]]; then _start_rollback_partial "$session_key" "$feature" "$config_dir" "$tmux_session" "$spawn_lock" "$_owned_tmux" "$_owned_spawn_lock" "$_owned_sessions_entry" "$_owned_spinner" "$_owned_hooked" ${_owned_worktrees[@]+"${_owned_worktrees[@]}"}; fi; exit $_rc' EXIT

    # Reconcile state before checking session existence — derive truth from reality
    reconcile_session "$config_dir"

    # Fail if session already exists AND is registered in sessions.json
    # If tmux exists but sessions.json is missing the entry, auto-clean and proceed
    if tmux has-session -t "=$tmux_session" 2>/dev/null; then
        if sessions_get_key "$session_key" "project" 2>/dev/null | grep -q .; then
            die "Feature '$feature' already running. Use: tmux attach -t $tmux_session"
        else
            log "Found orphan tmux session '$tmux_session' (not in sessions.json) — killing and restarting"
            tmux kill-session -t "=$tmux_session" 2>/dev/null || true
        fi
    fi

    # Check for stopped session — resume instead of starting fresh
    local resuming=0
    local existing_bead_id="" existing_worktrees="" existing_services="" existing_branch=""
    if sessions_get_key "$session_key" "project" 2>/dev/null | grep -q .; then
        log "Found stopped session for $session_key — resuming"
        resuming=1
        existing_bead_id=$(sessions_get_key "$session_key" "bead_id")
        existing_branch=$(sessions_get_key "$session_key" "branch")
        existing_worktrees=$(python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
wt = d.get('$session_key', {}).get('worktrees', {})
for svc, path in wt.items():
    print(f'{svc}:{path}')
" 2>/dev/null || true)
        existing_services=$(python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
svcs = d.get('$session_key', {}).get('services', {})
for name, info in svcs.items():
    print(f'{name}:{info.get(\"port\", \"\")}')
" 2>/dev/null || true)
    fi

    log "Starting feature: $session_key (mode=$mode${resuming:+, resuming})"

    # Init per-workspace bead store if needed
    if [[ ! -d "$config_dir/.beads" ]]; then
        (cd "$config_dir" && bd init --stealth --prefix "$project" --quiet 2>/dev/null) \
            && log "Initialized bead store: $config_dir/.beads" || true
    fi

    # Bead — reuse existing bead when resuming a stopped session
    local bead_title="$feature ($project)"
    local bead_id
    if [[ $resuming -eq 1 && -n "$existing_bead_id" ]]; then
        bead_id="$existing_bead_id"
        log "Reusing existing bead: $bead_id"
    else
        bead_id=$(bead_find_or_create "$bead_title" "$config_dir") || bead_id=""
    fi

    if [[ -z "$bead_id" ]]; then
        die "bead creation failed for '$bead_title' — check dolt daemon state with 'bd doctor' in $config_dir, or 'rm -rf $config_dir/.beads && bd init' to reinitialize. Refusing to write a bead-less session entry."
    fi

    # PM issue
    local pm_issue pm_display tracker_type
    tracker_type=$(yaml_get_nested "$effective_config" "issue_tracker.type" "none")
    pm_issue=$(pm_find_or_create "$effective_config" "$feature")
    pm_display=$(pm_format_for_bead "$tracker_type" "$pm_issue")

    # ─── Worktree Setup ───────────────────────────────────────────────────────
    # worktrees_base is declared earlier (for rollback visibility); populate it here.
    local branch_prefix
    worktrees_base=$(yaml_get_nested "$effective_config" "worktrees.base" "")
    branch_prefix=$(yaml_get_nested "$effective_config" "worktrees.branch_prefix" "")

    # worktree_paths is declared earlier (for rollback visibility).
    local db_name=""

    local service_names
    mapfile -t service_names < <(yaml_service_names "$effective_config")

    local branch="${branch_prefix}${feature}"
    if [[ $resuming -eq 1 && -n "$existing_branch" ]]; then
        branch="$existing_branch"
    fi

    # When resuming, try to reuse existing worktrees from the stopped session
    local worktrees_reused=0
    if [[ $resuming -eq 1 && -n "$existing_worktrees" ]]; then
        local all_exist=1
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local wt_svc="${line%%:*}" wt_path="${line#*:}"
            if [[ -d "$wt_path" ]]; then
                worktree_paths[$wt_svc]="$wt_path"
            else
                all_exist=0
                log "Worktree missing for $wt_svc: $wt_path — will recreate"
            fi
        done <<< "$existing_worktrees"

        if [[ $all_exist -eq 1 && ${#worktree_paths[@]} -gt 0 ]]; then
            worktrees_reused=1
            log "Reusing existing worktrees (all present on disk)"
        else
            # Some missing — reset and recreate all
            declare -A worktree_paths=()
        fi
    fi

    if [[ -n "$worktrees_base" && $worktrees_reused -eq 0 ]]; then
        log "Setting up worktrees under $worktrees_base/$feature/"

        # Phase 1: Discover unique git repos and map services to them.
        # This handles monorepo layouts (e.g. potoo/server + potoo/web share one repo)
        # by creating a single worktree per unique git root.
        declare -A repo_worktree=()      # git_root → worktree_path (one per unique repo)
        declare -A svc_git_root=()       # svc → git_root
        declare -A svc_rel_path=()       # svc → path relative to git root (empty if at root)

        for svc in "${service_names[@]}"; do
            [[ -z "$svc" ]] && continue
            local svc_path
            svc_path=$(yaml_service_get "$effective_config" "$svc" "path" "")
            [[ -z "$svc_path" ]] && continue

            local svc_abs_path="$config_dir/$svc_path"
            # Check for git repo — could be a .git dir or a .git file (submodule)
            [[ ! -e "$svc_abs_path/.git" ]] && {
                # Walk up to find the git root (handles paths like potoo/server inside potoo/)
                local git_root
                git_root=$(git -C "$svc_abs_path" rev-parse --show-toplevel 2>/dev/null) || {
                    log "No git repo at or above $svc_abs_path — skipping worktree for $svc"
                    continue
                }
                svc_git_root[$svc]="$git_root"
                # Relative path of the service within the repo
                svc_rel_path[$svc]="${svc_abs_path#$git_root/}"
                continue
            }

            # .git exists at this path — it IS a git root (or submodule root)
            local git_root
            git_root=$(git -C "$svc_abs_path" rev-parse --show-toplevel 2>/dev/null) || {
                log "Cannot resolve git root at $svc_abs_path — skipping worktree for $svc"
                continue
            }
            svc_git_root[$svc]="$git_root"
            svc_rel_path[$svc]=""  # service is at repo root
        done

        # Phase 2: Create one worktree per unique git repo
        for svc in "${service_names[@]}"; do
            [[ -z "$svc" || -z "${svc_git_root[$svc]:-}" ]] && continue
            local git_root="${svc_git_root[$svc]}"

            if [[ -z "${repo_worktree[$git_root]:-}" ]]; then
                # First service using this repo — create branch + worktree
                local repo_name
                repo_name=$(basename "$git_root")
                local worktree_path="$config_dir/$worktrees_base/$feature/$repo_name"

                git -C "$git_root" fetch origin staging --quiet 2>/dev/null || true
                git -C "$git_root" branch "$branch" origin/staging 2>/dev/null \
                    || log "Branch $branch already exists in $repo_name"

                mkdir -p "$(dirname "$worktree_path")"
                if git -C "$git_root" worktree add "$worktree_path" "$branch" 2>/dev/null; then
                    log "Created worktree: $worktree_path (repo: $repo_name)"
                    # Track as rollback-owned: WE created this one. If init fails
                    # later, the trap will `rm -rf` this path (but not any
                    # pre-existing worktree we just happened to find).
                    _owned_worktrees+=("$worktree_path")
                else
                    log "Worktree already exists: $worktree_path"
                fi

                repo_worktree[$git_root]="$worktree_path"
            fi

            # Map service to its path within the shared worktree
            local wt_base="${repo_worktree[$git_root]}"
            local rel="${svc_rel_path[$svc]}"
            if [[ -n "$rel" ]]; then
                worktree_paths[$svc]="$wt_base/$rel"
            else
                worktree_paths[$svc]="$wt_base"
            fi

            # Run db_setup if configured
            local db_setup
            db_setup=$(yaml_service_get "$effective_config" "$svc" "db_setup" "")
            if [[ -n "$db_setup" ]]; then
                log "Running db_setup for $svc: $db_setup"
                (cd "${worktree_paths[$svc]}" && eval "$db_setup") \
                    || log "db_setup failed for $svc (continuing)"
                local env_db
                env_db=$(grep "^DB_NAME=" "${worktree_paths[$svc]}/.env" 2>/dev/null | cut -d= -f2 || true)
                [[ -n "$env_db" ]] && db_name="$env_db"
            fi

            # Run post_setup if configured (e.g. bun install, npm install)
            local post_setup
            post_setup=$(yaml_service_get "$effective_config" "$svc" "post_setup" "")
            if [[ -n "$post_setup" ]]; then
                log "Running post_setup for $svc: $post_setup"
                (cd "${worktree_paths[$svc]}" && eval "$post_setup") \
                    || log "post_setup failed for $svc (continuing)"
            fi
        done
    fi

    # Start tmux session for this feature
    # Window 0 is "god" (orchestrator) — always claude engine
    tmux new-session -d -s "$tmux_session" -n "god"
    _owned_tmux=1  # WE created this tmux session; rollback may kill it
    local _god_cmd
    _god_cmd=$(engine_spawn_cmd "claude" "$feature")
    tmux send-keys -t "=$tmux_session:god" "cd '$config_dir' && TW_SESSION='$session_key' TW_WORKER='god' $_god_cmd" Enter

    # Apply project color theme to tmux session
    session_apply_theme "$tmux_session" "$project" "$feature" "$session_key"

    # Install tw keybindings (once per tmux server)
    _tw_install_keybindings 2>/dev/null || true

    # Create hooked JSON for god so it can receive nudges via tw-mail-check hook
    local hooked_dir="$HOME/.tiddly-winks/hooked/${session_key}"
    mkdir -p "$hooked_dir"
    _owned_hooked=1  # WE own this hooked dir; rollback may rm -rf it
    python3 -c "
import json, sys
with open(sys.argv[1], 'w') as f:
    json.dump({
        'bead_id': sys.argv[2],
        'worker': 'god',
        'role': 'orchestrator',
        'output_file': '',
        'worker_bead_id': '',
        'feature': sys.argv[3]
    }, f, indent=2)
" "${hooked_dir}/god.json" "$bead_id" "$feature"

    tmux new-window -d -t "=$tmux_session" -n "main"
    tmux send-keys -t "=$tmux_session:main" "cd '$config_dir'" Enter

    # Allocate ports and start services
    declare -A service_data
    declare -A service_pane_ids

    for svc in "${service_names[@]}"; do
        [[ -z "$svc" ]] && continue
        local port_hint command env_var
        port_hint=$(yaml_service_get "$effective_config" "$svc" "port_hint" "3000")
        command=$(yaml_service_get "$effective_config" "$svc" "command" "")
        env_var=$(yaml_service_get "$effective_config" "$svc" "env" "")

        local port
        allocate_port port "$port_hint"
        service_data[$svc]="$port"

        # Substitute {port} in command and env
        command="${command//\{port\}/$port}"
        env_var="${env_var//\{port\}/$port}"

        # Resolve service path: worktree takes precedence over config path
        local svc_path abs_path
        if [[ -n "${worktree_paths[$svc]:-}" ]]; then
            abs_path="${worktree_paths[$svc]}"
        else
            svc_path=$(yaml_service_get "$effective_config" "$svc" "path" ".")
            abs_path="$config_dir/$svc_path"
        fi

        # Build shell command
        local shell_cmd="cd '$abs_path'"
        [[ -n "$env_var" ]] && shell_cmd="$shell_cmd && export $env_var"
        [[ -n "$command" ]] && shell_cmd="$shell_cmd && $command"

        log "Service '$svc' on port $port (path: $abs_path)"

        # Wrap in a restart loop with exponential backoff (max 30s)
        # Services auto-restart on crash; give up after 10 consecutive failures
        local restart_cmd="bash -c 'attempt=0; max_attempts=10; delay=2; while [ \$attempt -lt \$max_attempts ]; do $shell_cmd; exit_code=\$?; attempt=\$((attempt + 1)); if [ \$attempt -lt \$max_attempts ]; then echo \"[tw] Service crashed (exit \$exit_code), restarting in \${delay}s (attempt \$attempt/\$max_attempts)...\"; sleep \$delay; delay=\$((delay < 30 ? delay * 2 : 30)); fi; done; echo \"[tw] Service failed after \$max_attempts attempts. Run tw start to restart.\"; exec bash'"

        # First service gets its own pane in the services window; rest split
        # Capture pane ID for stable targeting (indices shift when panes die)
        local _pane_id
        if [[ "${services_window_created:-0}" -eq 0 ]]; then
            _pane_id=$(tmux new-window -d -t "=$tmux_session" -n "services" \
                -P -F '#{pane_id}' "$restart_cmd")
            services_window_created=1
        else
            _pane_id=$(tmux split-window -t "=$tmux_session:services" -v \
                -P -F '#{pane_id}' "$restart_cmd")
        fi
        service_pane_ids[$svc]="${_pane_id:-}"
    done

    # Balance panes in the services window
    if [[ "${services_window_created:-0}" -eq 1 ]]; then
        tmux select-layout -t "=$tmux_session:services" even-vertical 2>/dev/null || true
    fi

    # Template env files with allocated ports (if env_files section exists in config)
    local service_ports_json="{"
    local _sp_first=1
    for svc in "${!service_data[@]}"; do
        [[ $_sp_first -eq 0 ]] && service_ports_json+=","
        service_ports_json+="\"$svc\":${service_data[$svc]}"
        _sp_first=0
    done
    service_ports_json+="}"
    local env_output
    env_output=$(template_env_files "$effective_config" "$config_dir" "$service_ports_json" 2>/dev/null)
    if [[ -n "$env_output" ]]; then
        while IFS= read -r line; do
            log "$line"
        done <<< "$env_output"
    fi

    # Build proxy map and URLs
    local urls_block="" primary_url="" proxy_json="{"
    local proxy_pairs proxy_first=1
    mapfile -t proxy_pairs < <(yaml_proxy_pairs "$effective_config")

    for pair in "${proxy_pairs[@]}"; do
        [[ -z "$pair" ]] && continue
        local subdomain="${pair%%:*}"
        local svc_name="${pair##*:}"

        local host
        if [[ "$subdomain" == "" ]]; then
            host="http://${project}-${feature}.localhost"
        else
            host="http://${project}-${feature}-${subdomain}.localhost"
        fi
        urls_block+="- $svc_name: $host"$'\n'
        [[ -z "$primary_url" ]] && primary_url="$host"

        [[ $proxy_first -eq 0 ]] && proxy_json+=","
        proxy_json+="\"$subdomain\": \"$svc_name\""
        proxy_first=0
    done
    proxy_json+="}"

    # Compute branch name early (needed for orchestrator seed)
    local default_prefix
    default_prefix="$(whoami)/"
    local branch="${branch_prefix:-$default_prefix}${feature}"

    # Create agents output directory
    mkdir -p "$(agents_dir "$session_key")"

    # Lock: prevent daemon from respawning workers while cmd_start is still spawning them.
    # The daemon checks for this lock and skips worker health checks for this session.
    # Reuses outer-scope spawn_lock so the rollback trap can clean it up on die().
    spawn_lock="$TW_DIR/spawn-locks/${session_key}"
    mkdir -p "$TW_DIR/spawn-locks"
    echo "$$" > "$spawn_lock"
    _owned_spawn_lock=1  # WE created this lock; rollback may remove it

    # Add worker windows (persistent Claude agents with roles)
    local worker_pairs
    mapfile -t worker_pairs < <(yaml_worker_pairs "$effective_config")

    local workers_str=""
    for wpair in "${worker_pairs[@]}"; do
        [[ -z "$wpair" ]] && continue
        local wname="${wpair%%:*}"
        local _wrest="${wpair#*:}"; local wrole="${_wrest%%:*}"
        local wengine="${wpair##*:}"
        wengine=$(resolve_engine "$wengine" "$effective_config")
        local worker_bead_id
        worker_bead_id=$(worker_bead_find_or_create "$wname" "$project" "$config_dir")
        spawn_worker "$tmux_session" "$session_key" "$config_dir" \
            "$wname" "$wrole" "$bead_id" "$worker_bead_id" "$wengine" || {
            log "Worker $wname spawn failed (non-fatal, session continues)"
        }
        workers_str+="$wpair"$'\n'
    done

    # Release spawn lock after a grace period — workers take 10-15s to boot.
    # Without this delay, the daemon may see booting workers as "dead" and respawn them.
    (sleep 30 && rm -f "$spawn_lock") &

    # Seed orchestrator with worker context + worktree paths
    if [[ -n "$workers_str" ]]; then
        local worktrees_kv=""
        for svc in "${!worktree_paths[@]}"; do
            worktrees_kv+="$svc:${worktree_paths[$svc]}"$'\n'
        done
        seed_orchestrator "$tmux_session" "$session_key" "$feature" "$project" \
            "$bead_id" "$branch" "$workers_str" "$worktrees_kv"
    fi

    # Focus orchestrator window
    tmux select-window -t "=$tmux_session:god"

    # Build worktrees block for bead body
    local worktrees_bead_block=""
    if [[ ${#worktree_paths[@]} -gt 0 ]]; then
        worktrees_bead_block="- worktrees:"
        for svc in "${!worktree_paths[@]}"; do
            worktrees_bead_block+=$'\n'"  - $svc: ${worktree_paths[$svc]}"
        done
    fi

    # Build sessions.json entry
    local started
    started=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local sessions_data
    sessions_data=$(sessions_read)

    # Build service JSON (includes pane_id for stable tmux targeting)
    local services_json="{"
    local first=1
    for svc in "${service_names[@]}"; do
        [[ -z "$svc" ]] && continue
        [[ $first -eq 0 ]] && services_json+=","
        local _pid="${service_pane_ids[$svc]:-}"
        services_json+="\"$svc\": {\"port\": ${service_data[$svc]}, \"pane_id\": \"$_pid\"}"
        first=0
    done
    services_json+="}"

    # Build worktrees JSON
    local worktrees_json="{"
    first=1
    for svc in "${!worktree_paths[@]}"; do
        [[ $first -eq 0 ]] && worktrees_json+=","
        worktrees_json+="\"$svc\": \"${worktree_paths[$svc]}\""
        first=0
    done
    worktrees_json+="}"

    local new_sessions
    new_sessions=$(python3 - \
        "$sessions_data" "$session_key" "$project" "$feature" "$mode" "$started" \
        "$services_json" "$proxy_json" "$bead_id" "$config_dir" \
        "$worktrees_json" "$db_name" "$branch" <<'EOF'
import json, sys
data = json.loads(sys.argv[1])
key = sys.argv[2]
# Preserve dynamic_workers from previous session if resuming
old = data.get(key, {})
dw = old.get('dynamic_workers', [])
data[key] = {
    "project":    sys.argv[3],
    "feature":    sys.argv[4],
    "mode":       sys.argv[5],
    "started":    sys.argv[6],
    "services":   json.loads(sys.argv[7]),
    "proxy_map":  json.loads(sys.argv[8]),
    "bead_id":    sys.argv[9],
    "workspace":  sys.argv[10],
    "worktrees":  json.loads(sys.argv[11]),
    "db_name":    sys.argv[12],
    "branch":     sys.argv[13],
}
if dw:
    data[key]['dynamic_workers'] = dw
print(json.dumps(data, indent=2))
EOF
)
    echo "$new_sessions" | sessions_write

    # Init complete — clear rollback trap. State is now persisted in sessions.json;
    # anything that fails below is recoverable by re-running tw start.
    trap - EXIT

    # Regen Caddyfile and reload
    regen_caddyfile
    caddy_reload

    # Start activity spinner for worker windows
    spinner_start "$tmux_session" "$session_key"

    # Update bead
    if [[ -n "$bead_id" ]]; then
        local bead_body
        bead_body=$(build_bead_body \
            "$feature" "$project" "$branch" "$config_dir" \
            "$mode" "$started" "$pm_display" "$urls_block" \
            "$worktrees_bead_block" "$db_name")
        bead_update_body "$bead_id" "$bead_body" "$config_dir"
        bead_mark_in_progress "$bead_id" "$config_dir"
        bead_sync_metadata "$session_key" "$bead_id" "$config_dir"
        bd_run "$config_dir" vc commit -m "tw session update" 2>/dev/null || true
    fi

    # Print summary
    echo ""
    [[ $resuming -eq 1 ]] && echo "  Resumed stopped session"
    echo "  Feature:  $feature ($project)"
    echo "  Mode:     $mode"
    echo "  Branch:   $branch"
    [[ -n "$bead_id" ]] && echo "  Bead:     $bead_id"
    [[ -n "$db_name" ]] && echo "  DB:       $db_name"
    if [[ -n "$pm_issue" ]]; then
        local pm_id="${pm_issue%%:*}"
        local pm_url="${pm_issue##*:}"
        echo "  Issue:    $pm_id  $pm_url"
    fi
    if [[ ${#worktree_paths[@]} -gt 0 ]]; then
        echo ""
        echo "  Worktrees:"
        for svc in "${!worktree_paths[@]}"; do
            echo "    $svc: ${worktree_paths[$svc]}"
        done
    fi
    echo ""
    echo "  URLs:"
    while IFS= read -r line; do
        [[ -n "$line" ]] && echo "    $line"
    done <<< "$urls_block"
    if [[ ${#worker_pairs[@]} -gt 0 ]]; then
        echo ""
        echo "  Workers:"
        for wpair in "${worker_pairs[@]}"; do
            [[ -z "$wpair" ]] && continue
            local wname="${wpair%%:*}"
            local _wr2="${wpair#*:}"; local wrole="${_wr2%%:*}"
            if [[ -n "$wrole" ]]; then
                echo "    $wname  (context: $wrole)"
            else
                echo "    $wname"
            fi
        done
    fi
    echo ""
    echo "  Attach:   tmux attach -t $tmux_session"
    echo "  Claude:   tw claude $feature"
    echo ""

    # Clean up temp file if created
    [[ "$effective_config" != "$config_file" ]] && rm -f "$effective_config"

    # --attach: attach to the session and auto-login the god window
    if [[ $attach_flag -eq 1 ]]; then
        # Wait for god window's Claude to boot, then send /login
        (
            sleep 12
            # Only login if not already logged in
            local _pane_text
            _pane_text=$(tmux capture-pane -t "=$tmux_session:god" -p 2>/dev/null) || exit 0
            if echo "$_pane_text" | tail -3 | grep -q "Not logged in"; then
                tmux send-keys -t "=$tmux_session:god" "/login" Enter
                sleep 3
                # Select option 1 (subscription) if login menu appears
                tmux send-keys -t "=$tmux_session:god" Enter
                sleep 2
                # Press Enter to dismiss "Login successful" prompt
                tmux send-keys -t "=$tmux_session:god" Enter
            fi
        ) &

        # Also auto-login all worker windows
        for wpair in "${worker_pairs[@]}"; do
            [[ -z "$wpair" ]] && continue
            local wname="${wpair%%:*}"
            (
                sleep 14
                local _pane_text
                _pane_text=$(tmux capture-pane -t "=$tmux_session:$wname" -p 2>/dev/null) || exit 0
                if echo "$_pane_text" | tail -3 | grep -q "Not logged in"; then
                    tmux send-keys -t "=$tmux_session:$wname" "/login" Enter
                    sleep 3
                    tmux send-keys -t "=$tmux_session:$wname" Enter
                    sleep 2
                    tmux send-keys -t "=$tmux_session:$wname" Enter
                fi
            ) &
        done

        tmux select-window -t "=$tmux_session:god" 2>/dev/null || true
        exec tmux attach-session -t "=$tmux_session"
    fi
}

cmd_start() {
    # Collect targets and pass-through flags. Only the first positional arg is
    # the (possibly comma-separated) target list; flags are forwarded verbatim.
    local targets=""
    local -a passthrough=()
    local attach_flag=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --mode) passthrough+=("$1" "$2"); shift 2 ;;
            --mode=*) passthrough+=("$1"); shift ;;
            --attach) passthrough+=("$1"); attach_flag=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *)
                if [[ -z "$targets" ]]; then
                    targets="$1"
                else
                    die "Unexpected extra argument: $1"
                fi
                shift ;;
        esac
    done

    [[ -z "$targets" ]] && die "Usage: tw start <feature>[,<feature>,...] [--mode staging] [--attach]"

    # Split comma-separated targets
    local IFS=','
    local -a target_list=($targets)
    unset IFS

    if [[ ${#target_list[@]} -gt 1 && $attach_flag -eq 1 ]]; then
        die "--attach is only valid for a single feature (not a comma-separated list)"
    fi

    # Single-target: call directly so die() aborts tw loudly with its original
    # exit code (pre-d58f542 behavior). The rollback trap inside
    # _start_one_session still cleans up partial state.
    if [[ ${#target_list[@]} -eq 1 ]]; then
        local only="${target_list[0]}"
        only="${only## }"; only="${only%% }"
        [[ -z "$only" ]] && die "empty target"
        _start_one_session "$only" "${passthrough[@]}"
        return $?
    fi

    local failed=() succeeded=0
    for target in "${target_list[@]}"; do
        # Trim whitespace
        target="${target## }"
        target="${target%% }"
        [[ -z "$target" ]] && continue

        # Run in subshell so a die() inside _start_one_session (e.g. session
        # already running, bead creation failure) only aborts that one target.
        # The rollback trap inside _start_one_session cleans up partial state
        # before the subshell exits.
        if ( _start_one_session "$target" "${passthrough[@]}" ); then
            ((succeeded++)) || true
        else
            echo "  Error: failed to start '$target'"
            failed+=("$target")
        fi
    done

    if [[ ${#failed[@]} -gt 0 ]]; then
        echo ""
        echo "  Failed to start ${#failed[@]} session(s): ${failed[*]}"
        return 1
    fi
}

# Stop a single resolved session. Called by cmd_stop for each target.
# Args: feature_name done_flag session_key project config_dir tmux_session bead_id
_stop_one_session() {
    local feature="$1" done_flag="$2" session_key="$3" project="$4"
    local config_dir="$5" tmux_session="$6" bead_id="$7"

    # Kill activity spinner + reset circuit breakers
    spinner_stop "$session_key"
    breaker_reset_all "$session_key"

    # Capture all worker panes before killing
    if tmux has-session -t "=$tmux_session" 2>/dev/null; then
        for _win in $(tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null); do
            [[ "$_win" == "god" || "$_win" == "main" || "$_win" == "services" ]] && continue
            capture_pane "=$tmux_session:$_win" "$session_key" "$_win"
        done
    fi

    # Kill the feature's tmux session
    if tmux has-session -t "=$tmux_session" 2>/dev/null; then
        tmux kill-session -t "=$tmux_session" 2>/dev/null || true
        log "Killed session: $tmux_session"
    else
        log "tmux session '$tmux_session' not found (already stopped?)"
    fi

    # Tear down worktrees if --done
    if [[ $done_flag -eq 1 ]]; then
        # Squash WIP checkpoint commits before removing worktrees
        local squash_wt_json
        squash_wt_json=$(python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
wt = d.get('$session_key', {}).get('worktrees', {})
seen = set()
for svc, path in wt.items():
    import os
    root = path
    # Deduplicate by git root
    print(path)
" 2>/dev/null || true)
        # Squash main workspace
        _checkpoint_squash "$config_dir" || true
        # Squash each worktree
        while IFS= read -r _sq_path; do
            [[ -z "$_sq_path" ]] && continue
            _checkpoint_squash "$_sq_path" || true
        done <<< "$squash_wt_json"

        # Get unique worktree roots to remove. Multiple services may share the same
        # git worktree (e.g. potoo/server + potoo/web both live in worktrees/feat/potoo).
        # We deduplicate by finding the actual git root of each worktree path.
        local worktrees_json
        worktrees_json=$(python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
wt = d.get('$session_key', {}).get('worktrees', {})
for svc, path in wt.items():
    print(f'{svc}:{path}')
" 2>/dev/null || true)

        declare -A removed_worktrees=()
        # Collect unique parent git roots so we can `git worktree prune` each
        # one after the loop. Needed because `worktree remove` can fail when
        # the worktree dir is already missing from a prior broken state,
        # which leaves the parent's .git/worktrees/<name>/ registration stale
        # and makes the next `tw start` fail with "worktree already exists".
        declare -A parent_git_roots=()
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local wt_svc="${line%%:*}"
            local wt_path="${line#*:}"

            # Find the git root of this worktree path — this deduplicates
            # services that share the same repo worktree
            local wt_git_root
            wt_git_root=$(git -C "$wt_path" rev-parse --show-toplevel 2>/dev/null) || wt_git_root="$wt_path"

            # Skip if we already removed this worktree root
            [[ -n "${removed_worktrees[$wt_git_root]:-}" ]] && continue

            # Find the original repo to run worktree remove from
            local svc_path repo_abs_path git_root
            if config_file=$(find_config 2>/dev/null); then
                svc_path=$(yaml_service_get "$config_file" "$wt_svc" "path" "")
                repo_abs_path="$config_dir/$svc_path"
                git_root=$(git -C "$repo_abs_path" rev-parse --show-toplevel 2>/dev/null) || git_root="$repo_abs_path"
            fi

            if [[ -n "${git_root:-}" && -e "$git_root/.git" ]]; then
                parent_git_roots[$git_root]=1
                local wt_err
                if wt_err=$(git -C "$git_root" worktree remove "$wt_git_root" --force 2>&1); then
                    log "Removed worktree: $wt_git_root"
                else
                    # Stale metadata or subpath of a registered worktree —
                    # the post-loop `worktree prune` below cleans up registry
                    # entries that point to missing paths.
                    log "Warning: git worktree remove failed for $wt_git_root"
                    log "  git said: $wt_err"
                    log "  (pruning stale metadata from $git_root after loop)"
                fi
            fi
            removed_worktrees[$wt_git_root]=1
        done <<< "$worktrees_json"

        # Always prune each parent repo's worktree registry. Cheap no-op when
        # everything removed cleanly; fixes stale state otherwise.
        for _pgr in "${!parent_git_roots[@]}"; do
            git -C "$_pgr" worktree prune 2>/dev/null || true
        done

        # Clean up empty worktrees/<feature>/ directory
        local worktrees_base feature_wt_dir
        if config_file=$(find_config 2>/dev/null); then
            worktrees_base=$(yaml_get_nested "$config_file" "worktrees.base" "")
            if [[ -n "$worktrees_base" ]]; then
                feature_wt_dir="$config_dir/$worktrees_base/$feature"
                [[ -d "$feature_wt_dir" ]] && rmdir "$feature_wt_dir" 2>/dev/null \
                    && log "Removed worktree dir: $feature_wt_dir" || true
            fi
        fi
    fi

    # Clear stale GUPP tasks from hooked files so workers don't get ghost tasks on restart
    local _hooked_dir="$HOME/.tiddly-winks/hooked/${session_key}"
    if [[ -d "$_hooked_dir" ]]; then
        python3 -c "
import json, glob, sys, os
for f in glob.glob(os.path.join(sys.argv[1], '*.json')):
    try:
        d = json.load(open(f))
        changed = False
        for key in ('current_task', 'current_task_bead'):
            if key in d:
                del d[key]
                changed = True
        if changed:
            with open(f, 'w') as fh:
                json.dump(d, fh, indent=2)
    except Exception:
        pass
" "$_hooked_dir" 2>/dev/null || true
    fi

    # Only remove from sessions.json if --done; otherwise keep as "stopped"
    if [[ $done_flag -eq 1 ]]; then
        local sessions_data
        sessions_data=$(sessions_read)
        python3 - "$sessions_data" "$session_key" <<'EOF' | sessions_write
import json, sys
data = json.loads(sys.argv[1])
data.pop(sys.argv[2], None)
print(json.dumps(data, indent=2))
EOF
    fi

    # Regen Caddyfile
    regen_caddyfile
    caddy_reload

    # Update bead
    if [[ -n "$bead_id" ]]; then
        # Persist final session state to bead metadata before cleanup
        bead_sync_metadata "$session_key" "$bead_id" "$config_dir"

        if [[ $done_flag -eq 1 ]]; then
            bead_close "$bead_id" "$config_dir"
            log "Closed bead $bead_id"
        else
            local stopped
            stopped=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
            local current_body
            current_body=$(bead_get_body "$bead_id" "$config_dir")
            bd_run "$config_dir" update "$bead_id" --body="${current_body}

## Session Ended
- stopped: $stopped
- bead remains open (run: tw start $feature to resume)" 2>/dev/null || true
            log "Updated bead $bead_id (still open — use --done to close)"
        fi
        bd_run "$config_dir" vc commit -m "tw session update" 2>/dev/null || true
    fi

    echo "  Stopped: $feature ($project)"
    if [[ $done_flag -eq 1 ]]; then
        echo "  Bead $bead_id closed. Session removed."
    else
        echo "  Bead $bead_id open. Restart with: tw start $feature"
        echo "  Remove with: tw stop $feature --done"
    fi
}

cmd_stop() {
    local targets="" done_flag=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --done) done_flag=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *) targets="$1"; shift ;;
        esac
    done

    [[ -z "$targets" ]] && die "Usage: tw stop <feature|N>[,<feature|N>,...] [--done]"

    # Split comma-separated targets into an array
    local IFS=','
    local -a target_list=($targets)
    unset IFS

    local failed=() succeeded=0
    for target in "${target_list[@]}"; do
        # Trim whitespace
        target="${target## }"
        target="${target%% }"
        [[ -z "$target" ]] && continue

        # resolve_session calls die() on failure (which exits), so run it in a
        # subshell that prints the resolved values. This lets us catch failures
        # without killing the whole script when processing multiple targets.
        local _resolved
        if ! _resolved=$(
            resolve_session "$target"
            printf '%s\t%s\t%s\t%s\t%s' "$session_key" "$project" "$config_dir" "$tmux_session" "$bead_id"
        ) 2>/dev/null; then
            echo "  Error: no session found for '$target' — skipping"
            failed+=("$target")
            continue
        fi

        local session_key project config_dir tmux_session bead_id
        IFS=$'\t' read -r session_key project config_dir tmux_session bead_id <<< "$_resolved"

        # Derive the feature name from session_key (strip project- prefix)
        local feature="${session_key#"${project}-"}"

        if _stop_one_session "$feature" "$done_flag" "$session_key" "$project" "$config_dir" "$tmux_session" "$bead_id"; then
            ((succeeded++)) || true
        else
            echo "  Error: failed to stop '$target' ($session_key)"
            failed+=("$target")
        fi
    done

    if [[ ${#failed[@]} -gt 0 ]]; then
        echo ""
        echo "  Failed to stop ${#failed[@]} session(s): ${failed[*]}"
        return 1
    fi
}

# Thin wrapper: `tw done X[,Y,...]` === `tw stop X[,Y,...] --done`.
# Explicit verb for "I'm finished with this feature" — tears down worktrees
# and closes the bead. The --done flag on stop remains as-is for muscle memory.
cmd_done() {
    [[ $# -eq 0 ]] && die "Usage: tw done <feature|N>[,<feature|N>,...]"
    cmd_stop "$@" --done
}

cmd_list() {
    local filter_project="" json_flag=0 sort_project=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --project=*) filter_project="${1#--project=}"; shift ;;
            --project) filter_project="$2"; shift 2 ;;
            --json) json_flag=1; shift ;;
            -p) sort_project=1; shift ;;
            *) shift ;;
        esac
    done

    local sessions_data
    sessions_data=$(sessions_read)

    python3 - "$sessions_data" "$filter_project" "$json_flag" "$sort_project" <<'EOF'
import json, sys, subprocess

data = json.loads(sys.argv[1])
filter_proj = sys.argv[2]
json_flag = sys.argv[3] == "1"
sort_project = sys.argv[4] == "1"

if not data:
    if json_flag:
        print("[]")
    else:
        print("  No active sessions.")
    sys.exit(0)

def feature_alive(project, feature):
    session_key = f'{project}-{feature}'
    r = subprocess.run(['tmux', 'has-session', '-t', session_key], capture_output=True)
    return r.returncode == 0

rows = []
# Index by full sessions.json insertion order so displayed # always matches
# what resolve_session / cmd_attach resolve for a numeric argument. Filters
# and sorts below only reorder or drop rows — they never renumber.
for full_idx, (key, s) in enumerate(data.items(), start=1):
    proj = s.get('project', '')
    feat = s.get('feature', '')
    if filter_proj and proj != filter_proj:
        continue
    bead = s.get('bead_id', '')
    mode = s.get('mode', '')
    started = s.get('started', '')[:16].replace('T', ' ')
    status = 'alive' if feature_alive(proj, feat) else 'stopped'
    # Collect unique engines from workers
    workers = s.get('workers', {})
    engines = sorted(set(w.get('engine', 'claude') for w in workers.values())) if workers else ['claude']
    engines_str = ','.join(engines)
    rows.append({
        "index": full_idx,
        "project": proj,
        "feature": feat,
        "status": status,
        "mode": mode,
        "bead": bead,
        "started": started,
        "session_key": key,
        "engines": engines_str,
    })

if sort_project:
    # Stable sort by project name so within-project order is preserved.
    # Indices are NOT renumbered — # column stays tied to sessions.json order
    # so `tw stop N` resolves to the same session the user sees.
    rows.sort(key=lambda r: r['project'])

if json_flag:
    print(json.dumps(rows, indent=2))
else:
    print(f"  {'#':<4}{'PROJECT':<15} {'FEATURE':<25} {'STATUS':<8} {'MODE':<10} {'ENGINES':<14} {'BEAD':<12} {'STARTED'}")
    print(f"  {'─'*3} {'─'*15} {'─'*25} {'─'*8} {'─'*10} {'─'*14} {'─'*12} {'─'*20}")
    for r in rows:
        print(f"  {r['index']:<4}{r['project']:<15} {r['feature']:<25} {r['status']:<8} {r['mode']:<10} {r['engines']:<14} {r['bead']:<12} {r['started']}")
EOF
}

cmd_attach() {
    local target="" window=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --claude) shift ;;  # deprecated, god is now the default
            --window=*) window="${1#--window=}"; shift ;;
            --window) window="$2"; shift 2 ;;
            *) target="$1"; shift ;;
        esac
    done

    local sessions_data
    sessions_data=$(sessions_read)

    local session_key
    if [[ -z "$target" ]]; then
        # Auto-attach if exactly one alive session
        session_key=$(python3 - "$sessions_data" <<'PYEOF'
import json, sys, subprocess
data = json.loads(sys.argv[1])
alive = []
for key, s in data.items():
    sk = f"{s['project']}-{s['feature']}"
    r = subprocess.run(['tmux', 'has-session', '-t', f'={sk}'], capture_output=True)
    if r.returncode == 0:
        alive.append(sk)
if len(alive) == 1:
    print(alive[0])
PYEOF
        )
        if [[ -z "$session_key" ]]; then
            echo "Multiple sessions — specify an index or name:"
            echo ""
            cmd_list
            echo ""
            echo "Usage: tw attach <N> or tw attach <project-feature>"
            return 1
        fi
    elif [[ "$target" =~ ^[0-9]+$ ]]; then
        # Index-based: pick Nth session (1-based, matches tw list order)
        session_key=$(python3 - "$sessions_data" "$target" <<'PYEOF'
import json, sys
data = json.loads(sys.argv[1])
idx = int(sys.argv[2])
keys = list(data.keys())
if 1 <= idx <= len(keys):
    print(keys[idx - 1])
PYEOF
        )
        [[ -z "$session_key" ]] && die "No session at index $target (have $(sessions_list_keys | wc -l | tr -d ' ') sessions)"
    else
        # Substring match against session keys
        session_key=$(sessions_list_keys | grep -F "$target" | head -1 || true)
        [[ -z "$session_key" ]] && die "No session matching '$target'"
    fi

    local tmux_session="$session_key"
    tmux has-session -t "=$tmux_session" 2>/dev/null \
        || die "tmux session '$tmux_session' is dead. Run: tw prune"

    # Select target window — default to god (orchestrator)
    if [[ -n "$window" ]]; then
        tmux select-window -t "=$tmux_session:$window" 2>/dev/null \
            || log "No window '$window' — attaching to default"
    else
        tmux select-window -t "=$tmux_session:god" 2>/dev/null || true
    fi

    exec tmux attach-session -t "=$tmux_session"
}

cmd_status() {
    local feature="" json_flag=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json_flag=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *) feature="$1"; shift ;;
        esac
    done

    [[ -z "$feature" ]] && die "Usage: tw status <feature> [--json]"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    local sessions_data
    sessions_data=$(sessions_read)

    # Read env_files config if available
    local env_config_file=""
    local status_config_dir=""
    local config_file
    if config_file=$(find_config 2>/dev/null); then
        env_config_file="$config_file"
        status_config_dir="$(dirname "$config_file")"
    else
        if [[ -n "$config_dir" ]]; then
            status_config_dir="$config_dir"
            for cf in "$config_dir/.tw.yml" "$config_dir/.devenv.yml"; do
                [[ -f "$cf" ]] && env_config_file="$cf" && break
            done
        fi
    fi

    python3 - "$sessions_data" "$session_key" "$json_flag" "$env_config_file" "$status_config_dir" <<'EOF'
import json, sys, subprocess, os
data = json.loads(sys.argv[1])
key = sys.argv[2]
json_flag = sys.argv[3] == "1"
env_config_file = sys.argv[4] if len(sys.argv) > 4 else ""
config_dir = sys.argv[5] if len(sys.argv) > 5 else ""

s = data.get(key)
if not s:
    if json_flag:
        print(json.dumps({"error": f"No session found: {key}"}))
    else:
        print(f"  No session found: {key}")
    sys.exit(1)

project_name = s.get('project', '')
feature_name = s.get('feature', '')
session_key = f'{project_name}-{feature_name}'
try:
    r = subprocess.run(['tmux', 'has-session', '-t', session_key], capture_output=True)
    tmux_alive = r.returncode == 0
except Exception:
    tmux_alive = False

# Build URLs map
urls = {}
for subdomain, svc_name in s.get('proxy_map', {}).items():
    svc = s.get('services', {}).get(svc_name, {})
    port = svc.get('port', '?')
    if subdomain == '':
        host = f'http://{project_name}-{feature_name}.localhost'
    else:
        host = f'http://{project_name}-{feature_name}-{subdomain}.localhost'
    urls[svc_name] = {"url": host, "port": port}

if json_flag:
    out = dict(s)
    out['session_key'] = key
    out['status'] = 'alive' if tmux_alive else 'dead'
    out['urls'] = urls
    print(json.dumps(out, indent=2))
else:
    print(f"\n  Feature:   {feature_name} ({project_name})")
    print(f"  tmux:      {'alive — attach: tmux attach -t ' + session_key if tmux_alive else 'DEAD (run: tw prune)'}")
    print(f"  Mode:      {s.get('mode', '')}")
    print(f"  Branch:    {s.get('branch', '')}")
    print(f"  Started:   {s.get('started', '')}")
    print(f"  Workspace: {s.get('workspace', '')}")
    print(f"  Bead:      {s.get('bead_id', 'none')}")
    db = s.get('db_name', '')
    if db:
        print(f"  DB:        {db}")

    worktrees = s.get('worktrees', {})
    if worktrees:
        print()
        print("  Worktrees:")
        for svc, path in worktrees.items():
            print(f"    {svc:<20} {path}")

    print()
    print("  Services:")
    for svc, info in s.get('services', {}).items():
        pane_id = info.get('pane_id', '')
        pane_str = f"  pane {pane_id}" if pane_id else ""
        print(f"    {svc:<20} port {info.get('port', '?')}{pane_str}")
    print()
    print("  URLs:")
    for svc_name, u in urls.items():
        print(f"    {svc_name:<20} {u['url']}  (→ :{u['port']})")

    # Show env file mappings if configured
    if env_config_file and os.path.isfile(env_config_file):
        try:
            import yaml
            cfg = yaml.safe_load(open(env_config_file))
            env_files = cfg.get('env_files', {}) or {}
            if env_files:
                service_ports = {svc: info.get('port', '?') for svc, info in s.get('services', {}).items()}
                print()
                print("  Env files (templated):")
                for target, vars_dict in env_files.items():
                    abs_path = os.path.join(config_dir, target) if config_dir else target
                    exists = '✓' if os.path.isfile(abs_path) else '✗'
                    print(f"    {exists} {target}")
                    if isinstance(vars_dict, dict):
                        for var, tmpl in vars_dict.items():
                            val = str(tmpl)
                            for svc_name, port in service_ports.items():
                                val = val.replace('{{' + svc_name + '.port}}', str(port))
                            print(f"      {var}={val}")
        except Exception:
            pass

    # Show worker engines (only when non-default engines are in use)
    workers_data = s.get('workers', {})
    has_non_default = any(w.get('engine', 'claude') != 'claude' for w in workers_data.values()) if workers_data else False
    if has_non_default:
        print()
        print("  Engines:")
        for wname, winfo in workers_data.items():
            engine = winfo.get('engine', 'claude')
            print(f"    {wname:<20} {engine}")
    print()
EOF
}

cmd_open() {
    local feature="${1:-}"
    [[ -z "$feature" ]] && die "Usage: tw open <feature>"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    local sessions_data
    sessions_data=$(sessions_read)

    local primary_url
    primary_url=$(python3 - "$sessions_data" "$session_key" <<'EOF'
import json, sys
data = json.loads(sys.argv[1])
s = data.get(sys.argv[2], {})
project = s.get('project', '')
feature = s.get('feature', '')
for subdomain, svc_name in s.get('proxy_map', {}).items():
    if subdomain == '':
        print(f'http://{project}-{feature}.localhost')
        break
EOF
)

    [[ -z "$primary_url" ]] && die "No primary URL found for '$feature'"
    log "Opening $primary_url"
    open "$primary_url"
}

cmd_prune() {
    local sessions_data removed=0
    sessions_data=$(sessions_read)

    # Capture (session_key, workspace) pairs for sessions about to be pruned,
    # BEFORE we delete them, so we can reset their orphaned task beads.
    local prune_targets
    prune_targets=$(python3 - "$sessions_data" <<'EOF'
import json, sys, subprocess
data = json.loads(sys.argv[1])
for key, s in data.items():
    project = s.get('project', '')
    feature = s.get('feature', '')
    session_key = f'{project}-{feature}'
    r = subprocess.run(['tmux', 'has-session', '-t', session_key], capture_output=True)
    if r.returncode != 0:
        print(f"{session_key}\t{s.get('workspace','')}")
EOF
    )

    # Reset orphans for each dying session before we forget its workspace.
    local orphan_total=0
    if [[ -n "$prune_targets" ]]; then
        while IFS=$'\t' read -r _sk _ws; do
            [[ -z "$_sk" || -z "$_ws" ]] && continue
            [[ -d "$_ws/.beads" ]] || continue
            local _reset
            _reset=$(orphaned_beads_reset "$_sk" "$_ws" 2>/dev/null || true)
            local _n
            _n=$(echo "$_reset" | sed -n 's/.*total reset: //p')
            if [[ -n "$_n" && "$_n" -gt 0 ]]; then
                echo "  [orphans] $_sk: reset $_n task bead(s)"
                orphan_total=$((orphan_total + _n))
            fi
        done <<< "$prune_targets"
    fi

    local new_data
    new_data=$(python3 - "$sessions_data" <<'EOF'
import json, sys, subprocess
data = json.loads(sys.argv[1])
removed = []
for key, s in list(data.items()):
    project = s.get('project', '')
    feature = s.get('feature', '')
    session_key = f'{project}-{feature}'
    r = subprocess.run(['tmux', 'has-session', '-t', session_key], capture_output=True)
    if r.returncode != 0:
        removed.append(key)
        del data[key]
for k in removed:
    print(f"REMOVED:{k}", file=sys.stderr)
print(json.dumps(data, indent=2))
EOF
    )

    echo "$new_data" | sessions_write
    regen_caddyfile
    caddy_reload

    # Clean up any orphaned spinner PIDs
    for pid_file in "$TW_DIR"/spinner-*.pid; do
        [[ -f "$pid_file" ]] || continue
        kill "$(cat "$pid_file")" 2>/dev/null || true
        rm -f "$pid_file"
    done

    [[ $orphan_total -gt 0 ]] && echo "  Reset $orphan_total orphaned task bead(s) total."
    echo "  Prune complete."
}

cmd_reconcile() {
    local feature="${1:-}"

    # Find config dir
    local config_dir
    local config_file
    if config_file=$(find_config 2>/dev/null); then
        config_dir="$(dirname "$config_file")"
    else
        config_dir="$PWD"
    fi

    log "Running reconciliation..."
    reconcile_session "$config_dir"

    # If a feature was specified, also reconcile its workers
    if [[ -n "$feature" ]]; then
        local project session_key
        project=$(yaml_get "$config_dir/.tw.yml" "project" "" 2>/dev/null || true)
        if [[ -n "$project" ]]; then
            session_key="${project}-${feature}"
            reconcile_workers "$session_key" "$config_dir"
        fi
    else
        # Reconcile workers for all active sessions
        local session_keys
        session_keys=$(sessions_list_keys)
        while IFS= read -r sk; do
            [[ -z "$sk" ]] && continue
            local sk_workspace
            sk_workspace=$(sessions_get_key "$sk" "workspace" 2>/dev/null || true)
            reconcile_workers "$sk" "${sk_workspace:-$config_dir}"
        done <<< "$session_keys"
    fi

    echo "  Reconciliation complete."
}

# ─── Resume from beads after hard reset ──────────────────────────────────────

# Resume a single feature (or all, if --all is passed). Called by cmd_resume
# for each target in a comma-separated list. Accepts either a single feature
# name/index or --all.
_resume_one_session() {
    local target_feature="" all=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) all=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *) target_feature="$1"; shift ;;
        esac
    done

    [[ -z "$target_feature" && $all -eq 0 ]] \
        && die "Usage: tw resume <feature|N> | tw resume --all"

    # Resolve numeric index to feature name (matches tw list numbering)
    if [[ -n "$target_feature" && "$target_feature" =~ ^[0-9]+$ ]]; then
        local _resume_data _resume_sk
        _resume_data=$(sessions_read)
        _resume_sk=$(python3 - "$_resume_data" "$target_feature" <<'PYEOF'
import json, sys
data = json.loads(sys.argv[1])
idx = int(sys.argv[2])
keys = list(data.keys())
if 1 <= idx <= len(keys):
    print(keys[idx - 1])
PYEOF
        )
        if [[ -n "$_resume_sk" ]]; then
            # Extract feature name from session key (project-feature)
            local _resume_proj
            _resume_proj=$(sessions_get_key "$_resume_sk" "project")
            target_feature="${_resume_sk#"${_resume_proj}-"}"
        else
            die "No session at index $target_feature"
        fi
    fi

    # NOTE: Do NOT call cmd_prune here. After a crash/reboot all tmux sessions
    # are dead, so prune would wipe every entry from sessions.json before we
    # get a chance to rediscover them from beads. The resume loop already skips
    # sessions that are alive (line ~2900), so pruning is unnecessary.
    # Users can run 'tw prune' separately if they want to clean up.

    # Discover feature beads from all workspace bead stores.
    local feature_beads
    feature_beads=$(python3 - "$target_feature" "$all" <<'PYEOF'
import json, sys, subprocess, os, glob

target = sys.argv[1]
resume_all = sys.argv[2] == "1"

# Collect all workspaces with .beads directories
sessions_file = os.path.expanduser("~/.tiddly-winks/sessions.json")
workspaces = set()
try:
    with open(sessions_file) as f:
        for key, s in json.load(f).items():
            ws = s.get("workspace", "")
            if ws and os.path.isdir(os.path.join(ws, ".beads")):
                workspaces.add(ws)
except (FileNotFoundError, json.JSONDecodeError):
    pass

# Check cwd and parents for .beads
d = os.getcwd()
while d != "/":
    if os.path.isdir(os.path.join(d, ".beads")):
        workspaces.add(d)
        break
    d = os.path.dirname(d)

# Scan ~/Programming/*/ for .beads
for p in glob.glob(os.path.expanduser("~/Programming/*/.beads")):
    workspaces.add(os.path.dirname(p))

results = []
seen_ids = set()

for ws in workspaces:
    try:
        proc = subprocess.run(
            ["bd", "export", "--all"],
            capture_output=True, text=True, cwd=ws
        )
        for line in proc.stdout.strip().splitlines():
            bead = json.loads(line)
            if bead["id"] in seen_ids:
                continue
            # Accept open/in_progress AND closed — closed is kept as a
            # low-priority fallback for features whose bead was closed but
            # whose tmux/sessions.json state is still live (stale close).
            # Dedup below prefers higher-ranked statuses via status_rank.
            status = bead.get("status", "")
            if status not in ("in_progress", "open", "closed"):
                continue
            if bead.get("title", "").startswith("tw:worker"):
                continue

            title = bead.get("title", "")
            if "(" not in title or ")" not in title:
                continue

            desc = bead.get("description", "")
            title_feature = title.split("(")[0].strip()
            project = title.split("(")[1].rstrip(")")

            # Parse description for branch, workspace, mode
            branch = mode = bead_ws = ""
            for dline in desc.splitlines():
                dline = dline.strip()
                if dline.startswith("- branch:"):
                    branch = dline.split(":", 1)[1].strip()
                elif dline.startswith("- workspace:"):
                    bead_ws = dline.split(":", 1)[1].strip()
                elif dline.startswith("- mode:"):
                    mode = dline.split(":", 1)[1].strip()

            # Derive feature name from branch using .tw.yml branch_prefix.
            # More reliable than bead title which may diverge.
            feature = title_feature  # fallback
            actual_ws = bead_ws or ws
            if branch:
                try:
                    import yaml
                    bp = ""
                    for cfg_name in (".tw.yml", ".devenv.yml"):
                        cfg_path = os.path.join(actual_ws, cfg_name)
                        if os.path.isfile(cfg_path):
                            with open(cfg_path) as cf:
                                cfg = yaml.safe_load(cf) or {}
                            bp = (cfg.get("worktrees") or {}).get("branch_prefix", "")
                            break
                    if not bp:
                        import getpass
                        bp = getpass.getuser() + "/"
                    if branch.startswith(bp):
                        feature = branch[len(bp):]
                except Exception:
                    pass  # keep title_feature as fallback

            if not resume_all and target and feature != target:
                continue

            meta = bead.get("metadata", {}) or {}
            dw_json = meta.get("dynamic_workers", "[]")

            # Rank candidates so dedup can prefer the strongest match when
            # multiple beads share the same session key. Lower rank = better.
            #   status:  in_progress(0) < open(1) < closed(2)
            #   marker:  has "## Feature Space" header(+0) < missing(+1)
            # Soft signal per tw-e1h.4: beads with the marker are preferred
            # but not required — matching on title+status is sufficient.
            status_rank = {"in_progress": 0, "open": 1, "closed": 2}.get(status, 3)
            marker_rank = 0 if "## Feature Space" in desc else 1
            rank = status_rank * 2 + marker_rank

            sk = f"{project}-{feature}"
            seen_ids.add(bead["id"])

            # Dedup by session key — replace existing entry if this one ranks
            # better (lower), otherwise drop it.
            existing_idx = None
            for _i, _r in enumerate(results):
                if _r.get("_sk") == sk:
                    existing_idx = _i
                    break
            entry = {
                "_sk": sk,
                "_rank": rank,
                "bead_id": bead["id"],
                "feature": feature,
                "project": project,
                "branch": branch,
                "workspace": actual_ws,
                "mode": mode or "local",
                "dynamic_workers": dw_json,
            }
            if existing_idx is None:
                results.append(entry)
            elif rank < results[existing_idx].get("_rank", 999):
                results[existing_idx] = entry
    except Exception:
        continue

print(json.dumps(results))
PYEOF
    )

    local count
    count=$(echo "$feature_beads" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))")

    # ─── Fallback: sessions.json entry without a matching bead ────────────────
    # Some sessions.json entries have an empty bead_id (e.g. created before
    # bead integration, or bead creation failed silently). `tw list` happily
    # shows them but the bead scan above returns nothing. Lazy-create a bead
    # from the session entry so resume can proceed.
    if [[ "$count" == "0" && $all -eq 0 && -n "$target_feature" ]]; then
        local fb_sk
        fb_sk=$(python3 - "$target_feature" <<'PYEOF'
import json, os, sys
target = sys.argv[1]
try:
    d = json.load(open(os.path.expanduser("~/.tiddly-winks/sessions.json")))
except Exception:
    sys.exit(0)
for k, v in d.items():
    if v.get("feature") == target or k.endswith("-" + target):
        print(k)
        break
PYEOF
        )
        if [[ -n "$fb_sk" ]]; then
            local fb_proj fb_ws fb_branch fb_mode fb_dw new_bead_id
            fb_proj=$(sessions_get_key "$fb_sk" "project")
            fb_ws=$(sessions_get_key "$fb_sk" "workspace")
            fb_branch=$(sessions_get_key "$fb_sk" "branch")
            fb_mode=$(sessions_get_key "$fb_sk" "mode")
            [[ -z "$fb_mode" ]] && fb_mode="local"

            if [[ ! -d "$fb_ws" ]]; then
                die "sessions.json entry '$fb_sk' references missing workspace: $fb_ws"
            fi

            log "No bead matched '$target_feature' — falling back to sessions.json entry '$fb_sk' and lazy-creating a bead"

            # Ensure bead store exists in the workspace
            if [[ ! -d "$fb_ws/.beads" ]]; then
                (cd "$fb_ws" && bd init --stealth --prefix "$fb_proj" --quiet 2>/dev/null) || true
            fi

            new_bead_id=$(bead_find_or_create "$target_feature ($fb_proj)" "$fb_ws" 2>/dev/null || true)
            if [[ -z "$new_bead_id" ]]; then
                log "WARNING: lazy bead creation failed for '$target_feature' in $fb_ws (likely broken .beads store). Proceeding in bead-less degraded mode."
            else
                bead_mark_in_progress "$new_bead_id" "$fb_ws"
                # Write bead_id back into sessions.json so future resumes skip the fallback
                python3 - "$fb_sk" "$new_bead_id" <<'PYEOF'
import json, os, sys
sk, bid = sys.argv[1], sys.argv[2]
f = os.path.expanduser("~/.tiddly-winks/sessions.json")
d = json.load(open(f))
if sk in d:
    d[sk]["bead_id"] = bid
    json.dump(d, open(f, "w"), indent=2)
PYEOF
            fi

            # Preserve dynamic_workers from sessions.json so respawn still works
            fb_dw=$(python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
v = d.get('$fb_sk', {}).get('dynamic_workers', [])
print(json.dumps(v))
" 2>/dev/null || echo "[]")

            feature_beads=$(python3 -c "
import json, sys
print(json.dumps([{
    '_sk': sys.argv[1],
    'bead_id': sys.argv[2],
    'feature': sys.argv[3],
    'project': sys.argv[4],
    'branch': sys.argv[5],
    'workspace': sys.argv[6],
    'mode': sys.argv[7],
    'dynamic_workers': sys.argv[8],
}]))
" "$fb_sk" "$new_bead_id" "$target_feature" "$fb_proj" "$fb_branch" "$fb_ws" "$fb_mode" "$fb_dw")
            count=1
        fi
    fi

    if [[ "$count" == "0" ]]; then
        if [[ $all -eq 1 ]]; then
            echo "  No in-progress feature beads found to resume."
        else
            die "No in-progress bead found for feature '$target_feature'"
        fi
        return 0
    fi

    echo ""
    echo "  Found $count feature(s) to resume:"

    local i=0
    while IFS= read -r bead_json; do
        [[ -z "$bead_json" || "$bead_json" == "null" ]] && continue

        local feat proj ws mode bead_id dw_json
        feat=$(echo "$bead_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['feature'])")
        proj=$(echo "$bead_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['project'])")
        ws=$(echo "$bead_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['workspace'])")
        mode=$(echo "$bead_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['mode'])")
        bead_id=$(echo "$bead_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['bead_id'])")
        dw_json=$(echo "$bead_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['dynamic_workers'])")

        local session_key="${proj}-${feat}"

        if tmux has-session -t "=$session_key" 2>/dev/null; then
            echo "  ⏭  $session_key — already running, skipping"
            continue
        fi

        echo ""
        echo "  ▶ Resuming: $session_key (bead: $bead_id)"
        echo "    workspace: $ws"
        echo "    mode: $mode"

        if [[ ! -d "$ws" ]]; then
            echo "    ✗ Workspace not found: $ws — skipping"
            continue
        fi

        if [[ ! -f "$ws/.tw.yml" && ! -f "$ws/.devenv.yml" ]]; then
            echo "    ✗ No .tw.yml found in workspace: $ws — skipping"
            continue
        fi

        echo "    Starting session..."
        # Run cmd_start; it may exit non-zero due to non-critical failures
        # (e.g., db_setup). Check tmux session existence as the real success test.
        (cd "$ws" && cmd_start "$feat" --mode "$mode") 2>&1 || true

        if ! tmux has-session -t "=$session_key" 2>/dev/null; then
            echo "    ✗ Failed to start $session_key — continuing with next"
            continue
        fi

        # Respawn dynamic workers from bead metadata
        if [[ -n "$dw_json" && "$dw_json" != "[]" ]]; then
            echo "    Respawning dynamic workers..."
            local dw_pairs
            dw_pairs=$(python3 -c "
import json, sys
dw = json.loads(sys.argv[1])
for w in dw:
    print(f\"{w['name']}:{w.get('role', '')}\")
" "$dw_json" 2>/dev/null || true)

            while IFS= read -r wpair; do
                [[ -z "$wpair" ]] && continue
                local wname="${wpair%%:*}"
                local wrole="${wpair#*:}"

                # Skip if already spawned by cmd_start (from .tw.yml workers section)
                if tmux list-windows -t "=$session_key" -F "#{window_name}" 2>/dev/null | grep -qx "$wname"; then
                    continue
                fi

                echo "    + spawning: $wname${wrole:+ (role: $wrole)}"
                if [[ -n "$wrole" ]]; then
                    (cd "$ws" && cmd_spawn "$feat" "$wname" "$wrole") 2>/dev/null || {
                        echo "      ✗ Failed to spawn $wname"
                    }
                else
                    (cd "$ws" && cmd_spawn "$feat" "$wname") 2>/dev/null || {
                        echo "      ✗ Failed to spawn $wname"
                    }
                fi
            done <<< "$dw_pairs"
        fi

        # Reset any task beads left in_progress but assigned to workers that
        # no longer exist in the freshly-respawned roster. The session was
        # crash-restarted, so anything still in_progress is by definition
        # orphaned until a worker picks it back up.
        local _orphan_reset
        _orphan_reset=$(orphaned_beads_reset "$session_key" "$ws" 2>/dev/null || true)
        local _orphan_n
        _orphan_n=$(echo "$_orphan_reset" | sed -n 's/.*total reset: //p')
        if [[ -n "$_orphan_n" && "$_orphan_n" -gt 0 ]]; then
            echo "      ↻ reset $_orphan_n orphaned task bead(s)"
        fi

        echo "    ✓ $session_key resumed"
        ((i++)) || true
    done < <(echo "$feature_beads" | python3 -c "
import json, sys
for item in json.load(sys.stdin):
    print(json.dumps(item))
")

    echo ""
    echo "  Resume complete. $i session(s) restarted."
    echo "  Run 'tw list' to see all sessions."
    echo ""
}

cmd_resume() {
    local targets="" all=0
    local -a passthrough=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) all=1; passthrough+=("$1"); shift ;;
            -*) die "Unknown option: $1" ;;
            *)
                if [[ -z "$targets" ]]; then
                    targets="$1"
                else
                    die "Unexpected extra argument: $1"
                fi
                shift ;;
        esac
    done

    [[ -z "$targets" && $all -eq 0 ]] \
        && die "Usage: tw resume <feature|N>[,<feature|N>,...] | tw resume --all"

    # --all mode: no target list, single invocation
    if [[ $all -eq 1 ]]; then
        _resume_one_session --all
        return $?
    fi

    # Split comma-separated targets
    local IFS=','
    local -a target_list=($targets)
    unset IFS

    # Single-target: call directly so die() aborts tw loudly with its original
    # exit code (pre-2cf1f6a behavior).
    if [[ ${#target_list[@]} -eq 1 ]]; then
        local only="${target_list[0]}"
        only="${only## }"; only="${only%% }"
        [[ -z "$only" ]] && die "empty target"
        _resume_one_session "$only"
        return $?
    fi

    local failed=() succeeded=0
    for target in "${target_list[@]}"; do
        # Trim whitespace
        target="${target## }"
        target="${target%% }"
        [[ -z "$target" ]] && continue

        # Run in subshell so a die() inside _resume_one_session (e.g. no bead
        # found for target) only aborts that one target.
        if ( _resume_one_session "$target" ); then
            ((succeeded++)) || true
        else
            echo "  Error: failed to resume '$target'"
            failed+=("$target")
        fi
    done

    if [[ ${#failed[@]} -gt 0 ]]; then
        echo ""
        echo "  Failed to resume ${#failed[@]} session(s): ${failed[*]}"
        return 1
    fi
}


cmd_editor() {
    local feature="${1:-}"
    [[ -z "$feature" ]] && die "Usage: tw editor <feature>"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    local config_file
    config_file=$(find_config 2>/dev/null) || config_file="$config_dir/.tw.yml"

    # Build folder list from session worktrees, falling back to service paths
    local workspace_file
    workspace_file="${config_dir}/worktrees/${feature}/${feature}.code-workspace"

    local folders_json
    folders_json=$(python3 - "$SESSIONS_FILE" "$session_key" "$config_dir" "$config_file" "$feature" <<'EOF'
import json, os, sys

sessions_file, session_key, config_dir, config_file, feature = sys.argv[1:]

# Try worktrees from sessions.json first
worktrees = {}
try:
    data = json.load(open(sessions_file))
    worktrees = data.get(session_key, {}).get("worktrees", {})
except Exception:
    pass

folders = []
if worktrees:
    for svc, path in worktrees.items():
        rel = os.path.relpath(path, os.path.dirname(os.path.dirname(os.path.dirname(path))))
        # path is absolute; make it relative to the .code-workspace file location
        ws_dir = os.path.join(config_dir, "worktrees", feature)
        rel_path = os.path.relpath(path, ws_dir)
        folders.append({"path": rel_path, "name": svc})
else:
    # No active session — fall back to main service paths so the file is still useful
    try:
        import yaml
        cfg = yaml.safe_load(open(config_file))
        services = cfg.get("services", {}) or {}
        for svc, info in services.items():
            svc_path = (info or {}).get("path", "")
            if svc_path:
                abs_path = os.path.join(config_dir, svc_path)
                ws_dir = os.path.join(config_dir, "worktrees", feature)
                rel_path = os.path.relpath(abs_path, ws_dir)
                folders.append({"path": rel_path, "name": svc})
    except Exception:
        pass

print(json.dumps(folders))
EOF
    )

    if [[ -z "$folders_json" || "$folders_json" == "[]" ]]; then
        die "No worktrees or services found for '$feature'"
    fi

    # Write .code-workspace
    local ws_dir
    ws_dir="${config_dir}/worktrees/${feature}"
    mkdir -p "$ws_dir"

    python3 - "$workspace_file" "$folders_json" "$project" "$feature" <<'EOF'
import json, sys

outfile, folders_json, project, feature = sys.argv[1:]
folders = json.loads(folders_json)
workspace = {
    "folders": folders,
    "settings": {
        "git.ignoreLimitWarning": True
    }
}
with open(outfile, "w") as f:
    json.dump(workspace, f, indent="\t")
    f.write("\n")
print(outfile)
EOF

    log "Wrote $workspace_file"

    # Open in VS Code
    if command -v code &>/dev/null; then
        code "$workspace_file"
        echo "  Opened: $workspace_file"
    else
        echo "  Workspace file: $workspace_file"
        echo "  (install 'code' CLI to open automatically)"
    fi
}

cmd_claude() {
    local feature="${1:-}"
    [[ -z "$feature" ]] && die "Usage: tw claude <feature>"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    if ! tmux has-session -t "=$tmux_session" 2>/dev/null; then
        die "No tmux session '$tmux_session'. Run: tw start $feature"
    fi

    # Create god window if it doesn't exist
    local claude_window="god"
    if ! tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -q "^${claude_window}$"; then
        log "Creating god window in $tmux_session"
        tmux new-window -d -t "=$tmux_session" -n "$claude_window"
        local _god_cmd
        _god_cmd=$(engine_spawn_cmd "claude" "$feature")
        tmux send-keys -t "=$tmux_session:$claude_window" "cd '$config_dir' && TW_SESSION='$session_key' TW_WORKER='god' $_god_cmd" Enter
    fi

    # Build context block for pasting as first Claude message
    local sessions_data
    sessions_data=$(sessions_read)

    local branch db_name
    branch=$(sessions_get_key "$session_key" "branch")
    db_name=$(sessions_get_key "$session_key" "db_name")

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  Paste this as your first Claude message:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Resume work on $feature ($project)."
    [[ -n "$bead_id" ]] && echo "Bead $bead_id has full context — run: bd show $bead_id"
    [[ -n "$branch" ]] && echo "Branch: $branch"
    echo ""

    # Worktrees
    local worktrees_output
    worktrees_output=$(python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
wt = d.get('$session_key', {}).get('worktrees', {})
for svc, path in wt.items():
    print(f'  {svc}: {path}')
" 2>/dev/null || true)

    if [[ -n "$worktrees_output" ]]; then
        echo "Worktrees:"
        echo "$worktrees_output"
        echo ""
    fi

    [[ -n "$db_name" ]] && echo "DB: $db_name" && echo ""

    echo "URLs:"
    python3 - "$sessions_data" "$session_key" <<'EOF'
import json, sys
data = json.loads(sys.argv[1])
s = data.get(sys.argv[2], {})
project = s.get('project', '')
feature = s.get('feature', '')
for subdomain, svc_name in s.get('proxy_map', {}).items():
    if subdomain == '':
        print(f'  http://{project}-{feature}.localhost')
    else:
        print(f'  http://{project}-{feature}-{subdomain}.localhost')
EOF
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Set terminal window title = project, tab title = feature
    if [[ -n "${TMUX:-}" ]]; then
        printf '\033Ptmux;\033\033]2;%s\007\033\\' "$project"
        printf '\033Ptmux;\033\033]1;%s\007\033\\' "$feature"
    else
        printf '\033]2;%s\007' "$project"
        printf '\033]1;%s\007' "$feature"
    fi

    # Switch to god window and attach
    tmux select-window -t "=$tmux_session:$claude_window"
    tmux attach-session -t "=$tmux_session"
}

cmd_append() {
    local feature="${1:-}"
    [[ -z "$feature" ]] && die "Usage: tw append <feature>   (reads from stdin)"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    # Also search open beads if not in sessions.json (session may be stopped)
    if [[ -z "$bead_id" ]]; then
        bead_id=$(bead_find_open "$feature ($project)" "$config_dir")
    fi

    [[ -z "$bead_id" ]] && die "No bead found for '$feature'. Start a session first."

    # Read from stdin
    local appended_text
    appended_text=$(cat | scrub_secrets)
    [[ -z "$appended_text" ]] && die "No text provided (pipe text or paste + Ctrl-D)"

    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%MZ")

    # Get current bead body and append
    local current_body
    current_body=$(bead_get_body "$bead_id" "$config_dir")

    local new_body
    new_body="${current_body}
### Session — ${timestamp}
${appended_text}"

    bd_run "$config_dir" update "$bead_id" --body="$new_body" 2>/dev/null \
        || die "Failed to update bead $bead_id"
    bd_run "$config_dir" vc commit -m "tw session update" 2>/dev/null || true

    log "Appended to bead $bead_id"
    echo "  Bead $bead_id updated. Run: bd show $bead_id"
}

# ─── Init ─────────────────────────────────────────────────────────────────────

cmd_init() {
    local force=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *) shift ;;
        esac
    done

    # Check for existing config
    if existing=$(find_config 2>/dev/null); then
        [[ $force -eq 0 ]] && die ".tw.yml already exists at $existing. Use --force to overwrite."
        log "Overwriting existing config (--force)"
    fi

    # Verify claude CLI is available
    command -v claude >/dev/null 2>&1 || die "claude CLI not found — install Claude Code first"

    local project_dir="$PWD"
    local git_remote
    git_remote=$(git remote get-url origin 2>/dev/null || true)

    # ─── Fast local pre-scan ─────────────────────────────────────────────────
    log "Scanning project structure..."

    local prescan=""

    # Top-level directory listing
    prescan+="## Directory listing
$(ls -1a "$project_dir" | head -50)

"

    # Detect sub-repos (dirs with their own package.json or pyproject.toml)
    local subrepos=""
    for d in "$project_dir"/*/; do
        [[ -d "$d" ]] || continue
        local dname
        dname=$(basename "$d")
        if [[ -f "$d/package.json" || -f "$d/pyproject.toml" || -f "$d/Pipfile" || -f "$d/.git" ]]; then
            subrepos+="- $dname"
            [[ -f "$d/package.json" ]] && subrepos+=" (package.json)"
            [[ -f "$d/pyproject.toml" ]] && subrepos+=" (pyproject.toml)"
            [[ -f "$d/Pipfile" ]] && subrepos+=" (Pipfile)"
            [[ -d "$d/.git" ]] && subrepos+=" (separate git repo)"
            subrepos+=$'\n'
        fi
    done
    [[ -n "$subrepos" ]] && prescan+="## Sub-repos detected
$subrepos
"

    # Key config files — read first 30 lines of each if they exist
    for f in package.json pyproject.toml Pipfile docker-compose.yml docker-compose.yaml \
             Makefile .env.example Cargo.toml go.mod; do
        if [[ -f "$project_dir/$f" ]]; then
            prescan+="## $f (first 30 lines)
$(head -30 "$project_dir/$f")
...

"
        fi
    done

    # Detect framework configs
    for pattern in vite.config.* next.config.* nuxt.config.* svelte.config.*; do
        for f in "$project_dir"/$pattern; do
            [[ -f "$f" ]] || continue
            prescan+="## $(basename "$f") (first 15 lines)
$(head -15 "$f")
...

"
        done
    done

    # Sub-repo package.jsons
    if [[ -n "$subrepos" ]]; then
        for d in "$project_dir"/*/; do
            local dname
            dname=$(basename "$d")
            if [[ -f "$d/package.json" ]]; then
                prescan+="## $dname/package.json (first 20 lines)
$(head -20 "$d/package.json")
...

"
            fi
            if [[ -f "$d/pyproject.toml" ]]; then
                prescan+="## $dname/pyproject.toml (first 20 lines)
$(head -20 "$d/pyproject.toml")
...

"
            fi
        done
    fi

    # Detect package manager
    local pkg_mgr="npm"
    [[ -f "$project_dir/bun.lockb" || -f "$project_dir/bun.lock" ]] && pkg_mgr="bun"
    [[ -f "$project_dir/yarn.lock" ]] && pkg_mgr="yarn"
    [[ -f "$project_dir/pnpm-lock.yaml" ]] && pkg_mgr="pnpm"
    prescan+="## Detected package manager: $pkg_mgr
"

    # Check for database setup scripts
    local db_scripts=""
    for f in scripts/db.sh scripts/setup-db.sh scripts/reset-db.sh db/setup.sh; do
        [[ -f "$project_dir/$f" ]] && db_scripts+="- $f"$'\n'
    done
    for d in "$project_dir"/*/; do
        local dname
        dname=$(basename "$d")
        for f in scripts/db.sh scripts/setup-db.sh scripts/reset-db.sh; do
            [[ -f "$d/$f" ]] && db_scripts+="- $dname/$f"$'\n'
        done
    done
    [[ -n "$db_scripts" ]] && prescan+="## Database setup scripts
$db_scripts
"

    log "Generating config with Claude..."

    local prompt
    prompt=$(cat <<PROMPT
You are generating a .tw.yml config for tiddly-winks, a feature space manager.

## Pre-scan results

$prescan

Git remote: ${git_remote:-none}
Project directory: $project_dir

You do NOT need to use any tools — all the information you need is above.
If something critical is ambiguous, use Read to check one or two specific files.

## .tw.yml schema

\`\`\`yaml
project: myproject          # short slug, lowercase, hyphens OK — derive from git remote or dir name

issue_tracker:
  type: github              # github | linear | none
  repo: owner/repo          # only for type: github (from git remote)
  # team: FAI               # only for type: linear

worktrees:                  # ONLY include if there are multiple sub-repos (separate git repos or
  base: worktrees           # clearly separate frontend/backend app directories)
  branch_prefix: yourname/  # defaults to $(whoami)/ if omitted

services:
  frontend:
    path: my-frontend       # path relative to workspace root (use . for single-repo)
    command: "bun run dev -- --port {port}"   # use {port} placeholder
    port_hint: 5173
    window: frontend        # tmux window name

  backend:
    path: my-backend
    command: "uvicorn main:app --port {port}"
    port_hint: 8000
    env: "PORT={port}"      # optional: env var to inject before the command
    window: backend
    db_setup: "./scripts/db.sh"   # optional: run once after worktree created
    post_setup: "npm install"     # optional: run after worktree created (e.g. install deps)

proxy:
  "": frontend              # http://{project}-{feature}.localhost → frontend port
  api: backend              # http://{project}-{feature}-api.localhost → backend port

workers:                      # generic worker pool — workers are interchangeable
  - dev                       # 2-3 generic workers is typical
  - ops                       # god dispatches tasks with full context at send time
  # Add more workers if the project is large or has many parallel workstreams

quality_gates:                # optional: commands workers must pass before PRs
  typecheck: "tsc --noEmit"   # only if TypeScript project
  lint: "bun run lint"        # adapt to project's linter (eslint, ruff, etc.)
  test: "bun test"            # adapt to project's test runner
\`\`\`

## Rules

- project: lowercase slug from git remote repo name or directory name
- issue_tracker: if remote is github.com, use type github + repo; otherwise none
- worktrees: omit entirely for single-repo or pure tooling/script projects
- services: one entry per runnable service. Prefer bun over npm if bun.lock exists.
  For Python prefer uvicorn/gunicorn/flask run patterns. Check the actual start scripts.
  Omit services section entirely if there are no runnable services (e.g. pure CLI tools).
- db_setup: only include if you see a clear setup/reset script for a local database
- proxy: map "" to the primary web-facing service, named subdomains to APIs/other services
  Omit if no services.
- workers: use a generic pool of 2-3 workers (e.g. dev, ops) as a simple list.
  Do NOT assign roles — workers are interchangeable and god dispatches tasks with
  full context at send time. Specialization (CI, service monitoring, frontend, backend)
  happens through task descriptions, not worker identity. For larger projects with
  many parallel workstreams, add more generic workers (dev-1, dev-2, dev-3).
- quality_gates: include if the project has TypeScript (typecheck), a linter (lint),
  or tests (test). Use the project's actual commands (e.g. bun test, npm run lint,
  ruff check, pytest). Omit for projects with no clear quality checks.

## Output

Output ONLY the raw YAML. No explanation, no markdown fences, no prose before or after.
Start your response with "project:" and end with the last YAML line. Nothing else.
PROMPT
)

    local yaml_out
    yaml_out=$(claude -p "$prompt" 2>/dev/null) \
        || die "Claude agent failed — check that 'claude' CLI is authenticated"

    [[ -z "$yaml_out" ]] && die "Claude returned empty output"

    # Extract YAML block — strip markdown fences and any surrounding prose
    yaml_out=$(echo "$yaml_out" | python3 -c "
import sys, re
text = sys.stdin.read().strip()
# Strip markdown fences
text = re.sub(r'^\`\`\`[a-z]*\n', '', text)
text = re.sub(r'\n\`\`\`\s*$', '', text)
# If prose surrounds YAML, extract just the YAML block:
# find first line that looks like a top-level YAML key (word: ...)
# and last line that is YAML content (key, value, or blank)
lines = text.splitlines()
start = None
end = None
yaml_line = re.compile(r'^[a-zA-Z_][a-zA-Z0-9_]*\s*:|^\s+\S|^\s*$')
top_key = re.compile(r'^[a-zA-Z_][a-zA-Z0-9_]*\s*:')
for i, line in enumerate(lines):
    if start is None and top_key.match(line):
        start = i
    if start is not None and yaml_line.match(line):
        end = i
if start is not None and end is not None:
    text = '\n'.join(lines[start:end+1]).strip()
print(text)
")

    # Validate YAML is parseable
    if ! echo "$yaml_out" | python3 -c "import yaml, sys; yaml.safe_load(sys.stdin)" 2>/dev/null; then
        log "Warning: generated output may not be valid YAML"
    fi

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  Generated .tw.yml:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "$yaml_out"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    local answer
    read -r -p "Write .tw.yml to $project_dir? [Y/n] " answer
    answer="${answer:-Y}"

    if [[ "$answer" =~ ^[Yy]$ ]]; then
        echo "$yaml_out" > "$project_dir/.tw.yml"
        log "Wrote $project_dir/.tw.yml"

        # Init bead store if not present
        if [[ ! -d "$project_dir/.beads" ]]; then
            local init_project
            init_project=$(yaml_get "$project_dir/.tw.yml" "project" "")
            if [[ -n "$init_project" ]]; then
                (cd "$project_dir" && bd init --stealth --prefix "$init_project" --quiet 2>/dev/null) \
                    && log "Initialized bead store: $project_dir/.beads" || true
            fi
        fi

        echo ""
        echo "  Done. Review and adjust as needed."
        echo ""

        # Offer to set up PR review profiles
        local review_answer
        read -r -p "Set up PR review profiles? [Y/n] " review_answer
        review_answer="${review_answer:-Y}"
        if [[ "$review_answer" =~ ^[Yy]$ ]]; then
            _review_init
        fi

        # Offer to start immediately
        local start_answer
        read -r -p "Start a feature now? Enter name (or press Enter to skip): " start_answer
        if [[ -n "$start_answer" ]]; then
            cmd_start "$start_answer"
        else
            echo "  Ready. Run: tw start <feature>"
        fi
    else
        echo "  Aborted — nothing written."
    fi
}

nudge_dir() { echo "$HOME/.tiddly-winks/nudge/$1/$2"; }

# Enqueue a nudge message for a worker.
# Usage: nudge_enqueue <session_key> <worker> <message> [ttl_minutes]
nudge_enqueue() {
    local session_key="$1" worker="$2" message="$3" ttl="${4:-30}"
    local dir ts msg_file
    dir="$(nudge_dir "$session_key" "$worker")"
    mkdir -p "$dir"
    ts=$(date +%s)
    msg_file="${dir}/${ts}-${ttl}.msg"
    # Atomic write: temp file + rename to avoid partial reads
    local tmp_file
    tmp_file=$(mktemp "${dir}/.nudge-XXXXXX")
    printf '%s' "$message" > "$tmp_file"
    mv "$tmp_file" "$msg_file"
}

# Drain all non-expired nudge messages for a worker. Prints content and deletes files.
# Usage: nudge_drain <session_key> <worker>
nudge_drain() {
    local session_key="$1" worker="$2"
    local dir now
    dir="$(nudge_dir "$session_key" "$worker")"
    [[ -d "$dir" ]] || return 0
    now=$(date +%s)
    for msg_file in "$dir"/*.msg; do
        [[ -f "$msg_file" ]] || continue
        local base ts ttl expiry
        base=$(basename "$msg_file" .msg)
        ts="${base%%-*}"
        ttl="${base##*-}"
        expiry=$((ts + ttl * 60))
        if [[ "$now" -gt "$expiry" ]]; then
            rm -f "$msg_file"
            continue
        fi
        cat "$msg_file"
        printf '\n'
        rm -f "$msg_file"
    done
}

# Drain the oldest non-expired nudge for a worker. Returns content and removes the file.
# Usage: nudge_drain_one <session_key> <worker>
nudge_drain_one() {
    local session_key="$1" worker="$2"
    local dir
    dir="$(nudge_dir "$session_key" "$worker")"
    [[ -d "$dir" ]] || return 0
    local now
    now=$(date +%s)
    for msg_file in "$dir"/*.msg; do
        [[ -f "$msg_file" ]] || continue
        local base ts ttl expiry
        base=$(basename "$msg_file" .msg)
        ts="${base%%-*}"
        ttl="${base##*-}"
        expiry=$((ts + ttl * 60))
        if [[ "$now" -gt "$expiry" ]]; then
            rm -f "$msg_file"
            continue
        fi
        cat "$msg_file"
        rm -f "$msg_file"
        return 0
    done
}

# ─── Mail System (beads-backed persistent messaging) ─────────────────────────

cmd_mail() {
    local subcmd="${1:-}"
    [[ -z "$subcmd" ]] && die "Usage: tw mail <send|inbox|read|ack> ..."
    shift

    case "$subcmd" in
        send)  _mail_send "$@" ;;
        inbox) _mail_inbox "$@" ;;
        read)  _mail_read "$@" ;;
        ack)   _mail_ack "$@" ;;
        *)     die "Unknown mail subcommand: $subcmd. Use send, inbox, read, or ack." ;;
    esac
}

_mail_send() {
    local feature="" target="" subject="" body="" from=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -s|--subject) subject="$2"; shift 2 ;;
            -m|--message) body="$2"; shift 2 ;;
            -f|--from)    from="$2"; shift 2 ;;
            -*)           die "Unknown option: $1" ;;
            *)
                if [[ -z "$feature" ]]; then feature="$1"
                elif [[ -z "$target" ]]; then target="$1"
                else die "Too many positional args"
                fi
                shift ;;
        esac
    done

    [[ -z "$feature" || -z "$target" || -z "$subject" ]] \
        && die 'Usage: tw mail send <feature> <target> -s "Subject" [-m "Body"] [-f sender]'

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    # Default sender: try to detect from env
    if [[ -z "$from" ]]; then
        from="${TW_WORKER_NAME:-unknown}"
    fi

    local sent_at
    sent_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    # Create mail bead with metadata
    local metadata
    metadata=$(printf '{"mail_from":"%s","mail_to":"%s","mail_status":"unread","mail_sent_at":"%s","mail_session":"%s"}' \
        "$from" "$target" "$sent_at" "$session_key")

    local bead_id
    bead_id=$(bd create "mail: $subject" \
        -d "${body:-$subject}" \
        -l "tw:mail,mail:to:${target},mail:from:${from},mail:unread" \
        --metadata "$metadata" \
        -p 3 \
        2>&1 | grep -oE 'issue: [a-z0-9-]+' | head -1 | sed 's/issue: //')

    if [[ -z "$bead_id" ]]; then
        die "Failed to create mail bead"
    fi

    echo "  Mail sent: $bead_id (to=$target, subject=$subject)"

    # Send nudge as wake-up
    if tmux has-session -t "=$session_key" 2>/dev/null; then
        if tmux list-windows -t "=$session_key" -F "#{window_name}" 2>/dev/null | grep -qx "$target"; then
            nudge_enqueue "$session_key" "$target" \
                "You have mail — run: tw mail read $bead_id" 5 2>/dev/null || true
            send_to_pane "=$session_key:$target" \
                "You have mail. Run: tw mail read $bead_id" 2>/dev/null || true
        fi
    fi
}

_mail_inbox() {
    local feature="${1:-}"
    [[ -z "$feature" ]] && die "Usage: tw mail inbox <feature> [worker]"
    local worker="${2:-}"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    # Default worker from env
    if [[ -z "$worker" ]]; then
        worker="${TW_WORKER_NAME:-}"
    fi

    # Query unread mail
    local label_filter="tw:mail,mail:unread"
    if [[ -n "$worker" ]]; then
        label_filter="${label_filter},mail:to:${worker}"
    fi

    local mail_list
    mail_list=$(bd list -l "$label_filter" --flat --sort=created 2>/dev/null || true)

    if [[ -z "$mail_list" || "$mail_list" == *"No issues"* ]]; then
        echo "  No unread mail${worker:+ for $worker}."
        return 0
    fi

    echo ""
    echo "  INBOX${worker:+ ($worker)}"
    echo "  ─────────────────────────────────────────────────"
    echo "$mail_list"
    echo ""
}

_mail_read() {
    local bead_id="${1:-}"
    [[ -z "$bead_id" ]] && die "Usage: tw mail read <bead-id>"

    # Show the message
    bd show "$bead_id"

    # Mark as read
    bd update "$bead_id" --remove-label "mail:unread" --add-label "mail:read" \
        --set-metadata "mail_status=read" 2>/dev/null || true
    echo ""
    echo "  Marked as read."
}

_mail_ack() {
    local bead_id="${1:-}"
    [[ -z "$bead_id" ]] && die "Usage: tw mail ack <bead-id>"

    local acker="${TW_WORKER_NAME:-unknown}"
    local acked_at
    acked_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    # Close the bead and mark as acked
    bd update "$bead_id" \
        --remove-label "mail:unread" --remove-label "mail:read" \
        --add-label "mail:acked,mail:acked-by:${acker}" \
        --set-metadata "mail_status=acked" \
        --set-metadata "mail_acked_by=$acker" \
        --set-metadata "mail_acked_at=$acked_at" \
        2>/dev/null || true

    bd close "$bead_id" 2>/dev/null || true

    echo "  Mail $bead_id acknowledged and closed."
}

# ─── Nudge System ────────────────────────────────────────────────────────────

cmd_nudge() {
    local subcmd="${1:-}"
    [[ -z "$subcmd" ]] && die "Usage: tw nudge <enqueue|drain> <session_key> <worker> [message]"
    shift

    case "$subcmd" in
        enqueue)
            local session_key="${1:-}" worker="${2:-}" message="${3:-}" ttl="${4:-30}"
            [[ -z "$session_key" || -z "$worker" || -z "$message" ]] \
                && die "Usage: tw nudge enqueue <session_key> <worker> <message> [ttl_minutes]"
            nudge_enqueue "$session_key" "$worker" "$message" "$ttl"
            echo "  Queued nudge for $worker in session $session_key"
            ;;
        drain)
            local session_key="${1:-}" worker="${2:-}"
            [[ -z "$session_key" || -z "$worker" ]] \
                && die "Usage: tw nudge drain <session_key> <worker>"
            nudge_drain "$session_key" "$worker"
            ;;
        *)
            die "Unknown nudge subcommand: $subcmd. Use enqueue or drain."
            ;;
    esac
}

cmd_send() {
    local feature="" worker="" task="" urgent=0 requested_engine=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --urgent) urgent=1; shift ;;
            --engine) requested_engine="$2"; shift 2 ;;
            -*) die "Unknown option: $1" ;;
            *)
                if [[ -z "$feature" ]]; then feature="$1"
                elif [[ -z "$worker" ]]; then worker="$1"
                else task="$task $1"
                fi
                shift ;;
        esac
    done

    task="${task# }"
    [[ -z "$feature" || -z "$worker" || -z "$task" ]] \
        && die 'Usage: tw send <feature> <worker> "<task>" [--urgent] [--engine <name>]'

    # Append completion-signal footer so the orchestrator gets notified when
    # the worker finishes. Skip if the task already mentions 'tw signal' to
    # avoid duplication when callers inject their own signal instructions.
    if [[ "$task" != *"tw signal"* ]]; then
        task="${task}

---
When you finish this task, run: tw signal ${feature} ${worker} done
(This notifies the orchestrator that your work is complete.)"
    fi

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    tmux has-session -t "=$tmux_session" 2>/dev/null \
        || die "No tmux session '$tmux_session' — is the feature running?"
    tmux_window_exists "$tmux_session" "$worker" \
        || die "Worker window '$worker' not found — run: tw workers $feature"

    local ttl=30
    [[ "$urgent" -eq 1 ]] && ttl=120

    # Clear done signal — worker is being re-activated
    worker_signal_clear_all "$session_key" "$worker" 2>/dev/null || true

    # ─── Bead-backed task dispatch ───────────────────────────────────────────
    # Create a task bead so the work item persists even if the worker dies.
    # The bead is the source of truth; the nudge is just a wake-up signal.

    local hooked_file="$HOME/.tiddly-winks/hooked/${session_key}/${worker}.json"
    local worker_bead_id="" bead_id="" task_bead_id=""
    if [[ -f "$hooked_file" ]]; then
        eval "$(python3 -c "
import json, shlex
d = json.load(open('$hooked_file'))
print(f'worker_bead_id={shlex.quote(d.get(\"worker_bead_id\", \"\"))}')
print(f'bead_id={shlex.quote(d.get(\"bead_id\", \"\"))}')
" 2>/dev/null)"
    fi

    # Create task bead with full task text as description
    # Must run bd from the project workspace where the .beads store lives
    local task_title
    task_title=$(printf '%.80s' "$task")
    task_bead_id=$(cd "$config_dir" && bd create --title="$task_title" \
        --description="$task" \
        --type=task \
        --priority=2 \
        ${bead_id:+--parent="$bead_id"} \
        2>/dev/null | grep -oE '[a-z0-9-]+-[a-z0-9]+' | head -1 || true)

    if [[ -n "$task_bead_id" ]]; then
        # Store assignment metadata on the task bead
        (cd "$config_dir" && bd update "$task_bead_id" --status=in_progress \
            --set-metadata "assigned_to=$worker" \
            --set-metadata "assigned_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
            --set-metadata "session=$session_key") \
            2>/dev/null || true

        # Write task bead ID to hooked file so worker picks it up on restart
        if [[ -f "$hooked_file" ]]; then
            python3 -c "
import json, sys
f = sys.argv[1]
d = json.load(open(f))
d['current_task'] = sys.argv[2]
d['current_task_bead'] = sys.argv[3]
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
" "$hooked_file" "$task" "$task_bead_id" 2>/dev/null || true
        fi

        # Also record on worker identity bead for history
        if [[ -n "$worker_bead_id" ]]; then
            (cd "$config_dir" && bd comments add "$worker_bead_id" "[TASK $(date -u +%Y-%m-%dT%H:%MZ)] $task") 2>/dev/null || true
        fi

        # Nudge is just a wake-up referencing the bead
        nudge_enqueue "$session_key" "$worker" "$task" "$ttl"
    else
        # Fallback: bead creation failed, use old nudge-only behavior
        log "WARN: task bead creation failed for $worker, falling back to nudge-only"
        nudge_enqueue "$session_key" "$worker" "$task" "$ttl"

        if [[ -f "$hooked_file" ]]; then
            python3 -c "
import json, sys
f = sys.argv[1]
d = json.load(open(f))
d['current_task'] = sys.argv[2]
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
" "$hooked_file" "$task" 2>/dev/null || true
        fi

        if [[ -n "$worker_bead_id" ]]; then
            bd comments add "$worker_bead_id" "[TASK $(date -u +%Y-%m-%dT%H:%MZ)] $task" 2>/dev/null || true
        fi
    fi

    # ─── Engine-aware task delivery ───────────────────────────────────────────
    local _send_engine
    _send_engine=$(worker_engine "$session_key" "$worker")

    # --engine flag: switch engine if requested
    if [[ -n "$requested_engine" && "$requested_engine" != "$_send_engine" ]]; then
        _send_engine="$requested_engine"
        python3 -c "
import json, sys
f = sys.argv[1]
d = json.load(open(f))
s = d.setdefault(sys.argv[2], {})
w = s.setdefault('workers', {})
we = w.setdefault(sys.argv[3], {})
we['engine'] = sys.argv[4]
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
" "$HOME/.tiddly-winks/sessions.json" "$session_key" "$worker" "$_send_engine" 2>/dev/null || true
        if [[ -f "$hooked_file" ]]; then
            python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
d['engine'] = sys.argv[2]
with open(sys.argv[1], 'w') as fh:
    json.dump(d, fh, indent=2)
" "$hooked_file" "$_send_engine" 2>/dev/null || true
        fi
        log "Switched $worker engine to $_send_engine"
    fi

    if engine_supports_hooks "$_send_engine"; then
        # ── Hook-based engines (claude): nudge + wake via send_to_pane ──
        local target="=$tmux_session:$worker"
        if worker_is_not_logged_in "$tmux_session" "$worker" "$session_key"; then
            log "WARNING: $worker is not logged in — sending /login first"
            send_to_pane "$target" "/login"
            sleep 3
        fi

        local wake_msg="You have a new task from the orchestrator. Check your additional context and execute it now."
        if wait_for_idle "$tmux_session" "$worker" 15; then
            send_to_pane "$target" "$wake_msg"
            log "Delivered wake to $worker (idle detected)"
        else
            send_to_pane "$target" "$wake_msg"
            log "Delivered wake to $worker (busy, best-effort)"
        fi

        local urgency_label=""
        [[ "$urgent" -eq 1 ]] && urgency_label=" (urgent, 2h TTL)"
        if [[ -n "$task_bead_id" ]]; then
            echo "  Task bead created: $task_bead_id (assigned to $worker)"
        fi
        echo "  Nudge queued for $worker${urgency_label}: $task"
        echo "  Will be injected on next prompt turn via tw-mail-check hook."
    else
        # ── Non-hook engines (cursor, codex): respawn with task baked in ──
        local _state
        _state=$(worker_state "$tmux_session" "$worker" "$(agents_dir "$session_key")" "$session_key")

        if [[ "$_state" == "working" ]]; then
            log "Non-hook worker $worker is busy — task queued for respawn on completion"
            echo "  Task queued for $worker (busy, will respawn with task on completion)"
        else
            log "Respawning non-hook worker $worker with new task"

            if [[ "$_state" != "dead" ]]; then
                local _exit_cmd
                _exit_cmd=$(engine_exit_cmd "$_send_engine")
                tmux send-keys -t "=$tmux_session:$worker" "$_exit_cmd" Enter 2>/dev/null || true
                sleep 2
                if worker_is_alive "$tmux_session" "$worker" "$session_key"; then
                    tmux send-keys -t "=$tmux_session:$worker" C-c 2>/dev/null || true
                    sleep 1
                fi
            fi

            while tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "$worker"; do
                tmux kill-window -t "=$tmux_session:$worker" 2>/dev/null || break
            done

            local _wrole=""
            if [[ -f "$hooked_file" ]]; then
                _wrole=$(python3 -c "
import json
try: print(json.load(open('$hooked_file')).get('role', ''))
except: pass
" 2>/dev/null)
            fi
            local _worker_bead_id
            _worker_bead_id=$(worker_bead_find_or_create "$worker" "$project" "$config_dir" 2>/dev/null || echo "")
            local _bead_id
            _bead_id=$(sessions_get_key "$session_key" "bead_id")

            spawn_worker "$tmux_session" "$session_key" "$config_dir" \
                "$worker" "$_wrole" "$_bead_id" "$_worker_bead_id" "$_send_engine" || {
                log "FAIL: could not respawn $worker with new task"
            }

            breaker_reset "$session_key" "$worker" 2>/dev/null || true

            if [[ -n "$task_bead_id" ]]; then
                echo "  Task bead created: $task_bead_id (assigned to $worker)"
            fi
            echo "  Respawned $worker ($_send_engine) with task: $task"
        fi
    fi
}

cmd_tasks() {
    local feature="${1:-}"
    [[ -z "$feature" ]] && die "Usage: tw tasks <feature>"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    # Gather all worker bead IDs from hooked files
    local hooked_dir="$HOME/.tiddly-winks/hooked/${session_key}"
    local found=0

    echo ""
    printf "  %-15s %-22s %s\n" "WORKER" "ASSIGNED" "TASK"
    printf "  %-15s %-22s %s\n" "---------------" "----------------------" "--------------------"

    for hooked_file in "$hooked_dir"/*.json; do
        [[ -f "$hooked_file" ]] || continue
        local wname
        wname=$(basename "$hooked_file" .json)

        local worker_bead_id
        worker_bead_id=$(python3 -c "
import json
d = json.load(open('$hooked_file'))
print(d.get('worker_bead_id', ''))
" 2>/dev/null || true)
        [[ -z "$worker_bead_id" ]] && continue

        # Read all [TASK] comments from the worker bead
        local task_lines
        task_lines=$(bd comments "$worker_bead_id" 2>/dev/null \
            | grep '\[TASK ' || true)
        [[ -z "$task_lines" ]] && continue

        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            # Extract timestamp and task text from: "... [TASK 2026-03-20T01:15Z] do the thing"
            local ts task_text
            ts=$(echo "$line" | grep -o '\[TASK [^]]*\]' | sed 's/\[TASK //;s/\]//')
            task_text=$(echo "$line" | grep -o '\[TASK [^]]*\] .*' | sed 's/^\[TASK [^]]*\] //')
            # Truncate long task text for display
            if [[ ${#task_text} -gt 60 ]]; then
                task_text="${task_text:0:57}..."
            fi
            printf "  %-15s %-22s %s\n" "$wname" "$ts" "$task_text"
            (( found++ )) || true
        done <<< "$task_lines"
    done

    echo ""
    if [[ $found -eq 0 ]]; then
        echo "  No tasks recorded in worker beads."
    else
        echo "  $found task(s) found across worker beads."
    fi
}

cmd_signal() {
    local feature="" worker="" signal=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*) die "Unknown option: $1" ;;
            *)
                if [[ -z "$feature" ]]; then feature="$1"
                elif [[ -z "$worker" ]]; then worker="$1"
                elif [[ -z "$signal" ]]; then signal="$1"
                else die "Too many arguments"
                fi
                shift ;;
        esac
    done

    [[ -z "$feature" || -z "$worker" || -z "$signal" ]] \
        && die "Usage: tw signal <feature> <worker> <signal>
Supported signals: done, clear"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    case "$signal" in
        done)
            worker_signal_set "$session_key" "$worker" "done"
            # Reset crash counter on successful completion
            rm -f "$CRASH_COUNT_DIR/$session_key/$worker" 2>/dev/null || true
            echo "  ✓ $worker signaled done (crash counter reset)"
            # Notify god window so it picks up completion on next prompt turn
            if tmux_window_exists "$tmux_session" "god"; then
                nudge_enqueue "$session_key" "god" \
                    "Worker $worker signaled DONE. Task complete. Check their output file for results." 30
                send_to_pane "=$tmux_session:god" \
                    "Worker $worker has completed their task." 2>/dev/null || true
            fi
            ;;
        clear)
            worker_signal_clear_all "$session_key" "$worker"
            echo "  ✓ $worker signals cleared"
            ;;
        *)
            die "Unknown signal: $signal. Supported: done, clear"
            ;;
    esac
}

# Check if a worker is idle at the prompt (ready to receive input).
# Inspects the tmux pane's visible content for engine-specific prompt indicators.
# Returns 0 if idle, 1 if busy/unknown.
# Optional 3rd arg: session_key (for engine lookup).
worker_is_idle() {
    local tmux_session="$1" wname="$2" session_key="${3:-$tmux_session}"

    # Capture last 5 lines of the pane
    local pane_text
    pane_text=$(tmux capture-pane -t "=$tmux_session:$wname" -p -S -5 2>/dev/null) || return 1

    local engine
    engine=$(worker_engine "$session_key" "$wname")

    # Not logged in is not idle — it's a broken state
    local not_logged_in_pat
    not_logged_in_pat=$(engine_not_logged_in_pattern "$engine")
    if echo "$pane_text" | tail -3 | grep -qE "$not_logged_in_pat"; then
        return 1
    fi

    # Check if engine is busy (actively running tools)
    local busy_pat
    busy_pat=$(engine_busy_pattern "$engine")
    if echo "$pane_text" | grep -qE "$busy_pat"; then
        return 1  # busy
    fi

    # Check for idle indicators
    local idle_pat
    idle_pat=$(engine_idle_pattern "$engine")
    if echo "$pane_text" | grep -qE "$idle_pat"; then
        return 0  # idle at prompt
    fi

    return 1  # unknown state, assume busy
}

# Check if a worker's Claude session is not logged in.
# Returns 0 if not logged in, 1 otherwise.
# Checks the bottom 3 visible lines of the pane for engine-specific auth failure patterns.
# Optional 3rd arg: session_key (for engine lookup).
worker_is_not_logged_in() {
    local tmux_session="$1" wname="$2" session_key="${3:-$tmux_session}"
    local pane_text
    pane_text=$(tmux capture-pane -t "=$tmux_session:$wname" -p 2>/dev/null) || return 1
    local engine
    engine=$(worker_engine "$session_key" "$wname")
    local pattern
    pattern=$(engine_not_logged_in_pattern "$engine")
    echo "$pane_text" | tail -3 | grep -qE "$pattern"
}

# Wait for a worker to become idle, with timeout.
# Returns 0 if idle detected, 1 if timed out.
wait_for_idle() {
    local tmux_session="$1" wname="$2" timeout_secs="${3:-10}"
    local deadline=$(($(date +%s) + timeout_secs))
    local idle_count=0

    while [[ $(date +%s) -lt $deadline ]]; do
        if worker_is_idle "$tmux_session" "$wname"; then
            idle_count=$((idle_count + 1))
            # Require 2 consecutive idle polls to filter transient states
            if [[ $idle_count -ge 2 ]]; then
                return 0
            fi
            sleep 0.2
        else
            idle_count=0
            sleep 0.5
        fi
    done

    return 1  # timed out
}

# Send text to a tmux pane reliably. Handles chunking and enter key timing.
send_to_pane() {
    local target="$1" text="$2"

    # 1. Sanitize: strip C0 control chars (except newline) and normalize whitespace
    text=$(python3 -c "
import sys, re
t = sys.argv[1]
# Strip ESC sequences (ANSI), CR, BS, TAB, and other C0 controls except newline
t = re.sub(r'\x1b\[[0-9;]*[A-Za-z]', '', t)  # ANSI escape sequences
t = re.sub(r'[\x00-\x09\x0b-\x0c\x0e-\x1f\x7f]', '', t)  # C0 controls except \\n (0x0a) and \\r (0x0d)
t = t.replace('\r', '')  # strip CR
t = t.replace('\u00a0', ' ')  # non-breaking space → regular space
print(t, end='')
" "$text")

    # 2. Acquire lock to serialize sends to the same target (mkdir is atomic, works on macOS)
    local lock_dir="$HOME/.tiddly-winks/locks"
    mkdir -p "$lock_dir" 2>/dev/null
    local lock_target="${target//[:\/]/_}"
    local lock_path="${lock_dir}/${lock_target}.lock"

    # Remove stale locks (older than 10s or held by dead process)
    if [[ -d "$lock_path" ]]; then
        local _lock_age=0
        local _lock_mtime
        _lock_mtime=$(stat -f %m "$lock_path" 2>/dev/null || stat -c %Y "$lock_path" 2>/dev/null || echo 0)
        _lock_age=$(( $(date +%s) - _lock_mtime ))
        if [[ $_lock_age -gt 10 ]]; then
            rmdir "$lock_path" 2>/dev/null || rm -rf "$lock_path" 2>/dev/null
        fi
    fi

    local _lock_acquired=0
    local _lock_deadline=$(($(date +%s) + 2))

    while [[ $(date +%s) -lt $_lock_deadline ]]; do
        if mkdir "$lock_path" 2>/dev/null; then
            _lock_acquired=1
            break
        fi
        sleep 0.1
    done

    if [[ $_lock_acquired -eq 0 ]]; then
        # Force remove and try once more — lock is likely orphaned
        rmdir "$lock_path" 2>/dev/null || rm -rf "$lock_path" 2>/dev/null
        if mkdir "$lock_path" 2>/dev/null; then
            _lock_acquired=1
        else
            log "send_to_pane: lock timeout for $target"
            return 1
        fi
    fi

    # 3. Retry loop with backoff for transient tmux errors
    local chunk_size=512
    local len=${#text}
    local offset=0

    while [[ $offset -lt $len ]]; do
        local chunk="${text:$offset:$chunk_size}"
        local attempt=0 max_retries=3 backoff=0.5

        while true; do
            local err
            err=$(tmux send-keys -t "$target" -l "$chunk" 2>&1) && break

            # Permanent errors — don't retry
            if [[ "$err" == *"session not found"* || "$err" == *"window not found"* || "$err" == *"no such"* || "$err" == *"can't find"* ]]; then
                log "send_to_pane: permanent error for $target: $err"
                rmdir "$lock_path" 2>/dev/null
                return 1
            fi

            (( attempt++ ))
            if [[ $attempt -ge $max_retries ]]; then
                log "send_to_pane: failed after $max_retries retries for $target: $err"
                rmdir "$lock_path" 2>/dev/null
                return 1
            fi
            sleep "$backoff"
            backoff=$(python3 -c "print($backoff * 1.5)")
        done

        offset=$((offset + chunk_size))
        [[ $offset -lt $len ]] && sleep 0.01
    done

    # Brief pause then Enter
    sleep 0.1
    tmux send-keys -t "$target" Enter
    rmdir "$lock_path" 2>/dev/null
}

# Check if a worker window has a live engine process (not just a bare shell).
# Returns 0 if alive, 1 if dead/missing.
# Optional 3rd arg: session_key (for engine lookup). Falls back to tmux_session.
worker_is_alive() {
    local tmux_session="$1" wname="$2" session_key="${3:-$tmux_session}"
    local pane_pid
    pane_pid=$(tmux list-panes -t "=$tmux_session:$wname" -F "#{pane_pid}" 2>/dev/null | head -1)
    [[ -z "$pane_pid" ]] && return 1
    local engine
    engine=$(worker_engine "$session_key" "$wname")
    local pattern
    pattern=$(engine_process_pattern "$engine")
    pgrep -P "$pane_pid" -f "$pattern" >/dev/null 2>&1
}

# Determine worker state: working, idle, stalled, done, or dead.
# Prints state to stdout. Uses process, prompt, signals, and output file freshness.
# Usage: worker_state <tmux_session> <wname> <agents_path> [session_key]
worker_state() {
    local tmux_session="$1" wname="$2" agents_path="${3:-}" session_key="${4:-$tmux_session}"

    # 1. Check if window exists (allow spinner suffix like "test ⠼")
    if ! tmux_window_exists "$tmux_session" "$wname"; then
        echo "dead"; return
    fi

    # 2. Check if engine process is alive
    if ! worker_is_alive "$tmux_session" "$wname" "$session_key"; then
        echo "dead"; return
    fi

    # 2.5. Check if worker is not logged in
    if worker_is_not_logged_in "$tmux_session" "$wname" "$session_key"; then
        echo "not-logged-in"; return
    fi

    # 3. Check for "done" signal (self-managed completion)
    if worker_signal_check "$session_key" "$wname" "done"; then
        echo "done"; return
    fi

    # 4. Check output file freshness for stall detection
    local stalled=0
    if [[ -n "$agents_path" ]]; then
        local output_file="$agents_path/${wname}.md"
        if [[ -f "$output_file" ]]; then
            local now mtime age_secs
            now=$(date +%s)
            mtime=$(stat -f %m "$output_file" 2>/dev/null || stat -c %Y "$output_file" 2>/dev/null || echo 0)
            age_secs=$((now - mtime))
            [[ $age_secs -gt 3600 ]] && stalled=1
        fi
    fi

    # 5. Check if idle at prompt
    if worker_is_idle "$tmux_session" "$wname" "$session_key"; then
        echo "idle"; return
    fi

    # 6. Alive and busy — working or stalled
    if [[ $stalled -eq 1 ]]; then
        echo "stalled"; return
    fi

    echo "working"
}

cmd_handoff() {
    local feature="" worker=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*) die "Unknown option: $1" ;;
            *)
                if [[ -z "$feature" ]]; then feature="$1"
                elif [[ -z "$worker" ]]; then worker="$1"
                else die "Too many arguments"
                fi
                shift ;;
        esac
    done

    [[ -z "$feature" || -z "$worker" ]] && die "Usage: tw handoff <feature> <worker>"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    tmux has-session -t "=$tmux_session" 2>/dev/null \
        || die "No tmux session '$tmux_session'"

    # Verify worker window exists
    tmux_window_exists "$tmux_session" "$worker" \
        || die "Worker window '$worker' not found in session '$tmux_session'"

    # 1. Save worker's output file to their identity bead
    local output_file
    output_file="$(agents_dir "$session_key")/${worker}.md"

    local worker_bead_id
    worker_bead_id=$(worker_bead_find "$worker" "$project" "$config_dir")

    if [[ -n "$worker_bead_id" && -f "$output_file" ]]; then
        local output_content
        output_content=$(cat "$output_file" | scrub_secrets)
        if [[ -n "$output_content" ]]; then
            local timestamp
            timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
            bd_run "$config_dir" comments add "$worker_bead_id" "## Session handoff — $timestamp

$output_content" 2>/dev/null || log "Warning: could not append to worker bead $worker_bead_id"
            # Clear output file for fresh session
            > "$output_file"
            log "Saved output to worker bead $worker_bead_id"
        fi
    fi

    # Resolve engine for this worker
    local engine
    engine=$(worker_engine "$session_key" "$worker")

    # 2. Kill the engine process in the worker window
    local _exit_cmd
    _exit_cmd=$(engine_exit_cmd "$engine")
    tmux send-keys -t "=$tmux_session:$worker" "$_exit_cmd" Enter
    sleep 2

    # 3. If engine is still running, force-kill
    if worker_is_alive "$tmux_session" "$worker" "$session_key"; then
        tmux send-keys -t "=$tmux_session:$worker" C-c
        sleep 1
    fi

    # 4. Resolve role from hooked JSON or config
    local wrole=""
    local hooked_file="$HOME/.tiddly-winks/hooked/${session_key}/${worker}.json"
    if [[ -f "$hooked_file" ]]; then
        wrole=$(python3 -c "
import json
try: print(json.load(open('$hooked_file')).get('role', ''))
except: pass
" 2>/dev/null)
    fi

    # 5. Respawn engine in the same window
    local bead_id
    bead_id=$(sessions_get_key "$session_key" "bead_id")
    [[ -z "$worker_bead_id" ]] && worker_bead_id=$(worker_bead_find_or_create "$worker" "$project" "$config_dir")

    # Write updated hooked JSON
    local hooked_dir="$HOME/.tiddly-winks/hooked/${session_key}"
    mkdir -p "$hooked_dir"
    local _feature
    _feature=$(sessions_get_key "$session_key" "feature" 2>/dev/null || echo "${session_key#*-}")
    python3 -c "
import json, sys
with open(sys.argv[1], 'w') as f:
    json.dump({
        'bead_id': sys.argv[2],
        'worker': sys.argv[3],
        'role': sys.argv[4],
        'output_file': sys.argv[5],
        'worker_bead_id': sys.argv[6],
        'engine': sys.argv[7],
        'feature': sys.argv[8]
    }, f, indent=2)
" "${hooked_dir}/${worker}.json" "$bead_id" "$worker" "$wrole" "$output_file" "$worker_bead_id" "$engine" "$_feature"

    local _prompt_file=""
    if ! engine_supports_hooks "$engine"; then
        _prompt_file=$(engine_context_preamble "$session_key" "$worker" "$engine" 2>/dev/null || true)
    fi
    local _engine_cmd
    _engine_cmd=$(engine_spawn_cmd "$engine" "$worker" "$_prompt_file")
    tmux send-keys -t "=$tmux_session:$worker" \
        "cd '$config_dir' && TW_SESSION='$session_key' TW_WORKER='$worker' TW_ROLE='$wrole' $_engine_cmd" Enter

    # Voluntary handoff = healthy worker — reset circuit breaker
    breaker_reset "$session_key" "$worker"

    # Record handoff in worker CV
    local _cv_feature="${session_key#*-}"
    local _cv_summary=""
    if [[ -n "${output_content:-}" ]]; then
        # Extract first meaningful line as summary
        _cv_summary=$(echo "$output_content" | grep -v '^$' | grep -v '^#' | head -1 | cut -c1-80)
    fi
    [[ -z "$_cv_summary" ]] && _cv_summary="session handoff"
    cv_record_handoff "$project" "$worker" "$_cv_feature" "$_cv_summary" 2>/dev/null || true

    log "Handed off $worker — fresh session starting with identity bead $worker_bead_id"
    echo "  Handoff complete: $worker"
    echo "  Identity bead: $worker_bead_id (work history preserved)"
}

# ─── Sync Worker Outputs to Beads ────────────────────────────────────────────
sync_worker_output_to_bead() {
    local session_key="$1" wname="$2" agents_path="$3" project="$4" config_dir="$5" force="${6:-0}"
    local output_file="$agents_path/${wname}.md"
    [[ -f "$output_file" ]] || return 0
    local sync_dir="$HOME/.tiddly-winks/sync-offsets/${session_key}"
    mkdir -p "$sync_dir"
    local offset_file="$sync_dir/${wname}.last-sync-offset"
    local prev_offset=0
    [[ -f "$offset_file" ]] && prev_offset=$(cat "$offset_file" 2>/dev/null || echo 0)
    local current_size
    current_size=$(stat -f %z "$output_file" 2>/dev/null || stat -c %s "$output_file" 2>/dev/null || echo 0)
    # Nothing new to sync
    if [[ "$current_size" -le "$prev_offset" ]]; then
        return 0
    fi
    # Extract new content (bytes from prev_offset+1 onward)
    local new_content
    new_content=$(tail -c "+$((prev_offset + 1))" "$output_file")
    [[ -z "$new_content" ]] && return 0
    # Find worker bead ID
    local worker_bead_id
    worker_bead_id=$(worker_bead_find "$wname" "$project" "$config_dir" 2>/dev/null)
    if [[ -z "$worker_bead_id" ]]; then
        local hooked_file="$HOME/.tiddly-winks/hooked/${session_key}/${wname}.json"
        if [[ -f "$hooked_file" ]]; then
            worker_bead_id=$(python3 -c "
import json
try: print(json.load(open('$hooked_file')).get('worker_bead_id', ''))
except: pass
" 2>/dev/null)
        fi
    fi
    [[ -z "$worker_bead_id" ]] && return 0
    # Write new content to temp file and append as bead comment
    local tmpfile
    tmpfile=$(mktemp)
    echo "$new_content" > "$tmpfile"
    if bd_run "$config_dir" comments add "$worker_bead_id" -f "$tmpfile" >/dev/null 2>&1; then
        echo "$current_size" > "$offset_file"
        rm -f "$tmpfile"
        echo "$wname"
        return 0
    fi
    rm -f "$tmpfile"
    return 1
}

cmd_patrol() {
    local feature=""
    local sync_outputs=0
    local reset_orphans=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --sync-outputs) sync_outputs=1; shift ;;
            --reset-orphans) reset_orphans=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *) feature="$1"; shift ;;
        esac
    done

    [[ -z "$feature" ]] && die "Usage: tw patrol <feature> [--sync-outputs] [--reset-orphans]"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    tmux has-session -t "=$tmux_session" 2>/dev/null \
        || die "No tmux session '$tmux_session'"

    # Reconcile worker state before health checks
    reconcile_workers "$session_key" "$config_dir"

    local config_file="$config_dir/.tw.yml"
    [[ ! -f "$config_file" ]] && config_file="$config_dir/.devenv.yml"
    local override_file="$config_dir/.tw.override.yml"
    [[ ! -f "$override_file" && -f "$config_dir/.devenv.override.yml" ]] && override_file="$config_dir/.devenv.override.yml"
    local effective_config="$config_file"
    if [[ -f "$override_file" ]]; then
        effective_config=$(yaml_merge_override "$config_file" "$override_file")
    fi

    local worker_pairs
    mapfile -t worker_pairs < <(yaml_worker_pairs "$effective_config")
    # Merge dynamic workers from session state
    local dyn_pairs
    mapfile -t dyn_pairs < <(sessions_get_dynamic_workers "$session_key")
    worker_pairs+=("${dyn_pairs[@]}")

    local agents_path
    agents_path="$(agents_dir "$session_key")"
    local now
    now=$(date +%s)
    local report="" issues=0

    echo ""
    echo "  ┌─────────────────────────────────────────────────────────┐"
    echo "  │  Patrol Report: $feature"
    echo "  │  $(date '+%Y-%m-%d %H:%M:%S')"
    echo "  └─────────────────────────────────────────────────────────┘"
    echo ""

    # 1. Worker state assessment
    printf "  %-20s %-12s %-10s %s\n" "WORKER" "STATE" "CONTEXT" "OUTPUT AGE"
    printf "  %-20s %-12s %-10s %s\n" "--------------------" "------------" "----------" "----------"

    local dead_workers="" stalled_workers="" done_workers=""

    for wpair in "${worker_pairs[@]}"; do
        [[ -z "$wpair" ]] && continue
        local wname="${wpair%%:*}"
        local _wpr="${wpair#*:}"; local wrole="${_wpr%%:*}"
        local state output_age="-"

        state=$(worker_state "$tmux_session" "$wname" "$agents_path" "$session_key")

        case "$state" in
            dead)    dead_workers+="$wname "; (( issues++ )) || true ;;
            stalled) stalled_workers+="$wname "; (( issues++ )) || true ;;
            done)    done_workers+="$wname " ;;
        esac

        # Output file age for display
        local output_file="$agents_path/${wname}.md"
        if [[ -f "$output_file" ]]; then
            local mtime
            mtime=$(stat -f %m "$output_file" 2>/dev/null || stat -c %Y "$output_file" 2>/dev/null || echo 0)
            local age_secs=$((now - mtime))
            if [[ $age_secs -lt 60 ]]; then
                output_age="${age_secs}s"
            elif [[ $age_secs -lt 3600 ]]; then
                output_age="$((age_secs / 60))m"
            else
                output_age="$((age_secs / 3600))h"
            fi
        else
            output_age="none"
        fi

        printf "  %-20s %-12s %-10s %s\n" "$wname" "$state" "${wrole:--}" "$output_age"
    done

    echo ""

    # 2. Service health
    local services_json
    services_json=$(python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
s = d.get('$session_key', {}).get('services', {})
for name, info in s.items():
    print(f'{name}:{info[\"port\"]}')
" 2>/dev/null || true)

    if [[ -n "$services_json" ]]; then
        printf "  %-20s %-10s %s\n" "SERVICE" "PORT" "STATUS"
        printf "  %-20s %-10s %s\n" "--------------------" "----------" "----------"

        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local svc_name="${line%%:*}" svc_port="${line##*:}"
            local svc_status="down"
            if lsof -i ":$svc_port" 2>/dev/null | grep -q LISTEN; then
                svc_status="up"
            else
                (( issues++ )) || true
            fi
            printf "  %-20s %-10s %s\n" "$svc_name" "$svc_port" "$svc_status"
        done <<< "$services_json"

        echo ""
    fi

    # 3. Take action on dead/stuck workers (with circuit breaker)
    if [[ -n "$dead_workers" ]] && [[ -f "$TW_DIR/spawn-locks/${session_key}" ]]; then
        echo "  [⏳] Spawn in progress — skipping respawn for: $dead_workers"
        dead_workers=""
    fi
    if [[ -n "$dead_workers" ]]; then
        echo "  [!] Dead/missing workers: $dead_workers"
        local bead_id
        bead_id=$(sessions_get_key "$session_key" "bead_id")
        for w in $dead_workers; do
            # Skip respawning dynamic workers that signaled done — they finished
            # their task and exited intentionally, not crashed
            if worker_signal_check "$session_key" "$w" "done" 2>/dev/null; then
                local is_dyn=0
                for dp in "${dyn_pairs[@]}"; do
                    [[ "${dp%%:*}" == "$w" ]] && is_dyn=1 && break
                done
                if [[ $is_dyn -eq 1 ]]; then
                    # Clean up the finished one-off worker
                    sessions_remove_dynamic_worker "$session_key" "$w"
                    rm -f "$HOME/.tiddly-winks/hooked/${session_key}/${w}.json"
                    # Kill ALL windows matching this name (tmux allows duplicates)
                    while tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "$w"; do
                        tmux kill-window -t "=$tmux_session:$w" 2>/dev/null || break
                    done
                    worker_signal_clear_all "$session_key" "$w" 2>/dev/null || true
                    echo "      Reaped: $w (one-off worker, finished and exited)"
                    continue
                fi
            fi

            # Kill ALL dead windows matching this name before respawning
            while tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "$w"; do
                tmux kill-window -t "=$tmux_session:$w" 2>/dev/null || break
            done

            if breaker_check_and_record "$session_key" "$w"; then
                # Breaker OK — respawn this worker
                echo "      Respawning: $w"
                local wrole="" wengine=""
                for wp in "${worker_pairs[@]}"; do
                    if [[ "${wp%%:*}" == "$w" ]]; then
                        local _wpr="${wp#*:}"; wrole="${_wpr%%:*}"; wengine="${wp##*:}"
                        break
                    fi
                done
                wengine=$(resolve_engine "$wengine" "$config_file")
                # wrole may be empty for generic workers — that's fine
                local worker_bead_id
                worker_bead_id=$(worker_bead_find_or_create "$w" "$project" "$config_dir" 2>/dev/null || echo "")
                spawn_worker "$tmux_session" "$session_key" "$config_dir" "$w" "$wrole" "$bead_id" "$worker_bead_id" "$wengine" 2>/dev/null \
                    && { echo "      ✓ $w respawned"; cv_record_respawn "$project" "$w" "$feature" 2>/dev/null || true; } \
                    || echo "      ✗ $w respawn failed"
            else
                # Breaker tripped
                echo "      ⚡ $w circuit breaker tripped (${BREAKER_MAX_FAILURES}+ failures in ${BREAKER_WINDOW_SECS}s)"
                echo "        Manual override: tw workers $feature --respawn --force"
                breaker_notify_god "$tmux_session" "$w" "$BREAKER_MAX_FAILURES"
            fi
        done
        echo ""
    fi

    if [[ -n "$stalled_workers" ]]; then
        echo "  [!] Stalled workers (>1h no output): $stalled_workers"
        for w in $stalled_workers; do
            nudge_enqueue "$session_key" "$w" "Health check from patrol — your output file hasn't been updated in over 1 hour. Are you stuck? Please report your current status." 30
            echo "      Nudged: $w"
        done
        echo ""
    fi

    if [[ -n "$done_workers" ]]; then
        echo "  [✓] Done workers (signaled completion): $done_workers"
        for w in $done_workers; do
            # Check if this is a dynamic (one-off) worker
            local is_dynamic=0
            for dp in "${dyn_pairs[@]}"; do
                [[ "${dp%%:*}" == "$w" ]] && is_dynamic=1 && break
            done

            if [[ $is_dynamic -eq 1 ]]; then
                # Reap: kill tmux window, remove from dynamic_workers, clean up
                tmux kill-window -t "=$tmux_session:$w" 2>/dev/null || true
                sessions_remove_dynamic_worker "$session_key" "$w"
                rm -f "$HOME/.tiddly-winks/hooked/${session_key}/${w}.json"
                worker_signal_clear_all "$session_key" "$w" 2>/dev/null || true
                echo "      Reaped: $w (one-off worker, task complete)"
            else
                echo "      Available for reuse: $w"
                echo "      Wake with: tw send $feature $w \"<new task>\""
            fi
        done
        echo ""
    fi

    # 3b. Output progress tracking — report workers with new output since last patrol
    local patrol_state_dir="$HOME/.tiddly-winks/patrol-state/${session_key}"
    mkdir -p "$patrol_state_dir"
    local new_output_workers=""
    for wpair in "${worker_pairs[@]}"; do
        [[ -z "$wpair" ]] && continue
        local wname="${wpair%%:*}"
        local output_file="$agents_path/${wname}.md"
        local mtime_file="$patrol_state_dir/${wname}.mtime"

        [[ -f "$output_file" ]] || continue
        local current_mtime
        current_mtime=$(stat -f %m "$output_file" 2>/dev/null || stat -c %Y "$output_file" 2>/dev/null || echo 0)
        local prev_mtime=0
        [[ -f "$mtime_file" ]] && prev_mtime=$(cat "$mtime_file" 2>/dev/null || echo 0)

        if [[ "$current_mtime" -gt "$prev_mtime" ]]; then
            new_output_workers+="$wname "
        fi
        echo "$current_mtime" > "$mtime_file"
    done

    if [[ -n "$new_output_workers" ]]; then
        echo "  [+] New output since last patrol: $new_output_workers"
        echo "      View with: tw feed $feature --problems"
        echo ""
    fi

    # 3c. Sync worker outputs to beads (incremental)
    if [[ $sync_outputs -eq 1 || -n "$new_output_workers" ]]; then
        local synced_workers=""
        for wpair in "${worker_pairs[@]}"; do
            [[ -z "$wpair" ]] && continue
            local wname="${wpair%%:*}"
            # Only sync workers with new output (or all if --sync-outputs forced)
            if [[ $sync_outputs -eq 1 ]] || echo "$new_output_workers" | grep -qw "$wname"; then
                local synced
                synced=$(sync_worker_output_to_bead "$session_key" "$wname" "$agents_path" "$project" "$config_dir" "$sync_outputs" 2>/dev/null) || true
                [[ -n "$synced" ]] && synced_workers+="$synced "
            fi
        done
        if [[ -n "$synced_workers" ]]; then
            echo "  [↑] Synced outputs to beads: $synced_workers"
            echo ""
        fi
    fi

    # 3d. Orphaned task beads (in_progress but assigned to dead/missing workers)
    local orphans
    orphans=$(orphaned_beads_scan "$session_key" "$config_dir" 2>/dev/null || true)
    if [[ -n "$orphans" ]]; then
        local orphan_count
        orphan_count=$(printf '%s\n' "$orphans" | grep -c . || true)
        (( issues += orphan_count )) || true
        if [[ $reset_orphans -eq 1 ]]; then
            echo "  [!] Orphaned task beads: $orphan_count — resetting to open"
            orphaned_beads_reset "$session_key" "$config_dir" | grep -v 'total reset:' || true
            echo ""
        else
            echo "  [!] Orphaned task beads: $orphan_count (in_progress, worker gone)"
            while IFS=$'\t' read -r _oid _ow _orsn; do
                [[ -z "$_oid" ]] && continue
                printf '      %s → %s (%s)\n' "$_oid" "$_ow" "$_orsn"
            done <<< "$orphans"
            echo "      Reset with: tw patrol $feature --reset-orphans"
            echo ""
        fi
    fi

    # 4. Plugin dispatch
    local plugins_dir="$HOME/.tiddly-winks/plugins"
    local cooldown_dir="$HOME/.tiddly-winks/cooldowns/${session_key}"
    mkdir -p "$cooldown_dir"

    if [[ -d "$plugins_dir" ]]; then
        local plugins_dispatched=0 plugins_skipped=0

        for plugin_file in "$plugins_dir"/*.md; do
            [[ -f "$plugin_file" ]] || continue

            # Parse TOML frontmatter (between +++ lines)
            local plugin_name="" plugin_worker="" plugin_cooldown="" plugin_body=""
            local _plugin_parsed
            _plugin_parsed=$(python3 -c "
import re, sys, json
text = open(sys.argv[1]).read()
m = re.match(r'\+\+\+\n(.*?)\n\+\+\+\n(.*)', text, re.DOTALL)
if not m: sys.exit(0)
fm, body = m.groups()
d = {}
for line in fm.strip().splitlines():
    k, _, v = line.partition('=')
    d[k.strip()] = v.strip().strip('\"')
d['body'] = body.strip()
json.dump(d, sys.stdout)
" "$plugin_file" 2>/dev/null)
            [[ -z "$_plugin_parsed" ]] && continue
            plugin_name=$(echo "$_plugin_parsed" | python3 -c "import json,sys; print(json.load(sys.stdin).get('name',''))")
            plugin_worker=$(echo "$_plugin_parsed" | python3 -c "import json,sys; print(json.load(sys.stdin).get('worker',''))")
            plugin_cooldown=$(echo "$_plugin_parsed" | python3 -c "import json,sys; print(json.load(sys.stdin).get('cooldown',''))")
            plugin_body=$(echo "$_plugin_parsed" | python3 -c "import json,sys; print(json.load(sys.stdin).get('body',''))")

            [[ -z "${plugin_name:-}" || -z "${plugin_worker:-}" ]] && continue

            # Check if target worker exists in this session
            local worker_exists=0
            for wpair in "${worker_pairs[@]}"; do
                [[ "${wpair%%:*}" == "$plugin_worker" ]] && worker_exists=1 && break
            done
            if [[ $worker_exists -eq 0 ]]; then
                (( plugins_skipped++ )) || true
                continue
            fi

            # Check cooldown
            local cooldown_file="$cooldown_dir/${plugin_name}.last"
            local cooldown_secs=0
            if [[ -n "${plugin_cooldown:-}" ]]; then
                # Parse "5m", "1h", "30m" etc.
                local cd_val="${plugin_cooldown%[mhMH]}"
                local cd_unit="${plugin_cooldown: -1}"
                case "$cd_unit" in
                    h|H) cooldown_secs=$((cd_val * 3600)) ;;
                    *) cooldown_secs=$((cd_val * 60)) ;;
                esac
            fi

            if [[ -f "$cooldown_file" ]]; then
                local last_run
                last_run=$(cat "$cooldown_file")
                local elapsed=$((now - last_run))
                if [[ $elapsed -lt $cooldown_secs ]]; then
                    (( plugins_skipped++ )) || true
                    continue
                fi
            fi

            # Dispatch: nudge the target worker with plugin instructions
            nudge_enqueue "$session_key" "$plugin_worker" \
                "## Plugin: ${plugin_name}

${plugin_body}" 60
            echo "$now" > "$cooldown_file"
            echo "  [plugin] ${plugin_name} → ${plugin_worker}"
            (( plugins_dispatched++ )) || true
        done

        if [[ $plugins_dispatched -gt 0 || $plugins_skipped -gt 0 ]]; then
            echo "  Plugins: $plugins_dispatched dispatched, $plugins_skipped skipped (cooldown/no worker)"
            echo ""
        fi
    fi

    # 5. Summary
    if [[ $issues -eq 0 ]]; then
        echo "  All clear — $((${#worker_pairs[@]})) workers healthy."
    else
        echo "  Issues found: $issues"
    fi
    echo ""
}

# ─── Feed: tail all worker output files ──────────────────────────────────────
#
# Like 'gt feed' — tails all agents/*.md files for a feature, showing new
# output as it appears. God can run this to monitor worker progress in real time.

cmd_feed() {
    local feature="" problems_flag=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --problems) problems_flag=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *) feature="$1"; shift ;;
        esac
    done

    [[ -z "$feature" ]] && die "Usage: tw feed <feature> [--problems]"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    local agents_path
    agents_path="$(agents_dir "$session_key")"

    if [[ ! -d "$agents_path" ]]; then
        die "No agents directory for session '$session_key'"
    fi

    if [[ $problems_flag -eq 1 ]]; then
        # One-shot: show workers with stale output (>30min) or no output
        local now
        now=$(date +%s)
        echo ""
        printf "  %-20s %-12s %s\n" "WORKER" "LAST OUTPUT" "STATUS"
        printf "  %-20s %-12s %s\n" "--------------------" "------------" "----------"
        for f in "$agents_path"/*.md; do
            [[ -f "$f" ]] || continue
            local wname
            wname=$(basename "$f" .md)
            local mtime age_secs age_str status
            mtime=$(stat -f %m "$f" 2>/dev/null || stat -c %Y "$f" 2>/dev/null || echo 0)
            age_secs=$((now - mtime))
            if [[ $age_secs -lt 60 ]]; then
                age_str="${age_secs}s ago"
                status="active"
            elif [[ $age_secs -lt 3600 ]]; then
                age_str="$((age_secs / 60))m ago"
                if [[ $age_secs -gt 1800 ]]; then
                    status="stale"
                else
                    status="ok"
                fi
            else
                age_str="$((age_secs / 3600))h ago"
                status="stale"
            fi
            # Check file size
            local fsize
            fsize=$(wc -c < "$f" | tr -d ' ')
            if [[ "$fsize" -eq 0 ]]; then
                status="empty"
                age_str="never"
            fi
            printf "  %-20s %-12s %s\n" "$wname" "$age_str" "$status"
        done
        echo ""
        return 0
    fi

    # Stream mode: tail -f all output files
    echo "  Tailing worker output for: $session_key"
    echo "  Directory: $agents_path"
    echo "  Press Ctrl-C to stop"
    echo ""

    # Use tail -f on all .md files, prefixing each line with the worker name
    # fswatch would be nicer but tail -F works everywhere
    tail -F "$agents_path"/*.md 2>/dev/null | while IFS= read -r line; do
        echo "$line"
    done
}

cmd_spawn() {
    local feature="" name="" role="" spawn_engine=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --engine) spawn_engine="$2"; shift 2 ;;
            -*) die "Unknown option: $1" ;;
            *)
                if [[ -z "$feature" ]]; then feature="$1"
                elif [[ -z "$name" ]]; then name="$1"
                elif [[ -z "$role" ]]; then role="$1"
                else die "Too many arguments"
                fi
                shift ;;
        esac
    done

    [[ -z "$feature" || -z "$name" ]] \
        && die "Usage: tw spawn <feature> <name> [<role>] [--engine <name>]"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    # Validate session is running
    tmux has-session -t "=$tmux_session" 2>/dev/null \
        || die "No tmux session '$tmux_session' — is the feature running? Try: tw start $feature"

    # Check no existing window with that name
    if tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "$name"; then
        die "Worker window '$name' already exists in session '$tmux_session'"
    fi

    # Validate role file exists (if role provided)
    if [[ -n "$role" ]]; then
        local role_file="$HOME/.claude/roles/${role}.md"
        [[ -f "$role_file" ]] || die "Role file not found: $role_file"
    fi

    # Get bead_id from session state
    local bead_id
    bead_id=$(sessions_get_key "$session_key" "bead_id")

    # Create worker identity bead
    mkdir -p "$(agents_dir "$session_key")"
    local worker_bead_id
    worker_bead_id=$(worker_bead_find_or_create "$name" "$project" "$config_dir")

    # Resolve engine: --engine flag > .tw.yml > 'claude'
    local config_file="$config_dir/.tw.yml"
    local engine
    engine=$(resolve_engine "$spawn_engine" "$config_file")

    # Spawn the worker
    spawn_worker "$tmux_session" "$session_key" "$config_dir" "$name" "$role" "$bead_id" "$worker_bead_id" "$engine"

    # Persist to session state
    sessions_add_dynamic_worker "$session_key" "$name" "$role"

    # Sync metadata to bead
    bead_sync_metadata "$session_key" "$bead_id" "$config_dir"

    # Persist engine to sessions.json workers entry (non-default only)
    if [[ "$engine" != "claude" ]]; then
        python3 -c "
import json, sys
f = sys.argv[1]
d = json.load(open(f))
s = d.setdefault(sys.argv[2], {})
w = s.setdefault('workers', {})
we = w.setdefault(sys.argv[3], {})
we['engine'] = sys.argv[4]
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
" "$HOME/.tiddly-winks/sessions.json" "$session_key" "$name" "$engine" 2>/dev/null || true
    fi

    echo ""
    local _engine_label=""
    [[ "$engine" != "claude" ]] && _engine_label=" [engine: $engine]"
    if [[ -n "$role" ]]; then
        echo "  Spawned worker: $name (initial context: $role)${_engine_label}"
    else
        echo "  Spawned worker: $name${_engine_label}"
    fi
    echo "  Send work:  tw send $feature $name \"<task>\""
    echo "  Health:     tw workers $feature --health"
    echo ""
}

# ── tw review ─────────────────────────────────────────────────────────
# Manages per-workspace PR review profiles and dispatches multi-perspective reviews.
#   tw review init [--force]          Generate reviewer profiles for this workspace
#   tw review <feature> <pr-number>   Spawn reviewers and dispatch PR review tasks

cmd_review() {
    [[ $# -eq 0 ]] && die "Usage: tw review init [--force] | tw review <feature> <pr-number>"

    if [[ "$1" == "init" ]]; then
        shift
        _review_init "$@"
    else
        _review_dispatch "$@"
    fi
}

# ── tw review init ────────────────────────────────────────────────────
_review_init() {
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=1; shift ;;
            -*) die "Unknown option: $1" ;;
            *) shift ;;
        esac
    done

    local config_dir="$PWD"
    local config_file
    config_file=$(find_config 2>/dev/null) || die "No .tw.yml found — run 'tw init' first"
    config_dir=$(dirname "$config_file")

    local project
    project=$(yaml_get "$config_file" "project" "") || true
    [[ -z "$project" ]] && die ".tw.yml missing 'project' key"

    local reviews_dir="$config_dir/.tw/reviews"
    if [[ -d "$reviews_dir" ]] && [[ $force -eq 0 ]]; then
        local existing
        existing=$(ls "$reviews_dir"/*.md 2>/dev/null | wc -l | tr -d ' ')
        if [[ "$existing" -gt 0 ]]; then
            die "Review profiles already exist ($existing files in .tw/reviews/). Use --force to regenerate."
        fi
    fi

    # ─── Fast local prescan ─────────────────────────────────────────
    log "Scanning workspace for review profile generation..."

    local prescan=""

    # Include .tw.yml for context
    prescan+="## .tw.yml
$(cat "$config_file")

"

    # Directory listing
    prescan+="## Top-level directory listing
$(ls -1a "$config_dir" | head -50)

"

    # Detect sub-repos
    local subrepos=""
    for d in "$config_dir"/*/; do
        [[ -d "$d" ]] || continue
        local dname
        dname=$(basename "$d")
        if [[ -f "$d/package.json" || -f "$d/pyproject.toml" || -f "$d/Pipfile" || -f "$d/Cargo.toml" || -f "$d/go.mod" ]]; then
            subrepos+="- $dname"
            [[ -f "$d/package.json" ]] && subrepos+=" (package.json)"
            [[ -f "$d/pyproject.toml" ]] && subrepos+=" (pyproject.toml)"
            [[ -f "$d/Pipfile" ]] && subrepos+=" (Pipfile)"
            [[ -f "$d/Cargo.toml" ]] && subrepos+=" (Cargo.toml)"
            [[ -f "$d/go.mod" ]] && subrepos+=" (go.mod)"
            subrepos+=$'\n'
        fi
    done
    [[ -n "$subrepos" ]] && prescan+="## Sub-repos / service directories
$subrepos
"

    # Key config files
    for f in package.json pyproject.toml Pipfile docker-compose.yml docker-compose.yaml \
             Makefile Cargo.toml go.mod; do
        if [[ -f "$config_dir/$f" ]]; then
            prescan+="## $f (first 30 lines)
$(head -30 "$config_dir/$f")
...

"
        fi
    done

    # Sub-repo package files
    if [[ -n "$subrepos" ]]; then
        for d in "$config_dir"/*/; do
            local dname
            dname=$(basename "$d")
            for pf in package.json pyproject.toml Pipfile; do
                if [[ -f "$d/$pf" ]]; then
                    prescan+="## $dname/$pf (first 25 lines)
$(head -25 "$d/$pf")
...

"
                fi
            done
        done
    fi

    # Framework configs
    for pattern in vite.config.* next.config.* nuxt.config.* svelte.config.* tailwind.config.* tsconfig.json; do
        for f in "$config_dir"/$pattern "$config_dir"/*/$pattern; do
            [[ -f "$f" ]] || continue
            local relpath="${f#$config_dir/}"
            prescan+="## $relpath (first 15 lines)
$(head -15 "$f")
...

"
        done
    done

    # Sample source files for patterns (up to 3 per detected language)
    local sample_count=0
    for ext in ts tsx js jsx py go rs; do
        local files_found
        files_found=$(find "$config_dir" -maxdepth 4 -name "*.${ext}" \
            -not -path "*/node_modules/*" -not -path "*/.git/*" \
            -not -path "*/dist/*" -not -path "*/__pycache__/*" \
            -not -path "*/worktrees/*" \
            2>/dev/null | head -3 || true)
        while IFS= read -r sf; do
            [[ -z "$sf" ]] && continue
            local relpath="${sf#$config_dir/}"
            prescan+="## Sample: $relpath (first 40 lines)
$(head -40 "$sf")
...

"
            ((sample_count++)) || true
        done <<< "$files_found"
    done

    # Database/ORM detection
    local db_hints=""
    for pattern in "prisma/schema.prisma" "*/prisma/schema.prisma" \
                   "drizzle.config.*" "*/drizzle.config.*" \
                   "alembic.ini" "*/alembic.ini" \
                   "migrations/" "*/migrations/"; do
        for f in $config_dir/$pattern; do
            [[ -e "$f" ]] || continue
            local relpath="${f#$config_dir/}"
            db_hints+="- $relpath"$'\n'
            if [[ -f "$f" ]]; then
                prescan+="## $relpath (first 20 lines)
$(head -20 "$f")
...

"
            fi
        done
    done
    [[ -n "$db_hints" ]] && prescan+="## Database/ORM artifacts detected
$db_hints
"

    log "Generating reviewer profiles with Claude..."

    local prompt
    prompt=$(cat <<'PROMPT_HEREDOC'
You are analyzing a codebase to generate specialized PR reviewer profiles for tiddly-winks, a feature space manager.

## Pre-scan results

PRESCAN_PLACEHOLDER

## Your task

Based on the codebase analysis above, generate a set of specialized PR reviewer profiles. Each reviewer should have a **meaningfully distinct lens** — tailored to THIS project's actual stack, frameworks, patterns, and conventions.

Generate as many reviewers as the codebase warrants. Don't artificially limit yourself, but don't create redundant ones either. Consider reviewers for areas like:
- Backend/API patterns (if there's a backend)
- Data modeling/schema/migrations (if there's a DB layer)
- Logic & correctness (edge cases, race conditions — always relevant)
- Frontend patterns & UX (if there's a frontend)
- Security (if there are auth flows, user input, etc.)
- Performance (if there are hot paths, large data processing, etc.)
- Testing gaps (if there's a test framework)
- i18n/l10n (if there's internationalization)
- Accessibility (if there's a user-facing frontend)
- Type safety (if TypeScript/typed language)
- Infrastructure/DevOps (if there's IaC, Docker, CI config)
- Any other area specific to this project's domain

Each profile should reference the ACTUAL frameworks, libraries, file patterns, and conventions found in the prescan — not generic advice.

## Output format

Output a single JSON object (no markdown fences, no prose before or after). Start with `{` and end with `}`.

```
{
  "reviewers": [
    {
      "name": "short-slug",
      "title": "Human-readable title",
      "content": "Full markdown content of the reviewer profile"
    }
  ]
}
```

Each reviewer's `content` should follow this template (fill in project-specific details):

```markdown
# PR Reviewer — TITLE (PROJECT)

You are reviewing a PR in PROJECT, BRIEF_DESCRIPTION.

## Your Focus
SPECIALTY_DESCRIPTION. This project uses:
- SPECIFIC_TECH_1
- SPECIFIC_TECH_2
- SPECIFIC_PATTERNS

## What to Look For
- SPECIFIC_CHECKLIST_ITEM_1
- SPECIFIC_CHECKLIST_ITEM_2
- ... (be thorough and specific to this codebase)

## What to Ignore
Defer these to other reviewers — stay in your lane:
- AREA_1 (r-OTHER handles this)
- AREA_2 (r-OTHER handles this)

## How to Review
1. Run: gh pr diff {pr_number}
2. Run: gh pr view {pr_number}
3. Focus ONLY on files and changes relevant to your specialty
4. Post your review:
   gh pr review {pr_number} --comment --body '**[SPECIALTY_TAG]**

   YOUR_REVIEW_HERE'
5. Signal completion: tw signal {feature} {worker_name} done
```

IMPORTANT:
- The {pr_number}, {feature}, and {worker_name} placeholders must appear literally (with braces) — they get filled at dispatch time
- The "What to Ignore" section should reference the OTHER reviewers you're generating by their r-name
- Keep the "How to Review" section exactly as shown — these are the mechanical steps
- The "What to Look For" section is where your project-specific knowledge shines
- Be concrete: "Check that Prisma migrations include down migrations" not "Check migrations"
PROMPT_HEREDOC
)

    # Replace placeholder with actual prescan
    prompt="${prompt/PRESCAN_PLACEHOLDER/$prescan}"

    local json_out
    json_out=$(claude -p "$prompt" 2>/dev/null) \
        || die "Claude generation failed — check that 'claude' CLI is authenticated"

    [[ -z "$json_out" ]] && die "Claude returned empty output"

    # Strip markdown fences if present
    json_out=$(echo "$json_out" | python3 -c "
import sys, re, json
text = sys.stdin.read().strip()
# Strip markdown fences
text = re.sub(r'^\`\`\`[a-z]*\n', '', text)
text = re.sub(r'\n\`\`\`\s*$', '', text)
# Find JSON object
start = text.find('{')
end = text.rfind('}')
if start >= 0 and end > start:
    text = text[start:end+1]
# Validate it parses
json.loads(text)
print(text)
") || die "Failed to parse reviewer profiles — Claude output was not valid JSON"

    # Extract and write reviewer files
    mkdir -p "$reviews_dir"

    local reviewer_count
    reviewer_count=$(echo "$json_out" | python3 -c "
import json, sys
data = json.load(sys.stdin)
print(len(data.get('reviewers', [])))
")

    [[ "$reviewer_count" -eq 0 ]] && die "Claude generated zero reviewer profiles"

    # If --force, clear old profiles
    if [[ $force -eq 1 ]]; then
        rm -f "$reviews_dir"/*.md 2>/dev/null || true
    fi

    # Write each profile and build YAML config
    local yaml_reviews="reviews:"$'\n'
    local names_list=""

    echo "$json_out" | python3 -c "
import json, sys, os

data = json.load(sys.stdin)
reviews_dir = sys.argv[1]

for r in data.get('reviewers', []):
    name = r['name']
    content = r['content']
    filepath = os.path.join(reviews_dir, f'{name}.md')
    with open(filepath, 'w') as f:
        f.write(content)
        if not content.endswith('\n'):
            f.write('\n')
    # Output name:title for the summary
    print(f\"{name}:{r.get('title', name)}\")
" "$reviews_dir" | while IFS=: read -r rname rtitle; do
        echo "  $rname:"
        echo "    prompt: .tw/reviews/${rname}.md"
    done > "$reviews_dir/.yaml_fragment"

    # Read the generated yaml fragment
    yaml_reviews=$(printf "reviews:\n%s" "$(cat "$reviews_dir/.yaml_fragment")")
    rm -f "$reviews_dir/.yaml_fragment"

    # Display what was generated
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  Generated $reviewer_count reviewer profiles in .tw/reviews/:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    echo "$json_out" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for r in data.get('reviewers', []):
    print(f\"  r-{r['name']:20s} {r.get('title', r['name'])}\")
"

    echo ""
    echo "  YAML to add to .tw.yml:"
    echo "  ────────────────────────"
    echo "$yaml_reviews" | sed 's/^/  /'
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Ask to update .tw.yml
    local answer
    read -r -p "Add reviews: section to .tw.yml? [Y/n] " answer
    answer="${answer:-Y}"

    if [[ "$answer" =~ ^[Yy]$ ]]; then
        # Remove existing reviews: section if present, then append new one
        python3 -c "
import sys, re

config_path = sys.argv[1]
yaml_fragment = sys.argv[2]

with open(config_path, 'r') as f:
    content = f.read()

# Remove existing reviews: block (top-level key and all indented lines under it)
content = re.sub(r'\nreviews:\n(?:  .*\n)*', '\n', content)
content = re.sub(r'^reviews:\n(?:  .*\n)*', '', content)

# Ensure trailing newline
if not content.endswith('\n'):
    content += '\n'

# Append
content += '\n' + yaml_fragment + '\n'

with open(config_path, 'w') as f:
    f.write(content)
" "$config_file" "$yaml_reviews"
        log "Updated .tw.yml with reviews: section"
    else
        echo ""
        echo "  Skipped. Add the reviews: section to .tw.yml manually when ready."
    fi

    echo ""
    echo "  Review profiles saved to: $reviews_dir/"
    echo "  To dispatch a review:     tw review <feature> <pr-number>"
    echo "  To regenerate profiles:   tw review init --force"
    echo ""
}

# ── tw review <feature> <pr-number> ──────────────────────────────────
_review_dispatch() {
    local feature="" pr_number=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*) die "Unknown option: $1" ;;
            *)
                if [[ -z "$feature" ]]; then feature="$1"
                elif [[ -z "$pr_number" ]]; then pr_number="$1"
                else die "Too many arguments"
                fi
                shift ;;
        esac
    done

    [[ -z "$feature" || -z "$pr_number" ]] \
        && die "Usage: tw review <feature> <pr-number>"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    tmux has-session -t "=$tmux_session" 2>/dev/null \
        || die "No tmux session '$tmux_session' — is the feature running? Try: tw start $feature"

    local config_file
    config_file=$(find_config "$config_dir" 2>/dev/null) \
        || die "No .tw.yml found in $config_dir"

    # Read review entries
    local review_pairs
    mapfile -t review_pairs < <(yaml_review_entries "$config_file")
    [[ ${#review_pairs[@]} -eq 0 ]] \
        && die "No 'reviews:' section in .tw.yml — run 'tw review init' first"

    # Get bead_id
    bead_id=$(sessions_get_key "$session_key" "bead_id" 2>/dev/null || true)

    # Determine repo for the PR
    local repo
    repo=$(yaml_get_nested "$config_file" "issue_tracker.repo" "" 2>/dev/null || true)
    if [[ -z "$repo" ]]; then
        repo=$(cd "$config_dir" && gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || true)
    fi
    [[ -z "$repo" ]] && die "Cannot determine repo — set issue_tracker.repo in .tw.yml"

    local spawned=0 skipped=0 sent=0

    for rpair in "${review_pairs[@]}"; do
        [[ -z "$rpair" ]] && continue
        local rname="${rpair%%:*}" _rrest="${rpair#*:}"
        local rprompt="${_rrest%%:*}" rengine="${_rrest##*:}"
        rengine=$(resolve_engine "$rengine" "$config_file")

        # Build the task from the prompt file
        local task=""
        local prompt_path="$config_dir/$rprompt"
        if [[ -f "$prompt_path" ]]; then
            # Read the prompt file and fill placeholders
            task=$(cat "$prompt_path")
            task="${task//\{pr_number\}/$pr_number}"
            task="${task//\{feature\}/$feature}"
            task="${task//\{worker_name\}/$rname}"
            task="${task//\{repo\}/$repo}"
        else
            # Fallback: generic task if prompt file is missing
            log "Warning: prompt file not found: $prompt_path — using generic task"
            local specialty="${rname#r-}"
            task="Review PR #${pr_number} in ${repo} from a ${specialty} perspective. Run: gh pr diff ${pr_number} and gh pr view ${pr_number}. Focus on your specialty area. Post: gh pr review ${pr_number} --comment --body '**[${specialty}]** <your review>'. When done: tw signal ${feature} ${rname} done"
        fi

        # Spawn if not already running
        if tmux_window_exists "$tmux_session" "$rname"; then
            log "Reviewer $rname already running — re-sending task"
            ((skipped++)) || true
        else
            mkdir -p "$(agents_dir "$session_key")"
            local worker_bead_id
            worker_bead_id=$(worker_bead_find_or_create "$rname" "$project" "$config_dir")
            spawn_worker "$tmux_session" "$session_key" "$config_dir" \
                "$rname" "" "$bead_id" "$worker_bead_id" "$rengine"
            sessions_add_dynamic_worker "$session_key" "$rname" ""

            # Store engine if non-default
            if [[ "$rengine" != "claude" ]]; then
                python3 -c "
import json, sys
f = sys.argv[1]
d = json.load(open(f))
s = d.setdefault(sys.argv[2], {})
w = s.setdefault('workers', {})
we = w.setdefault(sys.argv[3], {})
we['engine'] = sys.argv[4]
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
" "$HOME/.tiddly-winks/sessions.json" "$session_key" "$rname" "$rengine" 2>/dev/null || true
            fi
            ((spawned++)) || true
        fi

        # Send the task via cmd_send (bead-backed, handles engine differences)
        # Run in a subshell to isolate set -e failures from the main loop
        ( cmd_send "$feature" "$rname" "$task" ) &
        ((sent++)) || true
    done

    # Wait for background sends to complete (|| true: some sends may fail)
    wait || true

    echo ""
    echo "  PR #${pr_number} review dispatched to ${sent} reviewers:"
    [[ $spawned -gt 0 ]] && echo "    Spawned: $spawned new"
    [[ $skipped -gt 0 ]] && echo "    Existing: $skipped (re-sent task)"
    echo ""
    echo "  Monitor: tw workers $feature --health"
    echo "  Feed:    tw feed $feature --problems"
    echo ""
}

cmd_workers() {
    local feature="" health_flag=0 respawn_flag=0 json_flag=0 force_flag=0 cleanup_flag=0 cv_worker=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --health) health_flag=1; shift ;;
            --respawn) respawn_flag=1; shift ;;
            --cleanup) cleanup_flag=1; shift ;;
            --json) json_flag=1; shift ;;
            --force) force_flag=1; shift ;;
            --cv) cv_worker="${2:-}"; shift; [[ -n "$cv_worker" ]] && shift ;;
            --cv=*) cv_worker="${1#--cv=}"; shift ;;
            -*) die "Unknown option: $1" ;;
            *) feature="$1"; shift ;;
        esac
    done

    [[ -z "$feature" ]] && die "Usage: tw workers <feature> [--health] [--respawn] [--cleanup] [--cv <worker>]"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    tmux has-session -t "=$tmux_session" 2>/dev/null \
        || die "No tmux session '$tmux_session' — is the feature running? Try: tw start $feature"

    local config_file="$config_dir/.tw.yml"
    [[ ! -f "$config_file" ]] && config_file="$config_dir/.devenv.yml"
    local override_file="$config_dir/.tw.override.yml"
    [[ ! -f "$override_file" && -f "$config_dir/.devenv.override.yml" ]] && override_file="$config_dir/.devenv.override.yml"
    local effective_config="$config_file"
    if [[ -f "$override_file" ]]; then
        effective_config=$(yaml_merge_override "$config_file" "$override_file")
    fi

    local worker_pairs
    mapfile -t worker_pairs < <(yaml_worker_pairs "$effective_config")
    # Merge dynamic workers from session state
    local dyn_pairs
    mapfile -t dyn_pairs < <(sessions_get_dynamic_workers "$session_key")
    worker_pairs+=("${dyn_pairs[@]}")

    [[ ${#worker_pairs[@]} -eq 0 ]] && { echo "  No workers defined in .tw.yml"; exit 0; }

    local bead_id
    bead_id=$(sessions_get_key "$session_key" "bead_id")

    mkdir -p "$(agents_dir "$session_key")"

    # --health: report worker status with 4-state model
    if [[ $health_flag -eq 1 ]]; then
        local agents_path
        agents_path="$(agents_dir "$session_key")"
        # Collect worker status lines as "name:role:status:engine"
        local health_lines=()
        for wpair in "${worker_pairs[@]}"; do
            [[ -z "$wpair" ]] && continue
            local wname="${wpair%%:*}"; local _wpr="${wpair#*:}"; local wrole="${_wpr%%:*}"
            local status wengine
            status=$(worker_state "$tmux_session" "$wname" "$agents_path" "$session_key")
            wengine=$(worker_engine "$session_key" "$wname")
            health_lines+=("${wname}:${wrole}:${status}:${wengine}")
        done

        if [[ $json_flag -eq 1 ]]; then
            printf '%s\n' "${health_lines[@]}" | python3 -c "
import json, sys
rows = []
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    parts = line.split(':', 3)
    rows.append({'name': parts[0], 'role': parts[1], 'status': parts[2], 'engine': parts[3] if len(parts) > 3 else 'claude', 'window': parts[0]})
print(json.dumps(rows, indent=2))
"
        else
            echo ""
            printf "  %-20s %-10s %-12s %s\n" "WORKER" "ENGINE" "STATUS" "CONTEXT"
            printf "  %-20s %-10s %-12s %s\n" "--------------------" "----------" "------------" "--------------------"
            for hline in "${health_lines[@]}"; do
                local wname="${hline%%:*}"
                local rest="${hline#*:}"
                local wrole="${rest%%:*}"
                rest="${rest#*:}"
                local status="${rest%%:*}"
                local wengine="${rest##*:}"
                printf "  %-20s %-10s %-12s %s\n" "$wname" "$wengine" "$status" "${wrole:--}"
            done
            echo ""
        fi
        return 0
    fi

    # --cv: show worker CV
    if [[ -n "$cv_worker" ]]; then
        echo ""
        cv_show "$project" "$cv_worker"
        echo ""
        return 0
    fi

    # --respawn: respawn dead/missing workers only (with circuit breaker)
    if [[ $respawn_flag -eq 1 ]]; then
        # --force resets all breakers before respawning
        if [[ $force_flag -eq 1 ]]; then
            breaker_reset_all "$session_key"
            log "Circuit breakers reset for $session_key"
        fi

        local respawned=0 alive=0 blocked=0
        for wpair in "${worker_pairs[@]}"; do
            [[ -z "$wpair" ]] && continue
            local wname="${wpair%%:*}"; local _wpr="${wpair#*:}"; local wrole="${_wpr%%:*}"
            local wengine="${wpair##*:}"
            wengine=$(resolve_engine "$wengine" "$config_file")

            if tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "$wname"; then
                if worker_is_alive "$tmux_session" "$wname" "$session_key"; then
                    (( alive++ )) || true
                    continue
                fi
                # Dead window(s) — kill ALL matching before respawning
                # (tmux allows duplicate window names; kill-window only removes one)
                while tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "$wname"; do
                    tmux kill-window -t "=$tmux_session:$wname" 2>/dev/null || break
                done
                log "Killed dead worker window(s): $wname"
            fi

            # Check circuit breaker (skip if --force already reset)
            if breaker_check_and_record "$session_key" "$wname"; then
                local worker_bead_id
                worker_bead_id=$(worker_bead_find_or_create "$wname" "$project" "$config_dir")
                spawn_worker "$tmux_session" "$session_key" "$config_dir" "$wname" "$wrole" "$bead_id" "$worker_bead_id" "$wengine"
                (( respawned++ )) || true
            else
                echo "  ⚡ $wname: circuit breaker tripped (use --force to override)"
                breaker_notify_god "$tmux_session" "$wname" "$BREAKER_MAX_FAILURES"
                (( blocked++ )) || true
            fi
        done
        echo ""
        echo "  Workers: $respawned respawned, $alive alive${blocked:+, $blocked blocked by breaker}"
        return 0
    fi

    # --cleanup: kill done/dead workers and remove dynamic worker entries
    if [[ $cleanup_flag -eq 1 ]]; then
        local agents_path
        agents_path="$(agents_dir "$session_key")"
        local cleaned=0 kept=0

        for wpair in "${worker_pairs[@]}"; do
            [[ -z "$wpair" ]] && continue
            local wname="${wpair%%:*}"
            local status
            status=$(worker_state "$tmux_session" "$wname" "$agents_path" "$session_key")

            if [[ "$status" == "done" || "$status" == "dead" ]]; then
                # Kill tmux window if it exists
                if tmux_window_exists "$tmux_session" "$wname"; then
                    tmux kill-window -t "=$tmux_session:$wname" 2>/dev/null || true
                fi
                # Remove from dynamic workers (no-op for static workers)
                sessions_remove_dynamic_worker "$session_key" "$wname" 2>/dev/null || true
                # Clear signals
                worker_signal_clear_all "$session_key" "$wname" 2>/dev/null || true
                log "Cleaned up worker: $wname ($status)"
                (( cleaned++ )) || true
            else
                (( kept++ )) || true
            fi
        done

        echo ""
        echo "  Cleanup: $cleaned removed, $kept still active"
        return 0
    fi

    # Default: spawn missing workers (original behavior)
    local spawned=0 skipped=0

    for wpair in "${worker_pairs[@]}"; do
        [[ -z "$wpair" ]] && continue
        local wname="${wpair%%:*}"
        local _wpr="${wpair#*:}"; local wrole="${_wpr%%:*}"
        local wengine="${wpair##*:}"
        wengine=$(resolve_engine "$wengine" "$config_file")

        # Skip if window already exists
        if tmux_window_exists "$tmux_session" "$wname"; then
            log "Worker already running: $wname (skipping)"
            (( skipped++ )) || true
            continue
        fi

        local worker_bead_id
        worker_bead_id=$(worker_bead_find_or_create "$wname" "$project" "$config_dir")
        spawn_worker "$tmux_session" "$session_key" "$config_dir" "$wname" "$wrole" "$bead_id" "$worker_bead_id" "$wengine"
        (( spawned++ )) || true
    done

    echo ""
    echo "  Workers: $spawned spawned, $skipped already running"
    echo "  Attach:  tmux attach -t $tmux_session"
}


cmd_gates() {
    local feature="${1:-}"
    local specific_gate=""

    shift || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --gate=*) specific_gate="${1#--gate=}"; shift ;;
            --gate)   specific_gate="${2:-}"; shift 2 ;;
            -*) die "Unknown option: $1" ;;
            *) shift ;;
        esac
    done

    # Find config
    local config_file
    config_file=$(find_config 2>/dev/null) || die "No .tw.yml found"
    local project
    project=$(yaml_get "$config_file" "project" "")
    [[ -z "$project" ]] && die "No project defined in .tw.yml"

    # Parse quality gates
    local gates_output
    gates_output=$(yaml_quality_gates "$config_file")
    [[ -z "$gates_output" ]] && die "No quality_gates defined in .tw.yml"

    # Determine working directory: use worktree if session is active, else config dir
    local work_dir
    work_dir=$(dirname "$config_file")

    if [[ -n "$feature" ]]; then
        local session_key="${project}-${feature}"
        local config_dir
        config_dir=$(sessions_get_key "$session_key" "config_dir" 2>/dev/null || true)
        if [[ -n "$config_dir" && -d "$config_dir" ]]; then
            work_dir="$config_dir"
        fi
    fi

    local total=0 passed=0 failed=0 failed_names=""

    while IFS=: read -r gname gcmd; do
        [[ -z "$gname" ]] && continue

        # If --gate specified, skip non-matching gates
        if [[ -n "$specific_gate" && "$gname" != "$specific_gate" ]]; then
            continue
        fi

        ((total++)) || true
        printf "\033[1;34m▶ Running gate: %s\033[0m\n" "$gname"
        printf "  \033[2m%s\033[0m\n" "$gcmd"

        if (cd "$work_dir" && eval "$gcmd") 2>&1; then
            printf "\033[1;32m✓ %s passed\033[0m\n\n" "$gname"
            ((passed++)) || true
        else
            printf "\033[1;31m✗ %s failed\033[0m\n\n" "$gname"
            ((failed++)) || true
            failed_names+="  - $gname"$'\n'
        fi
    done <<< "$gates_output"

    if [[ $total -eq 0 ]]; then
        if [[ -n "$specific_gate" ]]; then
            die "Gate '$specific_gate' not found in quality_gates"
        else
            die "No quality gates to run"
        fi
    fi

    echo "─────────────────────────────────"
    if [[ $failed -eq 0 ]]; then
        printf "\033[1;32mAll %d gate(s) passed\033[0m\n" "$total"
    else
        printf "\033[1;31m%d of %d gate(s) failed:\033[0m\n" "$failed" "$total"
        echo "$failed_names"
        exit 1
    fi
}

cmd_prime() {
    # Dynamic AI context — always in sync with the CLI
    # Intended to be injected via hooks at SessionStart and PreCompact

    # Detect current session context
    local current_session="" current_project="" current_feature="" current_bead=""
    local config_file
    if config_file=$(find_config 2>/dev/null); then
        current_project=$(yaml_get "$config_file" "project" "")
    fi

    # Try to find active session from worktree path
    if [[ -n "$current_project" ]]; then
        local cwd_branch
        cwd_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)
        if [[ "$cwd_branch" == */* ]]; then
            local candidate_feature="${cwd_branch##*/}"
            local candidate_key="${current_project}-${candidate_feature}"
            if sessions_list_keys | grep -qF "$candidate_key"; then
                current_session="$candidate_key"
                current_feature="$candidate_feature"
                current_bead=$(python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
s = d.get('$candidate_key', {})
print(s.get('bead_id', ''))
" 2>/dev/null || true)
            fi
        fi
    fi

    cat <<'PRIME'
# tiddly-winks — Feature Space Manager

> Run `tw prime` after compaction, clear, or new session to restore context.

## Core Rules
- **URLs**: Always use `http://{project}-{feature}.localhost`, NEVER raw `localhost:PORT`
- **Browser**: Chrome/Firefox only — Safari does NOT resolve `*.localhost`
- **Services**: Never start services manually — tw manages them via tmux
- **Beads**: Use `bd` for all issue tracking. `tw start` creates beads automatically.
- **Workers**: Don't run tasks yourself if a worker exists for it — use `tw send`
- **Context**: Run `/pass` when context gets large — it saves to bead and opens fresh window

## Essential Commands

### Session Management
```bash
tw list                          # Numbered list of all sessions
tw attach <N>                    # Attach by index from tw list
tw attach <name> --claude        # Jump to god (orchestrator) window
tw status <feature>              # Ports, URLs, worktrees, bead, workers
tw open <feature>                # Open primary URL in browser
```

### Feature Lifecycle
```bash
tw start <feature>               # Create feature space (branch, worktrees, services, bead)
tw stop <feature>                # Pause session (bead stays open)
tw stop <feature> --done         # Tear down everything, close bead
tw prune                         # Clean up dead sessions after reboot
tw resume <feature>              # Resume feature from bead state after hard reset
tw resume --all                  # Resume all in-progress features
```

### Worker Management
```bash
tw workers <feature> --health    # Check worker state (working/idle/stalled/done/dead/not-logged-in)
tw workers <feature> --cv <name> # Show worker CV and work history
tw workers <feature> --respawn [--force]  # Respawn dead workers (--force overrides circuit breaker)
tw workers <feature> --cleanup            # Kill done/dead workers, remove dynamic entries
tw send <feature> <worker> "task description"  # Queue task for a worker (clears done signal)
tw signal <feature> <worker> done   # Signal task completion (available for reuse)
tw handoff <feature> <worker>    # Cycle worker (save context, restart fresh)
tw patrol <feature>              # Full health check + auto-respawn + plugins
tw spawn <feature> <name> <role> # Add a worker to a running session
tw review init [--force]         # Generate workspace-specific PR reviewer profiles
tw review <feature> <pr-number>  # Dispatch multi-perspective PR review
tw checkpoint squash <feature>   # Squash WIP checkpoint commits before push/PR
```

### Mail (persistent beads-backed messaging)
```bash
tw mail send <feature> <target> -s "Subject" -m "Body" [-f sender]  # Send persistent mail
tw mail inbox <feature> [worker]    # List unread mail for a worker
tw mail read <bead-id>              # Read message and mark as read
tw mail ack <bead-id>               # Acknowledge and close message
```
Use mail for important signals: TASK_DONE, HELP/BLOCKED, HANDOFF.
Use nudges for simple wake-ups and non-critical pings.

### Runtime Config (fix proxy/port issues without restarting)
```bash
tw config show <feature>                   # Show current services + proxy routes
tw config proxy <feature> "" frontend      # Route primary URL to a different service
tw config proxy <feature> api backend      # Route -api subdomain
tw config service <feature> web add 5173   # Register a new service
tw config service <feature> web port 5174  # Change a service's port
```

### Context Recovery
```bash
/pass                            # Preferred: auto-save + fresh window
/wrap-up                         # Manual: copy output, then:
tw append <feature>              # Paste wrap-up to bead (Ctrl-D to end)
tw claude <feature>              # Start new Claude with context block
bd show <bead-id>                # Load full session history
```

## Anti-patterns — DO NOT
- Do NOT use `localhost:PORT` in URLs, docs, or beads — always use proxy URLs
- Do NOT open *.localhost URLs in Safari — they will not resolve
- Do NOT start services manually (npm run dev, etc.) — tw manages service lifecycle
- Do NOT create markdown TODO files — use `bd create` for task tracking
- Do NOT do worker tasks yourself — delegate via `tw send <feature> <worker> "task"`
- Do NOT ignore context loss — run `/pass` proactively when context grows large
- Do NOT use `bd edit` — it opens $EDITOR which blocks agents

## Session Naming
- tmux sessions: `{project}-{feature}`
- URLs: `http://{project}-{feature}.localhost` (primary), `-api.localhost` (backend)
- Branches: `{user}/{feature}` (configurable via branch_prefix in .tw.yml)
- Beads: `{feature} ({project})`
PRIME

    # Append quality gates if defined in project config
    if [[ -n "${config_file:-}" ]]; then
        local gates_output
        gates_output=$(yaml_quality_gates "$config_file")
        if [[ -n "$gates_output" ]]; then
            echo ""
            echo "## Quality Gates"
            echo "Before submitting PRs, workers MUST run these checks:"
            echo '```bash'
            while IFS=: read -r gname gcmd; do
                [[ -z "$gname" ]] && continue
                printf '%-30s # %s\n' "$gcmd" "$gname"
            done <<< "$gates_output"
            echo '```'
            echo "Run all gates: \`tw gates <feature>\`"
        fi
    fi

    # Append dynamic context if we detected a session
    if [[ -n "$current_session" ]]; then
        echo ""
        echo "## Current Session"
        echo "- **Session**: $current_session"
        echo "- **Project**: $current_project"
        echo "- **Feature**: $current_feature"
        [[ -n "$current_bead" ]] && echo "- **Bead**: $current_bead — run \`bd show $current_bead\` for full context"
        echo "- **Status**: run \`tw status $current_feature\` for ports/URLs/workers"
    fi

    # List all active sessions
    local sessions_data
    sessions_data=$(sessions_read)
    local session_count
    session_count=$(python3 -c "import json,sys; print(len(json.loads(sys.argv[1])))" "$sessions_data" 2>/dev/null || echo 0)
    if [[ "$session_count" -gt 0 ]]; then
        echo ""
        echo "## Active Sessions ($session_count)"
        echo '```'
        cmd_list 2>/dev/null
        echo '```'
    fi
}

cmd_onboard() {
    # Generate a minimal AGENTS.md / CLAUDE.md snippet pointing to tw prime
    cat <<'ONBOARD'
### tiddly-winks (tw) — Feature Space Manager

For full workflow context, run:
```bash
tw prime
```

Quick reference:
```bash
tw list                          # See active sessions
tw attach <N>                    # Attach by index
tw status <feature>              # Session details
tw start <feature>               # New feature space
tw stop <feature> [--done]       # Stop [and tear down]
```

> `tw prime` is auto-injected via hooks at session start. Run it manually
> after compaction or context loss.
ONBOARD
}

# ─── Pane ID ───────────────────────────────────────────────────────────────────

cmd_pane_id() {
    local feature="${1:-}" service="${2:-}"
    [[ -z "$feature" || -z "$service" ]] && die "Usage: tw pane-id <feature> <service>"

    local sessions_data
    sessions_data=$(sessions_read)

    local pane_id
    pane_id=$(python3 -c "
import json, sys
data = json.loads(sys.argv[1])
feature = sys.argv[2]
service = sys.argv[3]
for key, s in data.items():
    if s.get('feature') == feature or key.endswith('-' + feature):
        svcs = s.get('services', {})
        if service in svcs:
            pid = svcs[service].get('pane_id', '')
            if pid:
                print(pid)
                break
" "$sessions_data" "$feature" "$service" 2>/dev/null)

    if [[ -z "$pane_id" ]]; then
        die "No pane_id found for service '$service' in feature '$feature'"
    fi
    echo "$pane_id"
}

# ─── Port Owner ────────────────────────────────────────────────────────────────

cmd_port_owner() {
    local port="${1:-}"
    [[ -z "$port" ]] && die "Usage: tw port-owner <port>"
    [[ ! "$port" =~ ^[0-9]+$ ]] && die "Port must be a number"
    [[ ! -f "$SESSIONS_FILE" ]] && { echo "unmanaged (no sessions file)"; return 0; }

    local result
    result=$(python3 -c "
import json, sys
port = sys.argv[1]
try:
    data = json.load(open(sys.argv[2]))
except Exception:
    sys.exit(0)
for key, session in data.items():
    for svc, info in session.get('services', {}).items():
        p = info.get('port', '') if isinstance(info, dict) else info
        if str(p) == port:
            print(f'{key}:{svc} (port {port})')
            sys.exit(0)
" "$port" "$SESSIONS_FILE")

    if [[ -n "$result" ]]; then
        echo "$result"
    else
        echo "unmanaged (no tw session owns port $port)"
    fi
}

# ─── Engine Stats ─────────────────────────────────────────────────────────────

cmd_engine_stats() {
    local days=7
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --days) days="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    echo ""
    echo "  Engine usage (last $days days):"
    echo "  ─────────────────────────────────────────"

    local usage_dir="$TW_DIR/engine-usage"
    [[ -d "$usage_dir" ]] || { echo "  No usage data yet."; return 0; }

    local found=0
    for engine_dir in "$usage_dir"/*/; do
        [[ -d "$engine_dir" ]] || continue
        found=1
        local engine
        engine=$(basename "$engine_dir")
        local total=0
        local today_count=0
        local today
        today=$(date +%Y-%m-%d)

        for i in $(seq 0 $((days - 1))); do
            local d
            d=$(date -v-${i}d +%Y-%m-%d 2>/dev/null || date -d "-$i days" +%Y-%m-%d)
            local cf="$engine_dir/$d.count"
            if [[ -f "$cf" ]]; then
                local c
                c=$(cat "$cf")
                total=$((total + c))
                [[ "$d" == "$today" ]] && today_count=$c
            fi
        done

        printf "  %-12s today: %3d  |  %d-day total: %3d\n" "$engine" "$today_count" "$days" "$total"
    done

    [[ $found -eq 0 ]] && echo "  No usage data yet."
    echo ""
}

# ─── Doctor ───────────────────────────────────────────────────────────────────

cmd_doctor() {
    local errors=0 warnings=0

    _ok()   { echo "  ✓ $*"; }
    _warn() { echo "  ⚠ $*"; (( warnings++ )) || true; }
    _fail() { echo "  ✗ $*"; (( errors++ )) || true; }
    _hint() { echo "    → $*"; }

    echo "tw doctor — checking environment"
    echo

    # 1. tmux
    if command -v tmux &>/dev/null; then
        local tmux_ver
        tmux_ver=$(tmux -V 2>/dev/null | awk '{print $2}')
        if tmux list-sessions &>/dev/null; then
            _ok "tmux installed ($tmux_ver), server running"
        else
            _warn "tmux installed ($tmux_ver) but no server running"
            _hint "A server starts automatically with: tw start <feature>"
        fi
    else
        _fail "tmux not installed"
        _hint "Install with: brew install tmux"
    fi

    # 2. Caddy daemon
    if pgrep -qx caddy 2>/dev/null; then
        _ok "Caddy daemon running"
    else
        _fail "Caddy daemon not running"
        _hint "Start with: sudo launchctl kickstart -k system/com.tw.caddy"
    fi

    # 2b. Caddy admin API
    if curl -sf "$CADDY_ADMIN/config/" &>/dev/null; then
        _ok "Caddy admin API responding at $CADDY_ADMIN"
    else
        _warn "Caddy admin API not responding at $CADDY_ADMIN"
        _hint "Check: curl -s $CADDY_ADMIN/config/"
    fi

    # 3. Python 3 + PyYAML
    if command -v python3 &>/dev/null; then
        local py_ver
        py_ver=$(python3 --version 2>&1 | awk '{print $2}')
        if python3 -c "import yaml" 2>/dev/null; then
            _ok "Python 3 ($py_ver) with PyYAML"
        else
            _fail "Python 3 ($py_ver) found but PyYAML missing"
            _hint "Install with: pip3 install pyyaml"
        fi
    else
        _fail "Python 3 not installed"
        _hint "Install with: brew install python3"
    fi

    # 4. bd CLI (beads)
    if command -v bd &>/dev/null; then
        _ok "bd CLI installed"
    else
        _fail "bd CLI (beads) not installed"
        _hint "See beads installation docs"
    fi

    # 5. Sessions integrity
    if [[ -f "$SESSIONS_FILE" ]]; then
        local session_count dead_count
        session_count=$(python3 -c "
import json, sys
try:
    d = json.load(open('$SESSIONS_FILE'))
    print(len(d))
except Exception:
    print('INVALID')
" 2>/dev/null)

        if [[ "$session_count" == "INVALID" ]]; then
            _fail "sessions.json exists but is not valid JSON"
            _hint "Inspect: cat $SESSIONS_FILE"
        else
            _ok "sessions.json valid ($session_count sessions)"

            # Check for dead sessions (tmux session gone)
            if [[ "$session_count" -gt 0 ]]; then
                dead_count=$(python3 -c "
import json, subprocess, sys
d = json.load(open('$SESSIONS_FILE'))
dead = 0
for key, s in d.items():
    sk = f\"{s.get('project','')}-{s.get('feature','')}\"
    r = subprocess.run(['tmux', 'has-session', '-t', f'={sk}'], capture_output=True)
    if r.returncode != 0:
        dead += 1
print(dead)
" 2>/dev/null || echo 0)
                if [[ "$dead_count" -gt 0 ]]; then
                    _warn "$dead_count dead session(s) found"
                    _hint "Run: tw prune"
                fi
            fi
        fi
    else
        _warn "sessions.json does not exist (will be created on first tw start)"
    fi

    # 6. Hooks
    local hooks_dir="$HOME/.claude/hooks"
    local hook_names=("tw-prime.sh" "tw-mail-check.sh" "tw-notify.sh")
    for hook in "${hook_names[@]}"; do
        if [[ -f "$hooks_dir/$hook" ]]; then
            _ok "Hook present: $hook"
        else
            _fail "Hook missing: $hook"
            _hint "Install with: tw setup claude"
        fi
    done

    # 7. Roles directory
    local roles_dir="$HOME/.claude/roles"
    if [[ -d "$roles_dir" ]]; then
        local role_count
        role_count=$(find "$roles_dir" -maxdepth 1 -type f -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
        _ok "Roles directory exists ($role_count role files)"
    else
        _fail "Roles directory missing: $roles_dir"
        _hint "Create with: mkdir -p $roles_dir"
    fi

    # 8. Caddyfile
    if [[ -f "$CADDYFILE" ]]; then
        _ok "Caddyfile exists"
    else
        _warn "Caddyfile missing: $CADDYFILE"
        _hint "Will be generated on first tw start"
    fi

    # 9. PATH check
    if echo "$PATH" | tr ':' '\n' | grep -qx "$HOME/.local/bin"; then
        _ok "~/.local/bin is in PATH"
    else
        _fail "~/.local/bin is not in PATH"
        _hint "Add to your shell profile: export PATH=\"\$HOME/.local/bin:\$PATH\""
    fi

    # 10. Orphaned spinner PIDs
    local orphan_spinners=0
    for pid_file in "$TW_DIR"/spinner-*.pid; do
        [[ -f "$pid_file" ]] || continue
        local spid
        spid=$(cat "$pid_file")
        if ! kill -0 "$spid" 2>/dev/null; then
            (( orphan_spinners++ )) || true
            rm -f "$pid_file"
        fi
    done
    if [[ $orphan_spinners -gt 0 ]]; then
        _warn "$orphan_spinners orphaned spinner PID file(s) cleaned up"
    else
        _ok "No orphaned spinner PIDs"
    fi

    # 11. Caddy route sync — check that every alive session has matching Caddy routes
    if curl -sf "$CADDY_ADMIN/config/" &>/dev/null && [[ -f "$SESSIONS_FILE" ]]; then
        local caddy_config route_mismatches=0
        caddy_config=$(curl -sf "$CADDY_ADMIN/config/" 2>/dev/null || echo '{}')
        local missing_routes
        missing_routes=$(python3 - "$caddy_config" <<'PYEOF' 2>/dev/null || true
import json, sys, subprocess

caddy = json.loads(sys.argv[1])
caddy_str = json.dumps(caddy)

sessions = json.load(open("$SESSIONS_FILE"))
missing = []
for key, s in sessions.items():
    sk = f"{s.get('project','')}-{s.get('feature','')}"
    r = subprocess.run(['tmux', 'has-session', '-t', f'={sk}'], capture_output=True)
    if r.returncode != 0:
        continue  # not alive, skip
    proxy_map = s.get('proxy_map', {})
    for subdomain in proxy_map:
        if subdomain == '':
            host = f"{s['project']}-{s['feature']}.localhost"
        else:
            host = f"{s['project']}-{s['feature']}-{subdomain}.localhost"
        if host not in caddy_str:
            missing.append(host)

for m in missing:
    print(m)
PYEOF
        )
        if [[ -n "$missing_routes" ]]; then
            route_mismatches=$(echo "$missing_routes" | wc -l | tr -d ' ')
            _warn "$route_mismatches Caddy route(s) missing for alive sessions"
            while IFS= read -r route; do
                _hint "Missing: $route"
            done <<< "$missing_routes"
            _hint "Fix with: tw prune && tw start <feature>"
        else
            _ok "Caddy routes in sync with alive sessions"
        fi
    fi

    # 12. Stale worktrees — worktree dirs that exist but have no matching session
    if [[ -f "$SESSIONS_FILE" ]]; then
        local stale_wt=0
        local all_wt_paths
        all_wt_paths=$(python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
for s in d.values():
    for path in s.get('worktrees', {}).values():
        print(path)
" 2>/dev/null || true)

        # Check each registered worktree path actually exists
        while IFS= read -r wt_path; do
            [[ -z "$wt_path" ]] && continue
            if [[ ! -d "$wt_path" ]]; then
                (( stale_wt++ )) || true
                _warn "Worktree path missing on disk: $wt_path"
                _hint "Session may need restart: tw stop <feature> && tw start <feature>"
            fi
        done <<< "$all_wt_paths"
        [[ $stale_wt -eq 0 ]] && _ok "All registered worktree paths exist"
    fi

    # 13. Orphaned tw workers — claude processes with TW_WORKER env that aren't in a tmux pane
    local orphan_workers
    orphan_workers=$(python3 - <<'PYEOF' 2>/dev/null || echo 0
import subprocess

# Get all tmux pane PIDs
try:
    r = subprocess.run(['tmux', 'list-panes', '-a', '-F', '#{pane_pid}'],
                       capture_output=True, text=True)
    pane_pids = set(r.stdout.strip().split('\n')) if r.returncode == 0 else set()
except Exception:
    pane_pids = set()

# Get all claude PIDs
try:
    r = subprocess.run(['pgrep', '-f', 'claude.*--dangerously-skip-permissions'],
                       capture_output=True, text=True)
    claude_pids = [p.strip() for p in r.stdout.strip().split('\n') if p.strip()]
except Exception:
    claude_pids = []

orphans = 0
for cpid in claude_pids:
    # Check if this is a tw worker (parent shell has TW_WORKER in env)
    try:
        r = subprocess.run(['ps', '-p', cpid, '-o', 'ppid='], capture_output=True, text=True)
        ppid = r.stdout.strip()
        if not ppid:
            continue
        # Check parent's environment for TW_WORKER
        r = subprocess.run(['ps', '-p', ppid, '-E', '-o', 'command='],
                           capture_output=True, text=True)
        if 'TW_WORKER' not in r.stdout and 'TW_SESSION' not in r.stdout:
            continue  # Not a tw-managed process, skip
        # It's a tw worker — check if parent is a live tmux pane
        if ppid not in pane_pids:
            orphans += 1
    except Exception:
        continue

print(orphans)
PYEOF
    )
    if [[ "$orphan_workers" -gt 0 ]] 2>/dev/null; then
        _warn "$orphan_workers orphaned tw worker process(es) found (not in any tmux pane)"
        _hint "Inspect with: ps aux | grep 'TW_WORKER.*claude'"
    else
        _ok "No orphaned tw worker processes"
    fi

    # 14. Port conflicts — check if any session's ports are held by unexpected processes
    if [[ -f "$SESSIONS_FILE" ]]; then
        local port_conflicts=0
        python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
for key, s in d.items():
    for svc, info in s.get('services', {}).items():
        port = info.get('port', '') if isinstance(info, dict) else info
        if port:
            print(f'{key}|{svc}|{port}')
" 2>/dev/null | while IFS='|' read -r sk svc port; do
            [[ -z "$port" ]] && continue
            local port_holder
            port_holder=$(lsof -ti :"$port" 2>/dev/null | head -1)
            if [[ -n "$port_holder" ]]; then
                # Check if the process belongs to this session's tmux
                local holder_cmd
                holder_cmd=$(ps -p "$port_holder" -o command= 2>/dev/null | head -c 60)
                # Port is in use — that's expected if session is alive. Only warn if session is dead.
                local tmux_key="${sk}"
                if ! tmux has-session -t "=$tmux_key" 2>/dev/null; then
                    _warn "Port $port ($svc in $sk) held by stale process: $holder_cmd"
                    _hint "Kill with: kill $port_holder"
                    (( port_conflicts++ )) || true
                fi
            fi
        done
        [[ ${port_conflicts:-0} -eq 0 ]] && _ok "No stale port conflicts"
    fi

    # 15. Proxy content check — detect when primary proxy hits backend instead of frontend
    if [[ -f "$SESSIONS_FILE" ]]; then
        python3 -c "
import json
d = json.load(open('$SESSIONS_FILE'))
for key, s in d.items():
    pm = s.get('proxy_map', {})
    svcs = s.get('services', {})
    p = s.get('project', '')
    f = s.get('feature', '')
    primary_svc = pm.get('', '')
    if not primary_svc:
        continue
    port = svcs.get(primary_svc, {}).get('port', '')
    if port:
        print(f'{key}|{p}|{f}|{primary_svc}|{port}')
" 2>/dev/null | while IFS='|' read -r sk proj feat svc port; do
            [[ -z "$port" ]] && continue
            # Only check alive sessions
            tmux has-session -t "=$sk" 2>/dev/null || continue

            local url="http://localhost:${port}"
            local body
            body=$(curl -sf --max-time 2 "$url" 2>/dev/null || true)
            [[ -z "$body" ]] && continue

            # Check for frontend dev server indicators
            if echo "$body" | grep -qiE 'vite|__vite|webpack|hot-update|hmr|react-refresh|__next'; then
                _ok "Proxy $proj-$feat.localhost → $svc (frontend dev server detected)"
            elif echo "$body" | grep -qiE '"error"|"status"|"api"|"version".*:.*"[0-9]'; then
                _warn "Proxy $proj-$feat.localhost → $svc may be a backend API, not a frontend dev server"
                _hint "Fix with: tw config proxy $feat \"\" <frontend-service>"
                (( warnings++ )) || true
            else
                # HTML returned but no dev server indicators — could be backend serving static
                local content_type
                content_type=$(curl -sf --max-time 2 -o /dev/null -w "%{content_type}" "$url" 2>/dev/null || true)
                if [[ "$content_type" == *"text/html"* ]]; then
                    # Check if it's serving raw JS modules properly (frontend dev server does)
                    local js_check
                    js_check=$(curl -sf --max-time 2 -H "Accept: application/javascript" "$url/@vite/client" 2>/dev/null \
                        || curl -sf --max-time 2 "$url/src/main.tsx" 2>/dev/null \
                        || curl -sf --max-time 2 "$url/src/main.ts" 2>/dev/null \
                        || true)
                    if [[ -z "$js_check" ]]; then
                        _warn "Proxy $proj-$feat.localhost → $svc serves HTML but no dev server module endpoints"
                        _hint "This may be a backend with SPA catch-all. Fix with: tw config proxy $feat \"\" <frontend-service>"
                        (( warnings++ )) || true
                    fi
                fi
            fi
        done
    fi

    # Summary
    echo
    if [[ $errors -eq 0 && $warnings -eq 0 ]]; then
        echo "All checks passed."
    else
        [[ $errors -gt 0 ]] && echo "$errors error(s) found."
        [[ $warnings -gt 0 ]] && echo "$warnings warning(s) found."
    fi

    return $errors
}


cmd_setup() {
    local target="${1:-}"
    [[ -z "$target" ]] && die "Usage: tw setup claude"

    case "$target" in
        claude) setup_claude ;;
        *) die "Unknown setup target: $target. Available: claude" ;;
    esac
}

setup_claude() {
    local hooks_dir="$HOME/.claude/hooks"
    local settings_file="$HOME/.claude/settings.json"
    mkdir -p "$hooks_dir"

    # 1. Create/update tw-context.sh — injects tw prime for non-worker sessions
    cat > "$hooks_dir/tw-context.sh" << 'HOOKEOF'
#!/usr/bin/env bash
# tw-context: SessionStart hook — inject tw prime for any session in a tw project.
# Skips if already in a tw worker session (tw-prime.sh handles those).

# Skip if this is a worker session (tw-prime.sh handles it)
[[ -n "${TW_SESSION:-}" && -n "${TW_WORKER:-}" ]] && exit 0

# Check if we are in a tw-managed project
config_file=""
dir="$PWD"
while [[ "$dir" != "/" ]]; do
    [[ -f "$dir/.tw.yml" ]] && { config_file="$dir/.tw.yml"; break; }
    [[ -f "$dir/.devenv.yml" ]] && { config_file="$dir/.devenv.yml"; break; }
    dir="$(dirname "$dir")"
done
[[ -z "$config_file" ]] && exit 0

tw prime 2>/dev/null
HOOKEOF
    chmod +x "$hooks_dir/tw-context.sh"
    log "Wrote $hooks_dir/tw-context.sh"

    # 2. Create/update tw-compact.sh — re-injects tw prime before compaction
    cat > "$hooks_dir/tw-compact.sh" << 'HOOKEOF'
#!/usr/bin/env bash
# tw-compact: PreCompact hook — re-inject tw prime so context survives compaction.

# For workers, re-inject their specialized context
if [[ -n "${TW_SESSION:-}" && -n "${TW_WORKER:-}" ]]; then
    ~/.claude/hooks/tw-prime.sh 2>/dev/null
    exit 0
fi

# For non-workers in a tw project, re-inject tw prime
config_file=""
dir="$PWD"
while [[ "$dir" != "/" ]]; do
    [[ -f "$dir/.tw.yml" ]] && { config_file="$dir/.tw.yml"; break; }
    [[ -f "$dir/.devenv.yml" ]] && { config_file="$dir/.devenv.yml"; break; }
    dir="$(dirname "$dir")"
done
[[ -z "$config_file" ]] && exit 0

tw prime 2>/dev/null
HOOKEOF
    chmod +x "$hooks_dir/tw-compact.sh"
    log "Wrote $hooks_dir/tw-compact.sh"

    # 3. Register hooks in settings.json
    python3 - "$settings_file" "$hooks_dir" << 'PYEOF'
import json, sys, os

settings_file = sys.argv[1]
hooks_dir = sys.argv[2]

try:
    with open(settings_file) as f:
        settings = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    settings = {}

hooks = settings.setdefault("hooks", {})

def ensure_hook(event, command, timeout=30, status_msg=None):
    entries = hooks.setdefault(event, [])
    for entry in entries:
        for h in entry.get("hooks", []):
            if h.get("command", "").rstrip() == command:
                return False
    hook_def = {"type": "command", "command": command, "timeout": timeout}
    if status_msg:
        hook_def["statusMessage"] = status_msg
    entries.append({"hooks": [hook_def]})
    return True

changes = []

if ensure_hook("SessionStart",
               hooks_dir + "/tw-context.sh", 30,
               "Loading tw project context..."):
    changes.append("SessionStart: tw-context.sh")

if ensure_hook("PreCompact",
               hooks_dir + "/tw-compact.sh", 30,
               "Refreshing tw context..."):
    changes.append("PreCompact: tw-compact.sh")

if changes:
    with open(settings_file, 'w') as f:
        json.dump(settings, f, indent=2)
    for c in changes:
        print("  Registered hook: " + c)
else:
    print("  Hooks already registered")
PYEOF

    echo ""
    echo "  Done. tw prime will now auto-inject at session start and before compaction."
    echo "  Test with: claude (in a directory with .tw.yml)"
}


cmd_hook() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "$subcmd" in
        set)
            local feature="" worker="" task=""
            while [[ $# -gt 0 ]]; do
                if [[ -z "$feature" ]]; then feature="$1"
                elif [[ -z "$worker" ]]; then worker="$1"
                else task="$task $1"
                fi
                shift
            done
            task="${task# }"
            [[ -z "$feature" || -z "$worker" || -z "$task" ]] \
                && die 'Usage: tw hook set <feature> <worker> "<task>"'

            local session_key project config_dir tmux_session bead_id
            resolve_session "$feature"

            local hooked_file="$HOME/.tiddly-winks/hooked/${session_key}/${worker}.json"
            [[ -f "$hooked_file" ]] || die "No hooked file for worker '$worker' in session '$session_key'"

            python3 -c "
import json, sys
f, task = sys.argv[1], sys.argv[2]
d = json.load(open(f))
d['current_task'] = task
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
w = d.get('worker', '?')
print(f'  Hook set for {w}: {task}')
" "$hooked_file" "$task"
            ;;
        clear)
            local feature="${1:-}" worker="${2:-}"
            [[ -z "$feature" || -z "$worker" ]] \
                && die "Usage: tw hook clear <feature> <worker>"

            local session_key project config_dir tmux_session bead_id
            resolve_session "$feature"

            local hooked_file="$HOME/.tiddly-winks/hooked/${session_key}/${worker}.json"
            [[ -f "$hooked_file" ]] || die "No hooked file for worker '$worker'"

            python3 -c "
import json, sys
f = sys.argv[1]
d = json.load(open(f))
d.pop('current_task', None)
with open(f, 'w') as fh:
    json.dump(d, fh, indent=2)
w = d.get('worker', '?')
print(f'  Hook cleared for {w}')
" "$hooked_file"
            ;;
        show)
            local feature="${1:-}" worker="${2:-}"
            [[ -z "$feature" || -z "$worker" ]] \
                && die "Usage: tw hook show <feature> <worker>"

            local session_key project config_dir tmux_session bead_id
            resolve_session "$feature"

            local hooked_file="$HOME/.tiddly-winks/hooked/${session_key}/${worker}.json"
            [[ -f "$hooked_file" ]] || die "No hooked file for worker '$worker'"

            python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
task = d.get('current_task', '')
if task:
    w = d.get('worker', '?')
    print(f'  Hook for {w}: {task}')
else:
    w = d.get('worker', '?')
    print(f'  No hook set for {w}')
" "$hooked_file"
            ;;
        *)
            die "Usage: tw hook {set|clear|show} <feature> <worker> [task]"
            ;;
    esac
}


# ─── Checkpoint squash ────────────────────────────────────────────────────────
# Squash WIP checkpoint commits between merge-base and HEAD into a single commit.
# Preserves non-WIP commit messages. Safe because feature branches are typically
# squash-merged anyway.
# Usage: _checkpoint_squash <worktree_path> [base_ref]
_checkpoint_squash() {
    local wt_path="$1" base_ref="${2:-}"

    [[ -d "$wt_path" ]] || return 0
    [[ -d "$wt_path/.git" || -f "$wt_path/.git" ]] || return 0

    # Auto-detect base ref if not provided
    if [[ -z "$base_ref" ]]; then
        for candidate in origin/staging origin/main origin/master; do
            if git -C "$wt_path" rev-parse --verify "$candidate" &>/dev/null; then
                base_ref="$candidate"
                break
            fi
        done
        [[ -z "$base_ref" ]] && { log "Squash: no base ref found for $wt_path — skipping"; return 0; }
    fi

    # Find merge-base
    local merge_base
    merge_base=$(git -C "$wt_path" merge-base "$base_ref" HEAD 2>/dev/null) || {
        log "Squash: could not find merge-base for $wt_path — skipping"
        return 0
    }

    # List commit subjects from merge-base..HEAD
    local log_out
    log_out=$(git -C "$wt_path" log --format=%s "$merge_base..HEAD" 2>/dev/null) || return 0
    [[ -z "$log_out" ]] && return 0

    # Count WIP commits and collect non-WIP subjects
    local wip_count=0
    local non_wip_subjects=()
    while IFS= read -r subj; do
        if [[ "$subj" == "WIP: checkpoint"* ]]; then
            (( wip_count++ )) || true
        elif [[ -n "$subj" ]]; then
            non_wip_subjects+=("$subj")
        fi
    done <<< "$log_out"

    [[ $wip_count -eq 0 ]] && return 0

    # Soft-reset to merge-base (preserves all changes as staged)
    git -C "$wt_path" reset --soft "$merge_base" 2>/dev/null || {
        log "Squash: soft reset failed for $wt_path"
        return 1
    }

    # Build combined commit message
    local msg
    if [[ ${#non_wip_subjects[@]} -gt 0 ]]; then
        msg="${non_wip_subjects[0]}"
        if [[ ${#non_wip_subjects[@]} -gt 1 ]]; then
            msg+=$'\n'
            local i
            for (( i=1; i<${#non_wip_subjects[@]}; i++ )); do
                msg+=$'\n'"- ${non_wip_subjects[$i]}"
            done
        fi
    else
        msg="squashed WIP checkpoint commits"
    fi

    # Commit with combined message
    git -C "$wt_path" commit -m "$msg" --no-verify 2>/dev/null || {
        log "Squash: commit failed for $wt_path"
        return 1
    }

    log "Squash: collapsed $wip_count WIP commit(s) in $(basename "$wt_path")"
    # Return 2 to signal "squash happened" (vs 0 = no WIP commits)
    return 2
}

# ── tw checkpoint ─────────────────────────────────────────────────────────────
# Manage checkpoint WIP commits.
#   tw checkpoint squash <feature>   Squash WIP commits across all worktrees

cmd_checkpoint() {
    [[ $# -eq 0 ]] && die "Usage: tw checkpoint squash <feature>"

    local subcmd="$1"; shift
    case "$subcmd" in
        squash) _checkpoint_squash_feature "$@" ;;
        *) die "Unknown checkpoint subcommand: $subcmd. Usage: tw checkpoint squash <feature>" ;;
    esac
}

_checkpoint_squash_feature() {
    local feature=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*) die "Unknown option: $1" ;;
            *) feature="$1"; shift ;;
        esac
    done

    [[ -z "$feature" ]] && die "Usage: tw checkpoint squash <feature>"

    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"

    # Collect worktree paths + main workspace
    local squash_paths=()
    squash_paths+=("$config_dir")

    local wt_json
    wt_json=$(python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
s = d.get(sys.argv[2], {})
wt = s.get('worktrees', {})
for path in wt.values():
    if isinstance(path, str):
        print(path)
" "$SESSIONS_FILE" "$session_key" 2>/dev/null || true)

    while IFS= read -r wt_path; do
        [[ -n "$wt_path" && "$wt_path" != "$config_dir" ]] && squash_paths+=("$wt_path")
    done <<< "$wt_json"

    local total_squashed=0
    for spath in "${squash_paths[@]}"; do
        [[ -z "$spath" || ! -d "$spath" ]] && continue
        _checkpoint_squash "$spath"
        [[ $? -eq 2 ]] && (( total_squashed++ )) || true
    done

    if [[ $total_squashed -gt 0 ]]; then
        echo "  Squashed WIP checkpoints in $total_squashed path(s) for $feature"
    else
        echo "  No WIP checkpoint commits found for $feature"
    fi
}

# ─── Daemon ───────────────────────────────────────────────────────────────────

DAEMON_PID_FILE="$TW_DIR/daemon.pid"
DAEMON_LOG_FILE="$TW_DIR/logs/daemon.log"
DAEMON_HEARTBEAT_FILE="$TW_DIR/daemon.heartbeat"
DAEMON_HUNG_THRESHOLD=900  # 15 minutes
DAEMON_STALLED_THRESHOLD=1800  # 30 minutes — alive tmux but no output change
DAEMON_CHECKPOINT_INTERVAL=600  # 10 minutes — periodic WIP commits to protect worktree changes
CRASH_COUNT_DIR="$TW_DIR/crash-counts"
HEALTH_REPORT_DIR="$TW_DIR/health"

_daemon_is_running() {
    [[ -f "$DAEMON_PID_FILE" ]] || return 1
    local pid
    pid=$(cat "$DAEMON_PID_FILE")
    kill -0 "$pid" 2>/dev/null
}

_daemon_log() {
    local ts
    ts=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$ts] $*" >> "$DAEMON_LOG_FILE"
}

_daemon_log_truncate() {
    # Keep last 1000 lines
    if [[ -f "$DAEMON_LOG_FILE" ]]; then
        local lines
        lines=$(wc -l < "$DAEMON_LOG_FILE")
        if [[ $lines -gt 1200 ]]; then
            local tmp
            tmp=$(tail -1000 "$DAEMON_LOG_FILE")
            echo "$tmp" > "$DAEMON_LOG_FILE"
        fi
    fi
}

_daemon_tick() {
    _daemon_log "heartbeat tick"

    [[ ! -f "$SESSIONS_FILE" ]] && { _daemon_log "no sessions file"; return; }

    local session_keys
    session_keys=$(sessions_list_keys 2>/dev/null) || { _daemon_log "failed to read sessions"; return; }
    [[ -z "$session_keys" ]] && { _daemon_log "no active sessions"; return; }

    local now
    now=$(date +%s)

    while IFS= read -r session_key; do
        [[ -z "$session_key" ]] && continue

        local project feature tmux_session
        project=$(sessions_get_key "$session_key" "project")
        feature=$(sessions_get_key "$session_key" "feature")
        tmux_session="$session_key"

        # Check if tmux session is alive
        if ! tmux has-session -t "=$tmux_session" 2>/dev/null; then
            _daemon_log "DEAD session: $session_key (tmux gone) — pruning"
            local sessions_data new_data
            sessions_data=$(sessions_read)
            new_data=$(python3 -c "
import json, sys
data = json.loads(sys.argv[1])
data.pop(sys.argv[2], None)
print(json.dumps(data, indent=2))
" "$sessions_data" "$session_key")
            echo "$new_data" | sessions_write
            regen_caddyfile 2>/dev/null || true
            caddy_reload 2>/dev/null || true
            continue
        fi

        # Session is alive — check workers
        # Skip if cmd_start is still spawning workers (lock file present)
        local _spawn_lock="$TW_DIR/spawn-locks/${session_key}"
        if [[ -f "$_spawn_lock" ]]; then
            # Stale lock safety: if lock is older than 5 minutes, remove it (cmd_start crashed)
            local _lock_age=$(( now - $(stat -f %m "$_spawn_lock" 2>/dev/null || echo "$now") ))
            if [[ $_lock_age -gt 300 ]]; then
                _daemon_log "WARN: stale spawn lock for $session_key (${_lock_age}s old) — removing"
                rm -f "$_spawn_lock"
            else
                _daemon_log "SKIP: $session_key has active spawn lock — cmd_start still running"
                continue
            fi
        fi

        local config_dir
        config_dir=$(sessions_get_key "$session_key" "workspace")
        [[ -z "$config_dir" ]] && { _daemon_log "WARN: $session_key has no workspace"; continue; }

        local config_file="$config_dir/.tw.yml"
        [[ ! -f "$config_file" ]] && config_file="$config_dir/.devenv.yml"
        [[ ! -f "$config_file" ]] && { _daemon_log "WARN: $session_key has no config file"; continue; }

        local override_file="$config_dir/.tw.override.yml"
        [[ ! -f "$override_file" && -f "$config_dir/.devenv.override.yml" ]] && override_file="$config_dir/.devenv.override.yml"
        local effective_config="$config_file"
        if [[ -f "$override_file" ]]; then
            effective_config=$(yaml_merge_override "$config_file" "$override_file")
        fi

        local worker_pairs
        mapfile -t worker_pairs < <(yaml_worker_pairs "$effective_config")
        local dyn_pairs
        mapfile -t dyn_pairs < <(sessions_get_dynamic_workers "$session_key")
        worker_pairs+=("${dyn_pairs[@]}")

        local bead_id
        bead_id=$(sessions_get_key "$session_key" "bead_id")

        local dead_workers=0 alive_workers=0 hung_workers=0 stalled_workers=0
        local agents_path
        agents_path="$(agents_dir "$session_key")"

        # Build health report JSON for this session
        local health_workers_json=""

        for wpair in "${worker_pairs[@]}"; do
            [[ -z "$wpair" ]] && continue
            local wname="${wpair%%:*}"; local _wpr="${wpair#*:}"; local wrole="${_wpr%%:*}"
            local wengine="${wpair##*:}"
            wengine=$(resolve_engine "$wengine" "$effective_config")
            local is_dead=0
            local worker_status="alive"
            local output_mtime=0

            # Check output file mtime
            local output_file="$agents_path/${wname}.md"
            if [[ -f "$output_file" ]]; then
                output_mtime=$(stat -f %m "$output_file" 2>/dev/null || stat -c %Y "$output_file" 2>/dev/null || echo 0)
            fi

            if tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "$wname"; then
                if worker_is_alive "$tmux_session" "$wname" "$session_key"; then
                    # Check if worker needs login — auto-send /login
                    if worker_is_not_logged_in "$tmux_session" "$wname" "$session_key"; then
                        worker_status="not-logged-in"
                        _daemon_log "WARN: $session_key/$wname not logged in — sending /login"
                        send_to_pane "=$tmux_session:$wname" "/login" 2>/dev/null || true
                    fi
                    (( alive_workers++ )) || true
                    # Check for stalled (alive but no output in DAEMON_STALLED_THRESHOLD)
                    if [[ $output_mtime -gt 0 && "$worker_status" != "not-logged-in" ]]; then
                        local age_secs=$((now - output_mtime))
                        if [[ $age_secs -gt $DAEMON_STALLED_THRESHOLD ]]; then
                            worker_status="stalled"
                            (( stalled_workers++ )) || true
                            _daemon_log "WARN: stalled worker $session_key/$wname — no output in ${age_secs}s"
                        fi
                    fi
                else
                    is_dead=1
                fi
            else
                is_dead=1
            fi

            if [[ $is_dead -eq 1 ]]; then
                # Check if worker was recently spawned (still booting)
                local _spawn_ts_file="$TW_DIR/spawn-timestamps/$session_key/$wname"
                if [[ -f "$_spawn_ts_file" ]]; then
                    local _spawn_ts
                    _spawn_ts=$(cat "$_spawn_ts_file" 2>/dev/null || echo 0)
                    local _spawn_age=$((now - _spawn_ts))
                    if [[ $_spawn_age -lt 30 ]]; then
                        _daemon_log "SKIP respawn: $session_key/$wname spawned ${_spawn_age}s ago (still booting)"
                        worker_status="booting"
                        # Still count in health report but don't respawn
                        [[ -n "$health_workers_json" ]] && health_workers_json+=","
                        health_workers_json+=$(printf '{"name":"%s","role":"%s","tmux_alive":false,"last_output_mtime":%d,"status":"booting","crash_count":0}' \
                            "$wname" "$wrole" "$output_mtime")
                        continue
                    fi
                fi

                worker_status="dead"

                # Crash counter: check if circuit breaker should block respawn
                local crash_dir="$CRASH_COUNT_DIR/$session_key"
                local crash_file="$crash_dir/$wname"
                mkdir -p "$crash_dir"
                local crash_count=0
                [[ -f "$crash_file" ]] && crash_count=$(cat "$crash_file" 2>/dev/null || echo 0)
                (( crash_count++ )) || true
                echo "$crash_count" > "$crash_file"

                if [[ $crash_count -ge 3 ]]; then
                    _daemon_log "CIRCUIT BREAKER: $session_key/$wname crashed $crash_count times — NOT respawning, escalating"
                    worker_status="circuit-broken"
                    (( dead_workers++ )) || true

                    # Escalate to god via mail if god window exists
                    if tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "god"; then
                        local crash_msg="Worker '$wname' has crashed $crash_count consecutive times. Circuit breaker activated — auto-respawn disabled. Investigate and run: tw workers $feature --respawn --force"
                        nudge_enqueue "$session_key" "god" \
                            "CIRCUIT BREAKER: $wname crashed ${crash_count}x. $crash_msg" 120 2>/dev/null || true
                        send_to_pane "=$tmux_session:god" \
                            "ALERT: Worker $wname hit circuit breaker ($crash_count crashes). Check your nudges." 2>/dev/null || true
                        _daemon_log "Escalated $wname crash to god"
                    fi
                else
                    _daemon_log "DEAD worker: $session_key/$wname (crash #$crash_count) — respawning"
                    # Kill ALL windows matching this name (tmux allows duplicates)
                    while tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "$wname"; do
                        tmux kill-window -t "=$tmux_session:$wname" 2>/dev/null || break
                    done
                    local worker_bead_id
                    worker_bead_id=$(worker_bead_find_or_create "$wname" "$project" "$config_dir" 2>/dev/null || echo "")
                    spawn_worker "$tmux_session" "$session_key" "$config_dir" "$wname" "$wrole" "$bead_id" "$worker_bead_id" "$wengine" 2>/dev/null || {
                        _daemon_log "FAIL: could not respawn $session_key/$wname"
                    }
                fi
                (( dead_workers++ )) || true
                # Don't add to health_workers_json yet — fall through
            fi

            # Append to health report workers array
            [[ -n "$health_workers_json" ]] && health_workers_json+=","
            local tmux_alive="true"
            [[ "$worker_status" == "dead" || "$worker_status" == "circuit-broken" ]] && tmux_alive="false"
            health_workers_json+=$(printf '{"name":"%s","role":"%s","tmux_alive":%s,"last_output_mtime":%d,"status":"%s","crash_count":%d}' \
                "$wname" "$wrole" "$tmux_alive" "$output_mtime" "$worker_status" \
                "$(cat "$CRASH_COUNT_DIR/$session_key/$wname" 2>/dev/null || echo 0)")
        done

        _daemon_log "session $session_key: ${alive_workers} alive, ${dead_workers} dead, ${stalled_workers} stalled, ${hung_workers} hung"

        # Write structured health report
        mkdir -p "$HEALTH_REPORT_DIR"
        local health_file="$HEALTH_REPORT_DIR/${session_key}.json"
        local health_tmp="${health_file}.tmp.$$"
        printf '{"timestamp":%d,"session":"%s","project":"%s","feature":"%s","workers":[%s]}\n' \
            "$now" "$session_key" "$project" "$feature" "$health_workers_json" > "$health_tmp"
        mv -f "$health_tmp" "$health_file"

        # Check service ports — nudge keeper if any service is down
        local services_json
        services_json=$(python3 -c "
import json, sys
d = json.loads(sys.argv[1])
s = d.get(sys.argv[2], {})
svcs = s.get('services', {})
for name, info in svcs.items():
    port = info.get('port', '')
    if port:
        print(f'{name}:{port}')
" "$sessions_data" "$session_key" 2>/dev/null || true)

        if [[ -n "$services_json" ]]; then
            while IFS=: read -r svc_name svc_port; do
                [[ -z "$svc_port" ]] && continue
                if ! lsof -i :"$svc_port" -sTCP:LISTEN >/dev/null 2>&1; then
                    _daemon_log "DOWN service: $session_key/$svc_name (port $svc_port)"
                    # Nudge the keeper worker if one exists
                    if tmux list-windows -t "=$tmux_session" -F "#{window_name}" 2>/dev/null | grep -qx "keeper"; then
                        nudge_enqueue "$session_key" "keeper" \
                            "Service $svc_name is DOWN on port $svc_port. Check the services window and restart it. Run: tw status ${feature}" \
                            30 2>/dev/null || true
                        send_to_pane "=$tmux_session:keeper" \
                            "You have a new task from the orchestrator. Check your additional context and execute it now." 2>/dev/null || true
                        _daemon_log "Nudged keeper about $svc_name"
                    fi
                fi
            done <<< "$services_json"
        fi

        # Checkpoint: periodic WIP commits to protect worktree changes
        local ckpt_dir="$TW_DIR/checkpoints"
        mkdir -p "$ckpt_dir"
        local ckpt_file="$ckpt_dir/${session_key}.last"
        local ckpt_last=0
        [[ -f "$ckpt_file" ]] && ckpt_last=$(cat "$ckpt_file" 2>/dev/null || echo 0)
        local ckpt_elapsed=$(( now - ckpt_last ))

        if [[ $ckpt_elapsed -ge $DAEMON_CHECKPOINT_INTERVAL ]]; then
            # Collect worktree paths + main workspace
            local ckpt_paths=()
            ckpt_paths+=("$config_dir")
            local wt_json
            wt_json=$(python3 -c "
import json, sys
d = json.loads(sys.argv[1])
s = d.get(sys.argv[2], {})
wt = s.get('worktrees', {})
for path in wt.values():
    if isinstance(path, str):
        print(path)
" "$(sessions_read)" "$session_key" 2>/dev/null || true)
            while IFS= read -r wt_path; do
                [[ -n "$wt_path" && "$wt_path" != "$config_dir" ]] && ckpt_paths+=("$wt_path")
            done <<< "$wt_json"

            local ckpt_made=0
            for ckpt_path in "${ckpt_paths[@]}"; do
                [[ -z "$ckpt_path" || ! -d "$ckpt_path" ]] && continue
                [[ ! -d "$ckpt_path/.git" && ! -f "$ckpt_path/.git" ]] && continue

                if ! git -C "$ckpt_path" diff --quiet 2>/dev/null || ! git -C "$ckpt_path" diff --cached --quiet 2>/dev/null; then
                    local ckpt_ts
                    ckpt_ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
                    git -C "$ckpt_path" add -A -- . ':!.claude/' ':!.beads/' ':!__pycache__/' ':!node_modules/' ':!.env*' 2>/dev/null || true
                    if ! git -C "$ckpt_path" diff --cached --quiet 2>/dev/null; then
                        git -C "$ckpt_path" commit -m "WIP: checkpoint $ckpt_ts" --no-verify 2>/dev/null && {
                            _daemon_log "Checkpoint: $session_key $(basename "$ckpt_path")"
                            (( ckpt_made++ )) || true
                        }
                    fi
                fi
            done

            echo "$now" > "$ckpt_file"
            [[ $ckpt_made -gt 0 ]] && _daemon_log "Checkpoint done: $session_key ($ckpt_made path(s))"
        fi

    done <<< "$session_keys"

    # Write heartbeat timestamp
    date +%s > "$DAEMON_HEARTBEAT_FILE"

    # Auto-close any retiring windows
    for sess in $(tmux list-sessions -F "#{session_name}" 2>/dev/null); do
        for win in $(tmux list-windows -t "=$sess" -F "#{window_name}" 2>/dev/null); do
            if [[ "$win" == *-retiring* ]]; then
                _daemon_log "Closing retiring window: $sess:$win"
                tmux kill-window -t "=$sess:$win" 2>/dev/null || true
            fi
        done
    done

    # Truncate log if needed
    _daemon_log_truncate
}

cmd_daemon() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "$subcmd" in
        start) _daemon_start "$@" ;;
        stop)  _daemon_stop ;;
        status) _daemon_status ;;
        *) die "Usage: tw daemon start [--interval=180] | stop | status" ;;
    esac
}

_daemon_start() {
    local interval=180

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --interval=*) interval="${1#--interval=}"; shift ;;
            --interval) interval="$2"; shift 2 ;;
            *) die "Unknown option: $1" ;;
        esac
    done

    if _daemon_is_running; then
        local pid
        pid=$(cat "$DAEMON_PID_FILE")
        die "Daemon already running (PID $pid). Stop it first: tw daemon stop"
    fi

    mkdir -p "$TW_DIR/logs"

    # Fork the daemon loop into background
    (
        _daemon_log "daemon started (PID $$, interval ${interval}s)"
        trap '_daemon_log "daemon stopped (PID $$)"; rm -f "$DAEMON_PID_FILE"' EXIT

        while true; do
            _daemon_tick || _daemon_log "tick error (exit code $?)"
            sleep "$interval"
        done
    ) &
    local daemon_pid=$!
    disown "$daemon_pid"
    echo "$daemon_pid" > "$DAEMON_PID_FILE"

    log "Daemon started (PID $daemon_pid, interval ${interval}s)"
    log "Log: $DAEMON_LOG_FILE"
}

_daemon_stop() {
    if ! _daemon_is_running; then
        log "Daemon is not running."
        return 0
    fi

    local pid
    pid=$(cat "$DAEMON_PID_FILE")
    kill "$pid" 2>/dev/null || true
    rm -f "$DAEMON_PID_FILE"
    log "Daemon stopped (PID $pid)."
}

_daemon_status() {
    echo ""
    if _daemon_is_running; then
        local pid
        pid=$(cat "$DAEMON_PID_FILE")
        echo "  Daemon: running (PID $pid)"
    else
        echo "  Daemon: not running"
        # Clean up stale PID file
        [[ -f "$DAEMON_PID_FILE" ]] && rm -f "$DAEMON_PID_FILE"
    fi

    if [[ -f "$DAEMON_HEARTBEAT_FILE" ]]; then
        local last_beat now age_secs
        last_beat=$(cat "$DAEMON_HEARTBEAT_FILE")
        now=$(date +%s)
        # Handle both epoch seconds and ISO datetime formats
        if [[ "$last_beat" =~ ^[0-9]+$ ]]; then
            age_secs=$((now - last_beat))
        else
            # Convert ISO datetime to epoch
            local beat_epoch
            beat_epoch=$(date -j -f '%Y-%m-%dT%H:%M:%S' "$last_beat" '+%s' 2>/dev/null || echo 0)
            age_secs=$((now - beat_epoch))
        fi
        local age_str
        if [[ $age_secs -lt 60 ]]; then
            age_str="${age_secs}s ago"
        elif [[ $age_secs -lt 3600 ]]; then
            age_str="$((age_secs / 60))m ago"
        else
            age_str="$((age_secs / 3600))h ago"
        fi
        local beat_display
        if [[ "$last_beat" =~ ^[0-9]+$ ]]; then
            beat_display=$(date -r "$last_beat" '+%Y-%m-%d %H:%M:%S')
        else
            beat_display="$last_beat"
        fi
        echo "  Last heartbeat: $beat_display ($age_str)"
    else
        echo "  Last heartbeat: never"
    fi

    if [[ -f "$DAEMON_LOG_FILE" ]]; then
        echo "  Log: $DAEMON_LOG_FILE ($(wc -l < "$DAEMON_LOG_FILE") lines)"
        echo ""
        echo "  Recent log:"
        tail -5 "$DAEMON_LOG_FILE" | sed 's/^/    /'
    fi
    echo ""
}

# ─── Tmux Integration ────────────────────────────────────────────────────────

# Called by tmux pane-died hook — capture output before respawn
cmd_pane_capture() {
    local tmux_session="$1" session_key="$2" wname="$3"
    capture_pane "=$tmux_session:$wname" "$session_key" "$wname"
}

# Called by tmux pane-died hook — respawn with rapid-fire safety
cmd_pane_respawn() {
    local tmux_session="$1" session_key="$2" wname="$3" respawn_dir="$4" config_dir="$5" wrole="${6:-}" engine="${7:-claude}"

    # Rapid respawn tracking: count respawns within 5-minute windows
    local ts_file="$respawn_dir/${wname}.timestamps"
    local now
    now=$(date +%s)
    local window=300  # 5 minutes

    # Append current timestamp
    echo "$now" >> "$ts_file"

    # Count recent respawns (within window)
    local recent_count=0
    while IFS= read -r ts; do
        [[ -z "$ts" ]] && continue
        if [[ $((now - ts)) -le $window ]]; then
            (( recent_count++ )) || true
        fi
    done < "$ts_file"

    # Prune old timestamps
    awk -v cutoff="$((now - window))" '$1 >= cutoff' "$ts_file" > "${ts_file}.tmp" 2>/dev/null
    mv -f "${ts_file}.tmp" "$ts_file" 2>/dev/null || true

    if [[ $recent_count -ge 3 ]]; then
        # Too many rapid respawns — don't respawn, let daemon/patrol handle it
        _daemon_log "RAPID RESPAWN: $session_key/$wname hit $recent_count respawns in ${window}s — stopping auto-respawn" 2>/dev/null || true
        return 0
    fi

    # For non-hook engines: check for queued tasks before respawning.
    # If no pending task, leave the pane dead to save resources.
    if ! engine_supports_hooks "$engine"; then
        local _next_task
        _next_task=$(nudge_drain_one "$session_key" "$wname")
        if [[ -z "$_next_task" ]]; then
            # Also check hooked JSON for a current_task that hasn't been started
            local _hooked_task=""
            local _hooked_file="$HOME/.tiddly-winks/hooked/${session_key}/${wname}.json"
            if [[ -f "$_hooked_file" ]]; then
                _hooked_task=$(python3 -c "
import json
try: print(json.load(open('$_hooked_file')).get('current_task', ''))
except: pass
" 2>/dev/null)
            fi
            if [[ -z "$_hooked_task" ]]; then
                _daemon_log "Non-hook worker $wname exited with no pending tasks — leaving dead" 2>/dev/null || true
                return 0
            fi
        else
            # Inject the drained task into hooked JSON so the worker boots with it
            local _hooked_file="$HOME/.tiddly-winks/hooked/${session_key}/${wname}.json"
            if [[ -f "$_hooked_file" ]]; then
                python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
d['current_task'] = sys.argv[2]
with open(sys.argv[1], 'w') as fh:
    json.dump(d, fh, indent=2)
" "$_hooked_file" "$_next_task" 2>/dev/null || true
            fi
        fi
    fi

    # Safe to respawn — use tmux respawn-pane (re-uses same window)
    sleep 3
    local _prompt_file=""
    if ! engine_supports_hooks "$engine"; then
        _prompt_file=$(engine_context_preamble "$session_key" "$wname" "$engine" 2>/dev/null || true)
    fi
    local _engine_cmd
    _engine_cmd=$(engine_spawn_cmd "$engine" "$wname" "$_prompt_file")
    tmux respawn-pane -t "=$tmux_session:$wname" \
        "cd '$config_dir' && TW_SESSION='$session_key' TW_WORKER='$wname' TW_ROLE='$wrole' $_engine_cmd" \
        2>/dev/null || true

    # Queue wake prompt with engine-appropriate delay and text
    local _wake_delay _wake_prompt
    _wake_delay=$(engine_wake_delay "$engine")
    _wake_prompt=$(engine_wake_prompt "$engine")
    (
        sleep "$_wake_delay"
        tmux send-keys -t "=$tmux_session:$wname" \
            "$_wake_prompt" Enter
    ) &
}

# Install tw-specific tmux keybindings (once per server)
_tw_install_keybindings() {
    # Check if already installed
    local installed
    installed=$(tmux show-environment -g TW_BINDINGS_INSTALLED 2>/dev/null | grep -v '^-' || true)
    [[ -n "$installed" ]] && return 0

    # N = next tw session, P = previous tw session
    tmux bind-key N run-shell "tw tmux-next"
    tmux bind-key P run-shell "tw tmux-prev"

    # G = popup session switcher
    tmux bind-key G display-popup -E -w 60 -h 20 \
        "tmux list-sessions -F '#{session_name}' | grep -E '^[a-z]+-[a-z]' | fzf --reverse --header='Switch tw session' | xargs -I{} tmux switch-client -t ={}"

    # n/p = next/prev worker window (skips god, main, services)
    tmux bind-key n run-shell "tw win-next"
    tmux bind-key p run-shell "tw win-prev"

    # g = worker menu with state
    tmux bind-key g run-shell "tw win-menu"

    tmux set-environment -g TW_BINDINGS_INSTALLED 1
    log "Installed tw tmux keybindings (N/P/G/n/p/g)"
}

# Navigate to next tw session
cmd_tmux_next() {
    local current
    current=$(tmux display-message -p '#{session_name}')
    local sessions
    sessions=$(tmux list-sessions -F '#{session_name}' | grep -E '^[a-z]+-[a-z]' || true)
    [[ -z "$sessions" ]] && return 0

    local found=0 first="" target=""
    while IFS= read -r sess; do
        [[ -z "$first" ]] && first="$sess"
        if [[ $found -eq 1 ]]; then
            target="$sess"
            break
        fi
        [[ "$sess" == "$current" ]] && found=1
    done <<< "$sessions"

    # Wrap around to first if current is last
    [[ -z "$target" ]] && target="$first"
    [[ -n "$target" ]] && tmux switch-client -t "=$target"
}

# Navigate to previous tw session
cmd_tmux_prev() {
    local current
    current=$(tmux display-message -p '#{session_name}')
    local sessions
    sessions=$(tmux list-sessions -F '#{session_name}' | grep -E '^[a-z]+-[a-z]' || true)
    [[ -z "$sessions" ]] && return 0

    local prev="" target=""
    local last=""
    while IFS= read -r sess; do
        last="$sess"
        if [[ "$sess" == "$current" ]]; then
            target="$prev"
            break
        fi
        prev="$sess"
    done <<< "$sessions"

    # Wrap around to last if current is first
    [[ -z "$target" ]] && target="$last"
    [[ -n "$target" ]] && tmux switch-client -t "=$target"
}

# Navigate to next worker window (skips god, main, services)
cmd_win_next() {
    local session current_win
    session=$(tmux display-message -p '#{session_name}')
    current_win=$(tmux display-message -p '#{window_name}')
    # Strip spinner suffix
    current_win="${current_win%% [⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]}"

    local workers=()
    while IFS= read -r wname; do
        local base="${wname%% [⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]}"
        case "$base" in
            god|main|services|[0-9]*) continue ;;
        esac
        workers+=("$base")
    done < <(tmux list-windows -t "=$session" -F "#{window_name}" 2>/dev/null)

    [[ ${#workers[@]} -eq 0 ]] && return 0

    local found=0 target=""
    for w in "${workers[@]}"; do
        if [[ $found -eq 1 ]]; then
            target="$w"
            break
        fi
        [[ "$w" == "$current_win" ]] && found=1
    done
    # Wrap around or jump to first worker if current is non-worker
    [[ -z "$target" ]] && target="${workers[0]}"
    tmux select-window -t "=$session:$target" 2>/dev/null || true
}

# Navigate to previous worker window (skips god, main, services)
cmd_win_prev() {
    local session current_win
    session=$(tmux display-message -p '#{session_name}')
    current_win=$(tmux display-message -p '#{window_name}')
    current_win="${current_win%% [⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]}"

    local workers=()
    while IFS= read -r wname; do
        local base="${wname%% [⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]}"
        case "$base" in
            god|main|services|[0-9]*) continue ;;
        esac
        workers+=("$base")
    done < <(tmux list-windows -t "=$session" -F "#{window_name}" 2>/dev/null)

    [[ ${#workers[@]} -eq 0 ]] && return 0

    local prev="" target=""
    for w in "${workers[@]}"; do
        if [[ "$w" == "$current_win" ]]; then
            target="$prev"
            break
        fi
        prev="$w"
    done
    # Wrap around to last worker
    [[ -z "$target" ]] && target="${workers[-1]}"
    tmux select-window -t "=$session:$target" 2>/dev/null || true
}

# Display a tmux menu of workers with state indicators
cmd_win_menu() {
    local session session_key feature
    session=$(tmux display-message -p '#{session_name}')

    # Derive session_key and feature from tmux session name
    session_key="$session"
    local project
    project=$(sessions_get_key "$session_key" "project" 2>/dev/null || true)
    [[ -z "$project" ]] && return 0
    feature="${session_key#"${project}-"}"

    # Build menu entries from worker windows with health state
    local menu_args=()
    while IFS= read -r wname; do
        local base="${wname%% [⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]}"
        case "$base" in
            god|main|services|[0-9]*) continue ;;
        esac
        # Check if spinning (active) based on window name having spinner char
        local state="idle"
        if [[ "$wname" =~ [⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏] ]]; then
            state="active"
        fi
        local icon="○"
        [[ "$state" == "active" ]] && icon="●"
        menu_args+=("$icon $base" "" "select-window -t =$session:$base")
    done < <(tmux list-windows -t "=$session" -F "#{window_name}" 2>/dev/null)

    if [[ ${#menu_args[@]} -eq 0 ]]; then
        tmux display-message "No worker windows"
        return 0
    fi

    # Add god window at the bottom separated by a line
    menu_args+=("" "" "")
    menu_args+=("◆ god" "" "select-window -t =$session:god")

    tmux display-menu -T "Workers: $feature" -x C -y C "${menu_args[@]}"
}

cmd_completion() {
    # Find the completion script relative to this script's location
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
    local completion_file="$script_dir/../completions/tw.bash"

    if [[ ! -f "$completion_file" ]]; then
        # Try installed location
        completion_file="$HOME/.tiddly-winks/completions/tw.bash"
    fi

    if [[ -f "$completion_file" ]]; then
        cat "$completion_file"
    else
        die "Completion script not found. Expected at: $completion_file"
    fi
}

cmd_config() {
    local sub="${1:-}"
    shift 2>/dev/null || true

    case "$sub" in
        proxy)   _config_proxy "$@" ;;
        service) _config_service "$@" ;;
        show)    _config_show "$@" ;;
        *)
            cat <<'EOF'
tw config — modify runtime session configuration

  tw config proxy <feature> <subdomain> <service>   Remap a proxy route
  tw config service <feature> <name> port <port>    Change a service's port
  tw config service <feature> <name> add <port>     Register a new service
  tw config show <feature>                          Show current runtime config

Examples:
  tw config proxy my-feature "" frontend      # route primary URL to frontend
  tw config proxy my-feature api backend      # route -api subdomain to backend
  tw config service my-feature web port 5173  # set web service port
  tw config service my-feature web add 5173   # register new service "web" on port 5173
EOF
            ;;
    esac
}

_config_resolve_session() {
    local feature="$1"
    local session_key project config_dir tmux_session bead_id
    resolve_session "$feature"
    echo "$session_key"
}

_config_proxy() {
    local feature="${1:-}" subdomain="${2:-}" service="${3:-}"
    [[ -z "$feature" || -z "$service" ]] \
        && die "Usage: tw config proxy <feature> <subdomain> <service>
  subdomain: \"\" for primary, or a name like \"api\"
  service: name of the service to proxy to (must exist in session)"

    # Allow "" to be passed as empty string for primary subdomain
    [[ "$subdomain" == '""' || "$subdomain" == "''" ]] && subdomain=""

    local session_key
    session_key=$(_config_resolve_session "$feature")

    # Verify the service exists in the session
    local sessions_data
    sessions_data=$(sessions_read)
    local svc_exists
    svc_exists=$(python3 -c "
import json, sys
d = json.loads(sys.argv[1])
s = d.get(sys.argv[2], {})
svcs = s.get('services', {})
print('yes' if sys.argv[3] in svcs else 'no')
" "$sessions_data" "$session_key" "$service" 2>/dev/null)

    [[ "$svc_exists" != "yes" ]] && die "Service '$service' not found in session '$session_key'. Available: $(python3 -c "
import json, sys
d = json.loads(sys.argv[1])
s = d.get(sys.argv[2], {})
print(', '.join(s.get('services', {}).keys()))
" "$sessions_data" "$session_key" 2>/dev/null)"

    # Update proxy_map in sessions.json
    local new_sessions
    new_sessions=$(python3 -c "
import json, sys
data = json.loads(sys.argv[1])
key = sys.argv[2]
subdomain = sys.argv[3]
service = sys.argv[4]
if key in data:
    data[key].setdefault('proxy_map', {})[subdomain] = service
print(json.dumps(data, indent=2))
" "$sessions_data" "$session_key" "$subdomain" "$service")
    echo "$new_sessions" | sessions_write

    regen_caddyfile
    caddy_reload

    local project feature_name
    project=$(echo "$sessions_data" | python3 -c "import json,sys; print(json.loads(sys.stdin.read()).get('$session_key',{}).get('project',''))")
    feature_name=$(echo "$sessions_data" | python3 -c "import json,sys; print(json.loads(sys.stdin.read()).get('$session_key',{}).get('feature',''))")

    local url
    if [[ -z "$subdomain" ]]; then
        url="http://${project}-${feature_name}.localhost"
    else
        url="http://${project}-${feature_name}-${subdomain}.localhost"
    fi

    echo "  Proxy updated: $url → $service"
    echo "  Caddy reloaded."
}

_config_service() {
    local feature="${1:-}" name="${2:-}" action="${3:-}" value="${4:-}"
    [[ -z "$feature" || -z "$name" || -z "$action" ]] \
        && die "Usage: tw config service <feature> <name> {port|add} <value>"

    local session_key
    session_key=$(_config_resolve_session "$feature")
    local sessions_data
    sessions_data=$(sessions_read)

    case "$action" in
        port)
            [[ -z "$value" ]] && die "Usage: tw config service <feature> <name> port <port>"
            local new_sessions
            new_sessions=$(python3 -c "
import json, sys
data = json.loads(sys.argv[1])
key = sys.argv[2]
name = sys.argv[3]
port = int(sys.argv[4])
if key in data and name in data[key].get('services', {}):
    data[key]['services'][name]['port'] = port
    print(json.dumps(data, indent=2))
else:
    print('ERROR', file=sys.stderr)
    sys.exit(1)
" "$sessions_data" "$session_key" "$name" "$value") \
                || die "Service '$name' not found in session '$session_key'"
            echo "$new_sessions" | sessions_write
            regen_caddyfile
            caddy_reload
            echo "  Service '$name' port updated to $value. Caddy reloaded."
            ;;
        add)
            [[ -z "$value" ]] && die "Usage: tw config service <feature> <name> add <port>"
            local new_sessions
            new_sessions=$(python3 -c "
import json, sys
data = json.loads(sys.argv[1])
key = sys.argv[2]
name = sys.argv[3]
port = int(sys.argv[4])
if key in data:
    data[key].setdefault('services', {})[name] = {'port': port}
    print(json.dumps(data, indent=2))
else:
    print('ERROR', file=sys.stderr)
    sys.exit(1)
" "$sessions_data" "$session_key" "$name" "$value") \
                || die "Session '$session_key' not found"
            echo "$new_sessions" | sessions_write
            regen_caddyfile
            caddy_reload
            echo "  Service '$name' added on port $value. Caddy reloaded."
            ;;
        *)
            die "Unknown action '$action'. Use: port, add"
            ;;
    esac
}

_config_show() {
    local feature="${1:-}"
    [[ -z "$feature" ]] && die "Usage: tw config show <feature>"

    local session_key
    session_key=$(_config_resolve_session "$feature")
    local sessions_data
    sessions_data=$(sessions_read)

    python3 - "$sessions_data" "$session_key" <<'PYEOF'
import json, sys

data = json.loads(sys.argv[1])
key = sys.argv[2]
s = data.get(key)
if not s:
    print(f"  No session '{key}' found.")
    sys.exit(1)

project = s.get('project', '')
feature = s.get('feature', '')
services = s.get('services', {})
proxy_map = s.get('proxy_map', {})

print(f"  Session: {key}")
print()
print("  Services:")
for name, info in services.items():
    port = info.get('port', '?')
    print(f"    {name}: port {port}")

print()
print("  Proxy routes:")
for subdomain, svc_name in proxy_map.items():
    svc = services.get(svc_name, {})
    port = svc.get('port', '?')
    if subdomain == '':
        host = f'http://{project}-{feature}.localhost'
    else:
        host = f'http://{project}-{feature}-{subdomain}.localhost'
    print(f"    {host} → {svc_name} (:{port})")
PYEOF
}

# ─── Dispatch ─────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
tw — tiddly-winks: feature space manager

Commands:
  tw init [--force]                     Analyze project and generate .tw.yml (uses Claude)
  tw start <feature>[,...] [--mode staging]  Create feature space(s) (worktrees, DB, services)
  tw stop <feature|N>[,...] [--done]      Stop session(s) (--done tears down worktrees + closes bead)
  tw done <feature|N>[,...]               Stop session(s) AND tear down worktrees + close bead (explicit done)
  tw list [--project=X] [--json]         List active sessions
  tw attach [<N>|<name>] [--window=X]    Attach to a session (defaults to god window)

Agent commands (used by Claude workers):
  tw workers <feature>                  Spawn missing worker windows into a running session
  tw workers <feature> --health [--json] Check worker state (working/idle/stalled/done/dead)
  tw workers <feature> --cv <name>     Show worker CV and work history
  tw workers <feature> --respawn [--force] Respawn dead workers (--force overrides circuit breaker)
  tw handoff <feature> <worker>         Cycle a worker's session (save context, restart fresh)
  tw patrol <feature>                   Health check: workers, services, stuck detection, auto-respawn
  tw spawn <feature> <name> <role>      Dynamically spawn a new worker into a running session
  tw signal <feature> <worker> done     Signal task completion (worker stays alive, available for reuse)
  tw signal <feature> <worker> clear    Clear all signals for a worker
  tw hook {set|clear|show} <feature> <worker>  Manage GUPP hooks on workers
  tw send <feature> <worker> "<task>" [--urgent]   Queue a nudge for a worker (clears done signal)
  tw nudge enqueue <session> <worker> "<msg>" [ttl] Enqueue a raw nudge message
  tw nudge drain <session> <worker>     Drain and print all queued nudges
  tw status <feature> [--json]           Show ports, URLs, worktrees, bead
  tw open <feature>                     Open primary URL in browser
  tw editor <feature>                   Generate per-feature .code-workspace and open in VS Code
  tw claude <feature>                   Open/attach to god (orchestrator) window
  tw append <feature>                   Append wrap-up text to bead (reads from stdin)
  tw setup claude                       Install hooks for auto-injecting tw prime
  tw prime                              AI workflow context (inject via hooks)
  tw onboard                            Generate AGENTS.md snippet
  tw prune                              Remove stale sessions after reboot
  tw reconcile [<feature>]              Derive state from reality (filesystem, tmux, beads)
  tw resume <feature>[,...]             Resume feature(s) from bead state after hard reset
  tw resume --all                       Resume all in-progress features from beads
  tw gates <feature> [--gate=NAME]       Run quality gates (all or specific)
  tw config proxy <feature> <sub> <svc>   Remap a proxy route at runtime
  tw config service <feature> <n> port <p> Update a service's port
  tw config service <feature> <n> add <p>  Register a new service
  tw config show <feature>                Show runtime config (services + proxies)
  tw doctor                              Run health checks on tw environment
  tw daemon start [--interval=180]        Start background health-check daemon
  tw daemon stop                          Stop the daemon
  tw daemon status                        Show daemon status + last heartbeat

Config file: .tw.yml (also accepts .devenv.yml for compatibility)
URLs: http://{project}-{feature}.localhost (Chrome/Firefox only — not Safari)
Docs: https://github.com/bentleycook/tiddly-winks
EOF
}

[[ $# -eq 0 ]] && { usage; exit 0; }

subcommand="$1"; shift
case "$subcommand" in
    init)    cmd_init "$@" ;;
    start)   cmd_start "$@" ;;
    stop)    cmd_stop "$@" ;;
    done)    cmd_done "$@" ;;
    list)    cmd_list "$@" ;;
    status)  cmd_status "$@" ;;
    open)    cmd_open "$@" ;;
    editor)  cmd_editor "$@" ;;
    prune)   cmd_prune "$@" ;;
    resume)  cmd_resume "$@" ;;
    claude)  cmd_claude "$@" ;;
    append)  cmd_append "$@" ;;
    spawn)   cmd_spawn "$@" ;;
    review)  cmd_review "$@" ;;
    checkpoint) cmd_checkpoint "$@" ;;
    workers) cmd_workers "$@" ;;
    handoff) cmd_handoff "$@" ;;
    attach)  cmd_attach "$@" ;;
    patrol)  cmd_patrol "$@" ;;
    feed)    cmd_feed "$@" ;;
    hook)    cmd_hook "$@" ;;
    send)    cmd_send "$@" ;;
    tasks)   cmd_tasks "$@" ;;
    signal)  cmd_signal "$@" ;;
    setup)   cmd_setup "$@" ;;
    prime)   cmd_prime ;;
    onboard) cmd_onboard ;;
    gates)   cmd_gates "$@" ;;
    daemon)  cmd_daemon "$@" ;;
    config)     cmd_config "$@" ;;
    completion) cmd_completion ;;
    port-owner) cmd_port_owner "$@" ;;
    pane-id)    cmd_pane_id "$@" ;;
    doctor)  cmd_doctor "$@" ;;
    engine-stats) cmd_engine_stats "$@" ;;
    mail)    cmd_mail "$@" ;;
    nudge)   cmd_nudge "$@" ;;
    pane-capture)  cmd_pane_capture "$@" ;;
    pane-respawn)  cmd_pane_respawn "$@" ;;
    tmux-next)     cmd_tmux_next ;;
    tmux-prev)     cmd_tmux_prev ;;
    win-next)      cmd_win_next ;;
    win-prev)      cmd_win_prev ;;
    win-menu)      cmd_win_menu ;;
    reconcile) cmd_reconcile "$@" ;;
    status-bar) cmd_status_bar "$@" ;;
    help|--help|-h) usage ;;
    *) die "Unknown subcommand: $subcommand. Run 'tw help' for usage." ;;
esac
